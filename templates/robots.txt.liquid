{%- comment -%}
  Overrides Shopify's default robots.txt to explicitly allow AI and LLM crawlers.
{%- endcomment -%}

{%- for group in robots.default_groups -%}
  {{- group.user_agent -}}

  {%- for rule in group.rules -%}
    {{- rule -}}
  {%- endfor -%}

  {%- if group.sitemap != blank -%}
    {{ group.sitemap }}
  {%- endif -%}
{% endfor %}

