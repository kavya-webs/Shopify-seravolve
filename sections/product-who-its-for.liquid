<section class="py-16 lg:py-24 px-6 lg:px-20 bg-white">
  <div class="max-w-4xl mx-auto">
    {%- assign who_its_for = product.metafields.custom.who_its_for.value -%}
    
    {%- if who_its_for != blank -%}
      <div class="bg-brand-aqua-mist/10 rounded-3xl p-8 lg:p-12 border border-brand-charcoal/5">
        <h3 class="font-serif text-2xl lg:text-3xl text-brand-slate mb-8 text-center">Who It's For</h3>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {%- for person in who_its_for -%}
            <div class="flex items-center space-x-3 text-brand-slate-light">
              <svg class="w-5 h-5 text-brand-aqua flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
              <span class="font-medium">{{ person }}</span>
            </div>
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Product Who Its For",
  "settings": [],
  "presets": [
    {
      "name": "Product Who Its For"
    }
  ]
}
{% endschema %}
