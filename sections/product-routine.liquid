<section id="routine-section" class="py-32 lg:py-48 px-6 lg:px-20 bg-white hidden">
  <div class="max-w-7xl mx-auto">
    <div class="mb-20 text-center lg:text-left">
      <p class="text-[9px] uppercase tracking-[0.5em] font-bold mb-4 text-brand-aqua">The Performance</p>
      <h2 class="font-serif text-4xl lg:text-6xl font-light leading-[1.05] text-brand-slate">Application Routine</h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-16 relative">
        <div class="block max-md:hidden absolute top-[28px] left-[10%] right-[10%] h-px bg-brand-aqua/20 z-0"></div>
        <div id="routine-steps-container" class="contents">
          <!-- Routine steps injected via JS -->
        </div>
    </div>

    <div class="mt-24 p-12 lg:p-16 bg-brand-aqua-mist/20 rounded-[48px] border border-brand-aqua/10 flex flex-col lg:flex-row items-center justify-between gap-12">
        <div class="flex items-center space-x-6">
          <div class="w-16 h-16 rounded-full bg-brand-aqua/10 flex items-center justify-center text-brand-aqua">
              <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22a7 7 0 0 0 7-7c0-2-1-3.9-3-5.5s-3.5-4-4-6.5c-.5 2.5-2 4.9-4 6.5C6 11.1 5 13 5 15a7 7 0 0 0 7 7z"/></svg>
          </div>
          <div>
              <p class="text-[9px] uppercase tracking-widest font-bold text-brand-aqua">Routine Frequency</p>
              <p id="routine-frequency" class="text-xl font-serif text-brand-slate"></p>
          </div>
        </div>
        <div class="h-px w-full lg:w-px lg:h-16 bg-brand-marble"></div>
        <div class="max-w-md">
          <p class="text-[10px] uppercase tracking-widest font-bold text-brand-slate opacity-40 mb-2">Concierge Tip</p>
          <p id="routine-protip" class="text-sm text-brand-slate-light font-medium leading-relaxed"></p>
        </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Product Routine",
  "settings": [],
  "presets": [
    {
      "name": "Product Routine"
    }
  ]
}
{% endschema %}
