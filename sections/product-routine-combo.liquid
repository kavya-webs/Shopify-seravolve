<section id="routine-combo-section" class="py-16 lg:py-24 px-6 lg:px-20 bg-white">
  <div class="max-w-7xl mx-auto">
    <div class="mb-20 text-center lg:text-left">
      <p class="text-[9px] uppercase tracking-[0.5em] font-bold mb-4 text-brand-aqua">The Performance</p>
      <h2 class="font-serif text-4xl lg:text-6xl font-light leading-[1.05] text-brand-slate">Routine Sequence</h2>
    </div>

    {%- assign routine_products = product.metafields.custom.routine_products.value -%}
    
    {%- if routine_products != blank -%}
      <div class="grid grid-cols-1 md:grid-cols-3 gap-16 relative">
          <div class="block max-md:hidden absolute top-[28px] left-[10%] right-[10%] h-px bg-brand-aqua/20 z-0"></div>
          
          {%- for p in routine_products -%}
            <div class="relative z-10 flex flex-col group">
              <!-- Step Number Bubble -->
              <div class="w-14 h-14 rounded-full bg-white border border-brand-charcoal/10 flex items-center justify-center mb-8 mx-auto md:mx-0 shadow-xl shadow-brand-charcoal/5 group-hover:scale-110 group-hover:bg-brand-aqua group-hover:text-white group-hover:border-brand-aqua transition-all duration-300">
                <span class="font-serif text-2xl text-brand-slate group-hover:text-white">{{ forloop.index }}</span>
              </div>

              <!-- Product Image -->
              <div class="w-1/2 md:w-full max-w-[180px] md:max-w-none mx-auto md:mx-0 aspect-[3/4] rounded-[32px] overflow-hidden bg-[#f8faf9] mb-8 relative border border-brand-charcoal/5">
                <img src="{{ p.featured_image | image_url: width: 600 }}" alt="{{ p.title }}" class="w-full h-full object-cover mix-blend-multiply opacity-90 group-hover:scale-105 transition-transform duration-700">
                <div class="absolute inset-0 bg-brand-charcoal/5 opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none"></div>
              </div>

              <!-- Text Content -->
              <div class="text-center md:text-left flex-grow flex flex-col">
                <h3 class="font-serif text-2xl text-brand-slate mb-3 group-hover:text-brand-aqua transition-colors">{{ p.title | split: 'for' | first | strip }}</h3>
                <p class="text-sm text-brand-slate/60 leading-relaxed font-light mb-4">{{ p.type | default: 'Treatment' }}</p>
                <div class="mt-auto">
                  <p class="text-xs uppercase tracking-widest font-bold text-brand-aqua mb-2">When to use</p>
                  <p class="text-sm text-brand-slate-light font-medium">{% if p.handle contains 'night' %}PM Only{% elsif p.handle contains 'spf' or p.handle contains 'sunscreen' %}AM Only{% else %}AM / PM{% endif %}</p>
                </div>
              </div>
            </div>
          {%- endfor -%}
      </div>

      <div class="mt-24 p-12 lg:p-16 bg-brand-aqua-mist/20 rounded-[48px] border border-brand-aqua/10 flex flex-col lg:flex-row items-center justify-between gap-12">
          <div class="flex items-center space-x-6">
            <div class="w-16 h-16 rounded-full bg-brand-aqua/10 flex items-center justify-center text-brand-aqua">
                <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22a7 7 0 0 0 7-7c0-2-1-3.9-3-5.5s-3.5-4-4-6.5c-.5 2.5-2 4.9-4 6.5C6 11.1 5 13 5 15a7 7 0 0 0 7 7z"/></svg>
            </div>
            <div>
                <p class="text-[9px] uppercase tracking-widest font-bold text-brand-aqua">Routine Frequency</p>
                <p class="text-xl font-serif text-brand-slate">Daily Use</p>
            </div>
          </div>
          <div class="h-px w-full lg:w-px lg:h-16 bg-brand-marble"></div>
          <div class="max-w-md">
            <p class="text-[10px] uppercase tracking-widest font-bold text-brand-slate opacity-40 mb-2">Concierge Tip</p>
            <p class="text-sm text-brand-slate-light font-medium leading-relaxed">Apply products in order from thinnest consistency to thickest for optimal absorption and barrier protection.</p>
          </div>
      </div>
    {%- else -%}
      <p class="text-center text-brand-slate/50 italic py-12 border border-dashed border-brand-charcoal/20 rounded-2xl">Please link products to this routine using the `custom.routine_products` metafield to display the application sequence.</p>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Product Routine Combo",
  "settings": [],
  "presets": [
    {
      "name": "Product Routine Combo"
    }
  ]
}
{% endschema %}
