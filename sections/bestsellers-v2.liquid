<section class="w-full bg-white pt-16 pb-20 lg:py-28">
  <div class="max-w-7xl mx-auto px-6 lg:px-12">
    <!-- Section Header -->
    <div class="flex items-end justify-between mb-10">
      <div>
        <p class="text-[10px] uppercase tracking-[0.4em] font-accent font-bold text-brand-aqua mb-3 animate-fade-in">
          {{ section.settings.subheading | escape }}
        </p>
        <h2 class="font-serif text-3xl lg:text-5xl text-brand-slate animate-fade-up">
          {{ section.settings.heading }}
        </h2>
      </div>

      <!-- Desktop Arrows -->
      <div class="flex max-lg:hidden items-center space-x-2">
        <button id="bestsellers-prev-{{ section.id }}" class="w-10 h-10 rounded-full border border-brand-marble/40 flex items-center justify-center hover:bg-brand-aqua-mist hover:border-brand-aqua/30 transition-all">
          <svg class="w-4 h-4 text-brand-slate" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
        </button>
        <button id="bestsellers-next-{{ section.id }}" class="w-10 h-10 rounded-full border border-brand-marble/40 flex items-center justify-center hover:bg-brand-aqua-mist hover:border-brand-aqua/30 transition-all">
          <svg class="w-4 h-4 text-brand-slate" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        </button>
      </div>
    </div>

    <!-- Horizontal Snap Carousel -->
    {%- assign collection = collections[section.settings.collection] -%}
    {%- if collection == blank -%}
      {%- assign collection = collections['all'] -%}
    {%- endif -%}
    {%- assign product_limit = section.settings.products_to_show -%}
    {%- assign routine_count = 0 -%}
    <div id="bestsellers-scroll-{{ section.id }}" class="flex gap-4 overflow-x-auto snap-x-mandatory scrollbar-hide pb-4 -mx-6 px-6 lg:mx-0 lg:px-0">
      {%- for product in collection.products -%}
        {%- unless product.title contains 'Routine' or product.title contains 'Ritual' -%}
          {%- continue -%}
        {%- endunless -%}
        {%- assign routine_count = routine_count | plus: 1 -%}
        {%- if routine_count > product_limit -%}
          {%- break -%}
        {%- endif -%}
        <div class="snap-start shrink-0 w-[75vw] sm:w-[55vw] lg:w-[calc(33.33%-1rem)] group animate-fade-up" style="animation-delay: {{ routine_count | times: 0.08 | at_most: 0.4 }}s;">
          <a href="{{ product.url }}" class="flex flex-col">
            <!-- Image -->
            <div class="relative aspect-[3/4] rounded-3xl overflow-hidden mb-4">
              {%- if product.featured_image -%}
                <img src="{{ product.featured_image | image_url: width: 600 }}" alt="{{ product.title | escape }}" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" {% if forloop.index <= 2 %}loading="eager" fetchpriority="high"{% else %}loading="lazy"{% endif %} width="600" height="800">
              {%- else -%}
                <div class="w-full h-full bg-brand-aqua-mist flex items-center justify-center">
                  <span class="text-brand-aqua/30 font-serif text-xl">SERAVOLVE</span>
                </div>
              {%- endif -%}

              <!-- Price badge -->
              <div class="absolute top-4 right-4">
                <div class="bg-brand-gold/90 backdrop-blur-sm px-3 py-1.5 rounded-full shadow-md">
                  <span class="text-white text-[11px] font-accent font-bold">
                    {{ product.price | money }}
                  </span>
                </div>
              </div>
            </div>

            <!-- Info -->
            <div class="px-1 flex flex-col">
              <p class="text-[9px] uppercase tracking-[0.2em] font-accent font-bold text-brand-aqua mb-1.5">
                {{ product.type | default: "Skincare" }}
              </p>
              <h3 class="font-serif text-lg text-brand-slate group-hover:text-brand-aqua transition-colors leading-snug mb-2 line-clamp-2">
                {{ product.title }}
              </h3>
              <div class="flex items-center justify-between mt-auto pt-3 border-t border-brand-marble/15">
                <span class="text-[10px] uppercase tracking-[0.15em] font-accent font-bold text-brand-slate/40 group-hover:text-brand-aqua transition-colors flex items-center gap-1">
                  Learn More <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                </span>
              </div>
            </div>
          </a>
        </div>
      {%- else -%}
        <!-- Fallback if no collection selected -->
        {%- for i in (1..3) -%}
           <div class="snap-start shrink-0 w-[75vw] sm:w-[55vw] lg:w-[calc(33.33%-1rem)] group animate-fade-up">
              <div class="flex flex-col">
                 <div class="relative aspect-[3/4] rounded-3xl overflow-hidden mb-4 bg-gray-100 flex items-center justify-center">
                    <span class="text-gray-400">Select collection</span>
                 </div>
                 <div class="px-1 flex flex-col">
                    <p class="text-[9px] uppercase tracking-[0.2em] font-accent font-bold text-brand-aqua mb-1.5">Skincare</p>
                    <h3 class="font-serif text-lg text-brand-slate leading-snug mb-2">Example Product</h3>
                 </div>
              </div>
           </div>
        {%- endfor -%}
      {%- endfor -%}
    </div>

    <!-- Dot indicators (mobile) -->
    <div id="bestsellers-dots-{{ section.id }}" class="flex lg:hidden items-center justify-center space-x-1.5 mt-6">
      {%- assign dot_count = 0 -%}
      {%- for product in collection.products -%}
        {%- unless product.title contains 'Routine' or product.title contains 'Ritual' -%}{%- continue -%}{%- endunless -%}
        {%- assign dot_count = dot_count | plus: 1 -%}
        {%- if dot_count > product_limit -%}{%- break -%}{%- endif -%}
        <div class="carousel-dot transition-all duration-300 rounded-full {% if dot_count == 1 %}w-5 h-1.5 bg-brand-aqua{% else %}w-1.5 h-1.5 bg-brand-marble/40{% endif %}" data-index="{{ dot_count | minus: 1 }}"></div>
      {%- endfor -%}
    </div>

    <!-- View All -->
    <div class="text-center mt-12">
      <a href="{{ collection.url | default: routes.collections_url | append: '/all' }}" class="inline-flex items-center space-x-2 text-[10px] uppercase tracking-[0.3em] font-accent font-bold text-brand-slate hover:text-brand-aqua transition-colors group">
        <span>Shop All Formulations</span>
        <svg class="w-3.5 h-3.5 group-hover:translate-x-1 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const container = document.getElementById('bestsellers-scroll-{{ section.id }}');
    const prevBtn = document.getElementById('bestsellers-prev-{{ section.id }}');
    const nextBtn = document.getElementById('bestsellers-next-{{ section.id }}');
    const dots = document.querySelectorAll('#bestsellers-dots-{{ section.id }} .carousel-dot');
    
    if(!container) return;

    const updateDots = () => {
      const scrollLeft = container.scrollLeft;
      const cardWidth = container.firstElementChild?.clientWidth || 280;
      const gap = 16;
      const idx = Math.round(scrollLeft / (cardWidth + gap));
      
      dots.forEach((dot, i) => {
        if(i === idx) {
          dot.classList.remove('w-1.5', 'bg-brand-marble/40');
          dot.classList.add('w-5', 'bg-brand-aqua');
        } else {
          dot.classList.add('w-1.5', 'bg-brand-marble/40');
          dot.classList.remove('w-5', 'bg-brand-aqua');
        }
      });
    };

    container.addEventListener('scroll', updateDots, { passive: true });

    const scrollToDirection = (dir) => {
      const cardWidth = container.firstElementChild?.clientWidth || 280;
      const gap = 16;
      const offset = dir === 'left' ? -(cardWidth + gap) : cardWidth + gap;
      container.scrollBy({ left: offset, behavior: 'smooth' });
    };

    if(prevBtn) prevBtn.addEventListener('click', () => scrollToDirection('left'));
    if(nextBtn) nextBtn.addEventListener('click', () => scrollToDirection('right'));
  });
</script>

<style>
  .scrollbar-hide::-webkit-scrollbar {
      display: none;
  }
  .scrollbar-hide {
      -ms-overflow-style: none;
      scrollbar-width: none;
  }
</style>

{% schema %}
{
  "name": "Bestsellers Carousel",
  "settings": [
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Curated For You"
    },
    {
      "type": "html",
      "id": "heading",
      "label": "Heading",
      "default": "The <span class=\"italic font-light\">Collection</span>"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 3,
      "max": 12,
      "step": 1,
      "default": 3,
      "label": "Products to show"
    }
  ],
  "presets": [
    {
      "name": "Bestsellers Carousel"
    }
  ]
}
{% endschema %}
