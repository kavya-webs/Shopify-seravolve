<div class="w-full min-h-screen bg-white">
  <!-- Load Enrichment Data -->
  {% capture enrichment_json %}{% render 'product-enrichment' %}{% endcapture %}
  
  <script>
    // Make enrichment data available to JS if needed
    window.productEnrichmentData = {{ enrichment_json }};
  </script>

  <style>
    .hide-scrollbar::-webkit-scrollbar { display: none; }
    .hide-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
  </style>

  <!-- 1. HERO SPLIT SECTION -->
  <section id="product-hero-{{ section.id }}" class="relative w-full flex flex-col lg:flex-row min-h-screen bg-white">
    <!-- Slider Column (Sticky) -->
    <div class="w-full lg:w-1/2 lg:sticky lg:top-32 lg:h-[calc(100vh-128px)] bg-brand-aqua-mist/30 flex flex-col items-center justify-center p-8 lg:p-20 overflow-hidden">
      <div class="relative w-full aspect-[4/5] rounded-[40px] overflow-hidden shadow-2xl bg-white mb-10 group mt-24 lg:mt-0">
        
        <!-- Sliding Track (Scroll Snap) -->
        <div id="product-gallery-track" class="absolute inset-0 flex overflow-x-auto snap-x snap-mandatory scroll-smooth hide-scrollbar">
          {% for media in product.media %}
            <div class="w-full h-full flex-shrink-0 snap-center snap-always">
              <img
                src="{{ media | image_url: width: 800 }}"
                alt="{{ media.alt | escape }}"
                class="w-full h-full object-cover"
                loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                width="800"
                height="1000"
              >
            </div>
          {% endfor %}
        </div>

        <!-- Navigation Controls -->
        <div class="absolute inset-0 flex items-center justify-between px-6 opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none hidden md:flex">
           <button id="gallery-prev" class="pointer-events-auto w-12 h-12 glass rounded-full flex items-center justify-center text-brand-slate hover:bg-brand-aqua hover:text-white transition-all transform hover:scale-110">
             <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
           </button>
           <button id="gallery-next" class="pointer-events-auto w-12 h-12 glass rounded-full flex items-center justify-center text-brand-slate hover:bg-brand-aqua hover:text-white transition-all transform hover:scale-110">
             <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
           </button>
        </div>

        <!-- Soft Branding Overlay -->
        <div class="absolute top-8 left-8 pointer-events-none">
          <p id="gallery-label" class="text-[9px] uppercase tracking-[0.4em] font-bold text-brand-slate/40">
            Biological Focus 1
          </p>
        </div>
      </div>

      <!-- Progress Indicators (Dots) -->
      <div id="gallery-dots" class="flex space-x-3 items-center">
         {% for media in product.media %}
            <button
              data-index="{{ forloop.index0 }}"
              class="gallery-dot h-1.5 rounded-full transition-all duration-500 {% if forloop.first %}w-12 bg-brand-aqua{% else %}w-3 bg-brand-marble hover:bg-brand-aqua/40{% endif %}"
            ></button>
         {% endfor %}
      </div>
    </div>

    <!-- Info Column -->
    <div class="w-full lg:w-1/2 p-8 lg:p-24 lg:pt-64 flex flex-col justify-center relative">
       
       <!-- Render any app blocks placed in this section here -->
       {%- for block in section.blocks -%}
          {%- render block -%}
       {%- endfor -%}

       <div class="animate-fade-up" style="animation-delay: 0.2s; animation-fill-mode: forwards;">
          <nav class="mb-16 flex items-center space-x-4">
            <a href="{{ routes.all_products_collection_url }}" class="text-[9px] uppercase tracking-[0.3em] font-bold text-brand-slate-light/40 hover:text-brand-aqua transition-colors">
               Library
             </a>
             <div class="h-px w-6 bg-brand-marble"></div>
             <span class="text-[9px] uppercase tracking-[0.3em] font-bold text-brand-aqua enrichment-concern">
               {{ product.type | default: 'Skincare' }}
             </span>
          </nav>

           <h1 class="font-serif text-4xl lg:text-6xl font-light text-brand-slate mb-6 leading-[1.05]">
             {{ product.title }}
           </h1>
           <p class="text-[10px] lg:text-xs font-sans uppercase tracking-[0.4em] text-brand-slate-light font-bold mb-16 enrichment-tagline">
             {{ product.type | default: 'Treatment' }}
          </p>

           <div class="h-px w-full bg-brand-marble/50 mb-16"></div>

          <div class="flex items-center justify-between mb-16">
             <div class="space-y-2">
                <p class="text-[9px] uppercase tracking-[0.4em] font-bold text-brand-aqua opacity-80">Biological Mission</p>
                <p class="text-sm lg:text-base font-medium text-brand-slate-light max-w-sm enrichment-mission">{{ product.description | strip_html | truncate: 60 }}</p>
              </div>
              <p class="font-serif text-2xl lg:text-3xl font-medium text-brand-slate">{{ product.price | money_without_trailing_zeros }}</p>
          </div>

           <div class="text-sm lg:text-base leading-relaxed text-brand-slate-light/80 mb-20 font-medium">
             {{ product.description }}
           </div>

          <div class="flex flex-col sm:flex-row gap-8 mt-12">
             {% form 'product', product, id: 'product-form', class: 'w-full sm:w-auto' %}
                <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
                <button 
                  type="submit"
                  name="add"
                  {% unless product.available %}disabled{% endunless %}
                  class="w-full sm:w-[240px] py-6 rounded-full text-[10px] uppercase tracking-[0.3em] font-black shadow-2xl flex items-center justify-center space-x-3 transition-all duration-500 {% if product.available %}bg-brand-aqua-deep text-white hover:bg-brand-aqua hover:-translate-y-1{% else %}bg-brand-aqua-deep/50 text-white opacity-50 cursor-not-allowed{% endif %}"
                >
                  <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><path d="M3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
                  <span>
                    {% if product.available %}Add to Routine{% else %}Sold Out{% endif %}
                  </span>
                </button>
             {% endform %}
             
             <a href="{{ routes.all_products_collection_url }}" class="flex-1 glass text-brand-slate py-6 rounded-full text-[10px] uppercase tracking-[0.3em] font-black border border-brand-marble hover:border-brand-aqua hover:-translate-y-1 transition-all duration-500 text-center flex items-center justify-center">
               Browse Collection
             </a>
          </div>

          <div class="mt-12 flex flex-col space-y-3 items-center lg:items-start">
            <p class="text-[10px] lg:text-[11px] uppercase tracking-[0.2em] font-black text-brand-slate-light">
              FREE DELIVERY ON ORDERS ₹999+
            </p>
            <p class="text-[10px] uppercase tracking-[0.3em] font-black text-brand-aqua/40 italic">
              CLINICAL CLEARANCE: FINAL SALE 
            </p>
          </div>

          <div class="mt-24 grid grid-cols-2 gap-12 pt-12 border-t border-brand-marble/30">
             <div>
               <p class="text-[10px] font-black text-brand-aqua uppercase tracking-[0.4em] mb-3">Target Concern</p>
               <p class="text-xs lg:text-sm font-black uppercase tracking-[0.2em] text-brand-slate enrichment-concern">{{ product.type }}</p>
             </div>
             <div>
               <p class="text-[10px] font-black text-brand-aqua uppercase tracking-[0.4em] mb-3">Potency Level</p>
               <p class="text-xs lg:text-sm font-black uppercase tracking-[0.2em] text-brand-slate">Molecular Grade</p>
             </div>
          </div>
       </div>
    </div>
  </section>

</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const handle = "{{ product.handle }}";
    const data = window.productEnrichmentData;
    const enrichment = data ? data[handle] : null;

    // Apply Enrichment Data to HTML
    if (enrichment) {
      document.querySelectorAll('.enrichment-tagline').forEach(el => el.textContent = enrichment.tagline);
      document.querySelectorAll('.enrichment-concern').forEach(el => el.textContent = enrichment.concern);
      document.querySelectorAll('.enrichment-mission').forEach(el => el.textContent = enrichment.mission);

      // Render Science
      const scienceSection = document.getElementById('science-section');
      const ingredientsContainer = document.getElementById('ingredients-container');
      const bioNotes = document.getElementById('bio-notes');
      
      if (scienceSection && enrichment.science) {
        scienceSection.classList.remove('hidden');
        if(bioNotes) bioNotes.textContent = enrichment.science.bioNotes;
        
        let ingredientsHtml = '';
        enrichment.science.ingredients.forEach((ing, i) => {
          ingredientsHtml += `
            <div class="bg-white p-12 rounded-[40px] border border-brand-marble/30 shadow-sm hover:shadow-xl hover:border-brand-aqua/20 transition-all duration-500 animate-fade-up" style="animation-delay: ${i * 0.1}s;">
              <div class="flex items-center space-x-4 mb-8">
                <div class="w-12 h-12 rounded-full bg-brand-aqua-mist flex items-center justify-center text-brand-aqua">
                   <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 2v7.31"/><path d="M14 9.3V1.99"/><path d="M8.5 2h7"/><path d="M14 9.3a6.5 6.5 0 1 1-4 0"/><path d="M5.52 16h12.96"/></svg>
                </div>
                 <div>
                  <h4 class="font-serif text-xl lg:text-2xl font-light text-brand-slate">${ing.name}</h4>
                 </div>
              </div>
              <p class="text-sm text-brand-slate-light font-medium leading-relaxed border-t border-brand-marble/30 pt-6">
                ${ing.benefit}
              </p>
            </div>
          `;
        });
        if(ingredientsContainer) ingredientsContainer.innerHTML = ingredientsHtml;
      }

      // Render Routine
      const routineSection = document.getElementById('routine-section');
      const stepsContainer = document.getElementById('routine-steps-container');
      const frequency = document.getElementById('routine-frequency');
      const protip = document.getElementById('routine-protip');

      if (routineSection && enrichment.routine) {
        routineSection.classList.remove('hidden');
        if(frequency) frequency.textContent = enrichment.routine.frequency;
        if(protip) protip.textContent = '"' + enrichment.routine.proTip + '"';

        let stepsHtml = '';
        enrichment.routine.steps.forEach((step, i) => {
          stepsHtml += `
            <div class="relative z-10 flex flex-col items-center md:items-start text-center md:text-left animate-fade-up" style="animation-delay: ${i * 0.2}s;">
              <div class="w-14 h-14 bg-brand-slate text-white rounded-full flex items-center justify-center font-serif text-xl font-light mb-10 shadow-lg border-4 border-white">
                ${step.phase}
              </div>
              <h4 class="font-serif text-2xl lg:text-3xl font-light text-brand-slate mb-3">${step.title}</h4>
              <p class="text-sm text-brand-slate-light leading-relaxed font-medium">
                ${step.instruction}
              </p>
            </div>
          `;
        });
        if(stepsContainer) stepsContainer.innerHTML = stepsHtml;
      }
    }

    // Default FAQs
    let faqs = [
      {
        question: `What skin types is {{ product.title | escape }} suitable for?`,
        answer: "This formula is designed for all skin types. It is non-comedogenic, meaning it won't clog pores. If you have highly reactive or sensitised skin, we recommend a patch test before first use.",
      },
      {
        question: "How long before I see visible results?",
        answer: enrichment
          ? "Studies show initial improvements within 14 days of consistent use, with full results visible at the 8-week mark. Individual results may vary based on skin condition and routine consistency."
          : "Most users begin to notice improvements within 2–4 weeks of daily use. For optimal results, we recommend consistent application as part of your morning and evening routine.",
      },
      {
        question: "Can I use this with other active ingredients?",
        answer: "Yes. This product is compatible with most skincare actives. However, if you are using prescription retinoids or strong chemical exfoliants (AHA/BHA), we suggest alternating usage days to prevent over-sensitisation.",
      },
      {
        question: "Is this product tested on animals?",
        answer: "Absolutely not. SERAVOLVE is proudly cruelty-free and never tests on animals at any stage of development. All efficacy testing is conducted through in-vitro studies and voluntary human trials.",
      },
      {
        question: "What is the shelf life after opening?",
        answer: "Once opened, this product retains full potency for 12 months (12M PAO). Store in a cool, dry place away from direct sunlight to preserve the active ingredients.",
      }
    ];

    const faqContainer = document.getElementById('faq-container');
    if (faqContainer) {
      let faqHtml = '';
      faqs.forEach((faq, i) => {
        faqHtml += `
          <div class="border-b border-brand-marble/30 last:border-b-0 faq-item">
            <button class="faq-toggle w-full flex items-center justify-between py-8 text-left group">
              <span class="font-serif text-base lg:text-lg text-brand-slate group-hover:text-brand-aqua transition-colors duration-300 pr-8">
                ${faq.question}
              </span>
              <div class="faq-icon flex-shrink-0 w-10 h-10 rounded-full bg-brand-aqua-mist flex items-center justify-center text-brand-aqua transition-transform duration-300">
                <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
              </div>
            </button>
            <div class="faq-content overflow-hidden" style="max-height: 0; transition: max-height 0.3s ease-in-out;">
              <p class="pb-8 text-sm lg:text-base text-brand-slate-light/70 leading-relaxed font-medium pl-1">
                ${faq.answer}
              </p>
            </div>
          </div>
        `;
      });
      faqContainer.innerHTML = faqHtml;

      // Add FAQ Toggle Logic
      const toggles = document.querySelectorAll('.faq-toggle');
      toggles.forEach(toggle => {
        toggle.addEventListener('click', function() {
          const content = this.nextElementSibling;
          const icon = this.querySelector('.faq-icon');
          
          if (content.style.maxHeight !== '0px' && content.style.maxHeight !== '') {
            content.style.maxHeight = '0px';
            icon.style.transform = 'rotate(0deg)';
          } else {
            // Close all other FAQs
            document.querySelectorAll('.faq-content').forEach(c => c.style.maxHeight = '0px');
            document.querySelectorAll('.faq-icon').forEach(i => i.style.transform = 'rotate(0deg)');
            
            content.style.maxHeight = content.scrollHeight + 'px';
            icon.style.transform = 'rotate(180deg)';
          }
        });
      });
    }

    // Gallery Slider Logic - Snap Scroll Integration
    const track = document.getElementById('product-gallery-track');
    const dots = document.querySelectorAll('.gallery-dot');
    const prevBtn = document.getElementById('gallery-prev');
    const nextBtn = document.getElementById('gallery-next');
    const label = document.getElementById('gallery-label');
    let currentIndex = 0;
    const totalImages = {{ product.media.size }};
    let isScrolling = false;

    function updateGalleryUI() {
      if(label) label.textContent = \`Biological Focus \${currentIndex + 1}\`;
      
      dots.forEach((dot, index) => {
        if (index === currentIndex) {
          dot.classList.replace('w-3', 'w-12');
          dot.classList.replace('bg-brand-marble', 'bg-brand-aqua');
          dot.classList.remove('hover:bg-brand-aqua/40');
        } else {
          dot.classList.replace('w-12', 'w-3');
          dot.classList.replace('bg-brand-aqua', 'bg-brand-marble');
          dot.classList.add('hover:bg-brand-aqua/40');
        }
      });
    }

    function scrollToCurrent() {
       if(!track) return;
       isScrolling = true;
       track.scrollTo({ left: track.clientWidth * currentIndex, behavior: 'smooth' });
       updateGalleryUI();
       
       // allow scroll event listener to pick up natural swipes again after auto-scroll finishes
       setTimeout(() => {
           isScrolling = false;
       }, 500);
    }

    if (track) {
      track.addEventListener('scroll', () => {
         if(isScrolling) return; // Prevent race conditions with button clicks
         
         const newIndex = Math.round(track.scrollLeft / track.clientWidth);
         if (newIndex !== currentIndex && newIndex >= 0 && newIndex < totalImages) {
           currentIndex = newIndex;
           updateGalleryUI();
         }
      }, { passive: true });
    }

    if (prevBtn) {
      prevBtn.addEventListener('click', () => {
        currentIndex = (currentIndex - 1 + totalImages) % totalImages;
        scrollToCurrent();
      });
    }

    if (nextBtn) {
      nextBtn.addEventListener('click', () => {
        currentIndex = (currentIndex + 1) % totalImages;
        scrollToCurrent();
      });
    }

    dots.forEach(dot => {
      dot.addEventListener('click', () => {
        currentIndex = parseInt(dot.getAttribute('data-index'));
        scrollToCurrent();
      });
    });

  });
</script>

{% schema %}
{
  "name": "Main Product",
  "settings": [],
  "blocks": [
    {
      "type": "@app"
    }
  ],
  "presets": [
    {
      "name": "Main Product Hero"
    }
  ]
}
{% endschema %}
