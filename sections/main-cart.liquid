{% schema %}
{
  "name": "Cart",
  "settings": [],
  "presets": [
    {
      "name": "Cart"
    }
  ]
}
{% endschema %}

<!-- Load Alpine.js -->


<script>
  function formatMoney(cents) {
    if (typeof cents === 'string') {
      cents = cents.replace('.', '');
    }
    const formatter = new Intl.NumberFormat('en-IN', {
      style: 'currency',
      currency: 'INR',
      minimumFractionDigits: 0,
    });
    return formatter.format(cents / 100);
  }

  document.addEventListener('alpine:init', () => {
    const productMeta = {
      {% for item in cart.items %}
        "{{ item.key }}": {
           stepNumber: {{ item.product.metafields.custom.step_number | default: 'null' }},
           isRoutine: {% if item.product.title contains 'Routine' or item.product.title contains 'Ritual' %}true{% else %}false{% endif %}
        }{% unless forloop.last %},{% endunless %}
      {% endfor %}
    };

    Alpine.data('cartApp', () => ({
      cart: {{ cart | json }},
      productMeta: productMeta,
      loading: false,

      get completedSteps() {
        if (!this.cart.items || this.cart.items.length === 0) return 0;
        const stepsFound = new Set();
        this.cart.items.forEach(item => {
          const meta = this.productMeta[item.key];
          if (meta && meta.stepNumber) {
            stepsFound.add(meta.stepNumber);
          }
        });
        return stepsFound.size;
      },

      get hasRoutine() {
        if (!this.cart.items || this.cart.items.length === 0) return false;
        return this.cart.items.some(item => {
          const meta = this.productMeta[item.key];
          return meta && meta.isRoutine;
        });
      },

      async changeQuantity(line, quantity) {
        if (this.loading) return;
        this.loading = true;
        try {
          const response = await fetch(window.Shopify.routes.root + 'cart/change.js', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              'Accept': 'application/json'
            },
            body: JSON.stringify({ line, quantity })
          });
          const newCart = await response.json();
          this.cart = newCart;
        } catch (error) {
          console.error("Error updating cart:", error);
        } finally {
          this.loading = false;
        }
      },

      async removeItem(line) {
        await this.changeQuantity(line, 0);
      }
    }));
  });
</script>

<div x-data="cartApp" class="w-full min-h-screen bg-brand-aqua-mist/10 pb-32 pt-32 lg:pt-48">
  <div class="max-w-7xl mx-auto px-6 lg:px-20">
    
    <div class="mb-12 pt-[64px] pb-[40px]">
      <h1 class="font-serif text-[30px] lg:text-[40px] font-semibold text-brand-slate leading-none mb-4">Almost there.</h1>
      <p class="text-[16px] font-normal text-brand-slate-light">Review your routine before checkout.</p>
    </div>

    <!-- Empty Cart View -->
    <div x-show="cart.item_count === 0" style="display: none;" class="glass p-16 lg:p-32 rounded-[40px] border border-brand-marble/30 text-center shadow-sm">
      <div class="w-32 h-32 mx-auto text-brand-aqua mb-8">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full opacity-60"><circle cx="12" cy="12" r="10"/><path d="M12 8v8"/><path d="M8 12h8"/></svg>
      </div>
      <h2 class="font-serif text-3xl lg:text-5xl font-light text-brand-slate mb-6">Your routine starts here.</h2>
      <p class="text-[16px] text-brand-slate-light font-normal mb-12 max-w-md mx-auto">Answer a few simple questions and we'll recommend the right skincare routine for your skin.</p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/pages/routine-builder" class="inline-flex items-center justify-center px-10 py-5 bg-brand-aqua-deep text-white rounded-full text-[10px] uppercase tracking-[0.3em] font-black hover:bg-brand-aqua transition-all duration-300 shadow-xl">
          Find My Routine
        </a>
        <a href="{{ routes.all_products_collection_url }}" class="inline-flex items-center justify-center px-10 py-5 bg-white text-brand-slate border border-brand-marble/40 rounded-full text-[10px] uppercase tracking-[0.3em] font-black hover:bg-brand-aqua-mist transition-all duration-300 shadow-sm">
          Shop Products
        </a>
      </div>
    </div>

    <!-- Cart Items View -->
    <div x-show="cart.item_count > 0" class="flex flex-col lg:flex-row gap-12 lg:gap-16 items-start relative">
      
      <!-- Items List -->
      <div class="w-full lg:w-2/3 space-y-6">
        <template x-for="(item, index) in cart.items" :key="item.key">
          <div class="glass p-4 md:p-6 rounded-[24px] md:rounded-[32px] border border-brand-marble/30 flex flex-row items-stretch md:items-center gap-4 md:gap-6 shadow-sm transition-opacity duration-300 relative" :class="{ 'opacity-50 pointer-events-none': loading }">
            
            <!-- Image -->
            <a :href="item.url" class="block w-24 md:w-32 flex-shrink-0 bg-white rounded-xl md:rounded-2xl overflow-hidden border border-brand-marble/10 aspect-[3/4]">
              <img :src="item.image" :alt="item.product_title" class="w-full h-full object-cover mix-blend-multiply" />
            </a>

            <!-- Details -->
            <div class="flex-1 flex flex-col justify-between py-1 min-w-0">
              <div class="flex justify-between items-start mb-3 md:mb-4 pr-8 md:pr-0">
                <div class="min-w-0">
                  <a :href="item.url" class="font-serif text-[17px] md:text-2xl lg:text-3xl font-light text-brand-slate hover:text-brand-aqua transition-colors line-clamp-2 leading-tight" x-text="item.product_title"></a>
                  <template x-if="item.variant_title && item.variant_title !== 'Default Title'">
                    <p class="text-[10px] uppercase tracking-[0.2em] font-bold text-brand-slate-light/60 mt-1" x-text="item.variant_title"></p>
                  </template>
                  <template x-if="productMeta[item.key] && productMeta[item.key].stepNumber">
                    <p class="text-[10px] md:text-[12px] uppercase tracking-[1px] text-brand-slate-light font-bold mt-1.5 md:mt-2">
                      STEP <span x-text="productMeta[item.key].stepNumber"></span> OF 5 <span class="mx-1">&bull;</span>
                      <template x-if="productMeta[item.key].stepNumber == 1"><span>Cleanse</span></template>
                      <template x-if="productMeta[item.key].stepNumber == 2"><span>Prep</span></template>
                      <template x-if="productMeta[item.key].stepNumber == 3"><span>Treat</span></template>
                      <template x-if="productMeta[item.key].stepNumber == 4"><span>Hydrate</span></template>
                      <template x-if="productMeta[item.key].stepNumber == 5"><span>Protect</span></template>
                    </p>
                  </template>
                </div>
                <button @click="removeItem(index + 1)" class="absolute top-4 right-4 md:static w-8 h-8 md:w-10 md:h-10 rounded-full bg-brand-marble/10 flex items-center justify-center text-brand-slate-light hover:text-red-500 hover:bg-red-50 transition-colors flex-shrink-0 md:ml-4">
                  <svg class="w-3.5 h-3.5 md:w-4 md:h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/><line x1="10" y1="11" x2="10" y2="17"/><line x1="14" y1="11" x2="14" y2="17"/></svg>
                </button>
              </div>

              <div class="flex flex-row items-center justify-between mt-auto">
                <!-- Quantity Controls -->
                <div class="flex items-center space-x-1 p-1 bg-white border border-brand-marble/30 rounded-full shadow-inner">
                  <button @click="changeQuantity(index + 1, item.quantity - 1)" class="w-8 h-8 rounded-full flex items-center justify-center text-brand-slate hover:bg-brand-aqua-mist transition-colors">
                    <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/></svg>
                  </button>
                  <span class="w-8 text-center text-[11px] font-bold text-brand-slate" x-text="item.quantity"></span>
                  <button @click="changeQuantity(index + 1, item.quantity + 1)" class="w-8 h-8 rounded-full flex items-center justify-center text-brand-slate hover:bg-brand-aqua-mist transition-colors">
                    <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5v14"/></svg>
                  </button>
                </div>
                
                <!-- Price -->
                <div class="text-right flex flex-col">
                  <span class="text-[17px] md:text-2xl font-mono font-medium md:font-light text-brand-slate tracking-tighter" x-text="formatMoney(item.final_line_price)"></span>
                  <template x-if="item.original_line_price > item.final_line_price">
                     <span class="text-[10px] md:text-xs font-mono text-brand-slate-light/60 line-through" x-text="formatMoney(item.original_line_price)"></span>
                  </template>
                </div>
              </div>
            </div>
          </div>
        </template>
        {% render 'routine-completion' %}
        {% render 'cart-trust-section' %}
      </div>

      <!-- Order Summary (Sticky) -->
      <div class="w-full lg:w-1/3 lg:sticky lg:top-32">
        <div class="glass p-8 lg:p-12 rounded-[40px] border border-brand-marble/30 shadow-2xl relative overflow-hidden transition-opacity duration-300" :class="{ 'opacity-50 pointer-events-none': loading }">
          
          <div class="absolute top-0 right-0 w-64 h-64 bg-brand-aqua/5 blur-[80px] rounded-full pointer-events-none"></div>

          <h3 class="font-serif text-3xl font-light text-brand-slate mb-8 relative z-10">Order Summary</h3>
          
          <div class="space-y-4 mb-8 relative z-10 border-b border-brand-marble/30 pb-8">
            <div class="flex justify-between items-center text-sm">
              <span class="text-brand-slate-light font-medium">Subtotal</span>
              <span class="font-mono text-brand-slate font-medium" x-text="formatMoney(cart.items_subtotal_price)"></span>
            </div>
            
            <!-- Discounts -->
            <template x-if="cart.total_discount > 0">
              <div class="flex justify-between items-center text-sm text-brand-aqua">
                <span class="font-bold">Discounts</span>
                <span class="font-mono font-bold" x-text="'-' + formatMoney(cart.total_discount)"></span>
              </div>
            </template>

            <div class="flex justify-between items-center text-sm">
              <span class="text-brand-slate-light font-medium">Shipping</span>
              <span class="text-[10px] uppercase tracking-widest font-bold text-brand-slate-light/60">Calculated at next step</span>
            </div>
          </div>

          <div class="flex justify-between items-end mb-10 relative z-10">
            <span class="text-[10px] uppercase tracking-[0.3em] font-black text-brand-slate">Estimated Total</span>
            <span class="font-mono text-4xl lg:text-5xl font-light text-brand-slate tracking-tighter" x-text="formatMoney(cart.total_price)"></span>
          </div>

          <form action="{{ routes.cart_url }}" method="post" id="cart-checkout-form" class="relative z-10">
            <!-- Add Routine Text -->
            <template x-if="!hasRoutine && completedSteps > 0 && completedSteps < 5">
              <div class="mb-6 p-4 bg-brand-aqua-mist/50 rounded-2xl border border-brand-aqua/20">
                <p class="text-[10px] uppercase tracking-widest font-bold text-brand-aqua mb-1">Your Routine</p>
                <p class="text-[13px] text-brand-slate leading-tight font-medium"><span x-text="completedSteps"></span> of 5 essential steps selected. Complete your routine for the best daily experience.</p>
              </div>
            </template>
            <template x-if="hasRoutine || completedSteps === 5">
              <div class="mb-6 p-4 bg-brand-aqua-mist/50 rounded-2xl border border-brand-aqua/20">
                <p class="text-[10px] uppercase tracking-widest font-bold text-brand-aqua mb-1">Your Routine</p>
                <p class="text-[13px] text-brand-slate leading-tight font-medium">Your daily skincare routine is complete and ready.</p>
              </div>
            </template>

            <button type="submit" name="checkout" class="w-full py-4 rounded-full text-[10px] md:text-[12px] uppercase tracking-widest md:tracking-[0.2em] font-black shadow-xl flex items-center justify-center space-x-2 md:space-x-3 transition-all duration-300 bg-brand-charcoal text-white hover:bg-brand-aqua hover:-translate-y-1">
              <span>Secure Checkout</span>
              <svg class="w-3.5 h-3.5 md:w-4 md:h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            </button>
          </form>

          <div class="mt-6 flex justify-center items-center gap-2 flex-wrap opacity-60 relative z-10">
            <span class="px-2 py-1 border border-brand-marble/50 rounded-md text-[9px] font-bold tracking-wider uppercase text-brand-slate-light">Visa</span>
            <span class="px-2 py-1 border border-brand-marble/50 rounded-md text-[9px] font-bold tracking-wider uppercase text-brand-slate-light">Mastercard</span>
            <span class="px-2 py-1 border border-brand-marble/50 rounded-md text-[9px] font-bold tracking-wider uppercase text-brand-slate-light">UPI</span>
            <span class="px-2 py-1 border border-brand-marble/50 rounded-md text-[9px] font-bold tracking-wider uppercase text-brand-slate-light">GPay</span>
            <span class="px-2 py-1 border border-brand-marble/50 rounded-md text-[9px] font-bold tracking-wider uppercase text-brand-slate-light">PhonePe</span>
            <span class="px-2 py-1 border border-brand-marble/50 rounded-md text-[9px] font-bold tracking-wider uppercase text-brand-slate-light">Shop Pay</span>
          </div>
          
          <div class="mt-4 text-center relative z-10">
            <p class="text-[11px] text-brand-slate-light/60">Taxes calculated at checkout.</p>
          </div>
        </div>

      </div>
    </div>

    <!-- Mobile Sticky Checkout -->
    <div x-show="cart.item_count > 0" class="lg:hidden fixed bottom-0 left-0 right-0 z-50 bg-white border-t border-brand-marble/30 p-4 pb-safe flex items-center justify-between shadow-[0_-10px_30px_rgba(0,0,0,0.05)]">
      <div>
        <p class="text-[10px] uppercase tracking-widest font-bold text-brand-slate-light mb-0.5">Total</p>
        <p class="font-mono text-xl font-medium text-brand-slate tracking-tighter" x-text="formatMoney(cart.total_price)"></p>
      </div>
      <button @click="document.getElementById('cart-checkout-form').submit()" class="h-12 px-6 rounded-full text-[10px] uppercase tracking-[0.2em] font-black shadow-lg flex items-center justify-center space-x-2 transition-all bg-brand-charcoal text-white hover:bg-brand-aqua">
        <span>Checkout</span>
      </button>
    </div>

  </div>
</div>
