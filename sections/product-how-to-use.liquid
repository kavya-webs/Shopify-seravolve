<section class="py-20 lg:py-32 px-6 lg:px-20 bg-brand-charcoal text-white relative overflow-hidden">
  <div class="max-w-4xl mx-auto relative z-10">
    <div class="mb-20 text-center">
      <p class="text-[9px] uppercase tracking-[0.5em] font-bold mb-6 text-brand-aqua">The Application</p>
      <h2 class="font-serif text-3xl lg:text-5xl font-light mb-10">How To Use</h2>
      
      <div class="inline-flex space-x-4">
        {%- if product.handle contains 'night' -%}
          <span class="bg-brand-slate text-xs font-bold uppercase tracking-widest px-4 py-2 rounded-full text-white">Night Routine</span>
        {%- elsif product.handle contains 'spf' or product.handle contains 'sunscreen' -%}
          <span class="bg-white/10 text-xs font-bold uppercase tracking-widest px-4 py-2 rounded-full text-white">Morning Routine</span>
        {%- else -%}
          <span class="bg-white/10 text-xs font-bold uppercase tracking-widest px-4 py-2 rounded-full text-white">Morning & Night</span>
        {%- endif -%}
      </div>
    </div>

    {%- assign how_to_use = product.metafields.custom.how_to_use_steps.value -%}
    
    <div class="max-w-2xl mx-auto pl-8 md:pl-0">
      {%- if how_to_use != blank -%}
        <div class="space-y-12 relative before:absolute before:inset-0 before:ml-[11px] md:before:mx-auto md:before:translate-x-0 before:w-px before:bg-white/10">
          {%- for step in how_to_use -%}
            <div class="relative flex items-center md:justify-between w-full">
              <!-- Dot -->
              <div class="absolute left-0 md:left-1/2 w-6 h-6 rounded-full bg-brand-aqua text-white font-bold text-xs flex items-center justify-center -translate-x-[50%] z-10">{{ forloop.index }}</div>
              
              <!-- Content -->
              <div class="w-full md:w-[45%] {% cycle 'pl-10 md:pl-0 md:text-right', 'pl-10 md:pr-0 md:text-left md:ml-auto' %}">
                <p class="font-serif text-lg text-white/90 leading-relaxed">{{ step }}</p>
              </div>
            </div>
          {%- endfor -%}
        </div>
      {%- endif -%}

      {%- assign routines = product.metafields.custom.parent_routines.value -%}
      {%- if routines != blank -%}
        {%- assign primary_routine = routines.first -%}
        {%- assign all_products = primary_routine.metafields.custom.routine_products.value -%}
        {%- assign next_product = nil -%}
        {%- assign found_current = false -%}
        
        {%- for p in all_products -%}
          {%- if found_current -%}
            {%- assign next_product = p -%}
            {%- break -%}
          {%- endif -%}
          {%- if p.id == product.id -%}
            {%- assign found_current = true -%}
          {%- endif -%}
        {%- endfor -%}

        {%- if next_product != blank -%}
          <div class="mt-16 flex justify-center md:justify-end">
            <a href="{{ next_product.url }}" class="group bg-brand-aqua/20 border border-brand-aqua/30 rounded-2xl p-6 flex items-center space-x-6 hover:bg-brand-aqua/30 transition-all max-w-sm w-full">
              <div class="w-16 h-16 rounded-xl overflow-hidden bg-brand-charcoal/10 flex-shrink-0">
                {%- if next_product.featured_image != blank -%}
                  <img src="{{ next_product.featured_image | image_url: width: 200 }}" alt="{{ next_product.title | escape }}" class="w-full h-full object-cover">
                {%- else -%}
                  {{ 'product-1' | placeholder_svg_tag: 'w-full h-full object-cover opacity-50' }}
                {%- endif -%}
              </div>
              <div>
                <p class="text-[9px] uppercase tracking-widest font-bold text-brand-aqua mb-1">Next Step</p>
                <p class="text-sm font-medium text-white group-hover:text-brand-aqua transition-colors">Pairs best with {{ next_product.title | split: 'for' | first | strip }}</p>
              </div>
            </a>
          </div>
        {%- endif -%}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Product How To Use",
  "settings": [],
  "presets": [
    {
      "name": "Product How To Use"
    }
  ]
}
{% endschema %}
