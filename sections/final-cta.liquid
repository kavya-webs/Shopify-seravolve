<section class="w-full relative overflow-hidden">
  <!-- Transition gradient white -> glacial -->
  <div class="h-16 bg-gradient-to-b from-white to-brand-glacial"></div>

  <div class="bg-brand-glacial pb-20 pt-12 lg:pt-20 lg:pb-32">
    <div class="max-w-md lg:max-w-2xl mx-auto px-6 text-center">
      <div class="animate-fade-up" style="animation-duration: 0.7s; animation-fill-mode: forwards;">
        <p class="text-[9px] uppercase tracking-[0.4em] font-accent font-bold text-brand-aqua mb-6">
          {{ section.settings.tagline | escape }}
        </p>
        <h2 class="font-serif text-2xl lg:text-4xl text-brand-slate mb-6 leading-tight">
          {{ section.settings.heading }}
        </h2>
        <p class="text-sm text-brand-slate/50 font-light mb-12 max-w-md mx-auto text-center">
          {{ section.settings.description | escape }}
        </p>

        {% form 'customer', id: 'newsletter-form', class: 'flex flex-col sm:flex-row gap-4 w-full max-w-md mx-auto' %}
          <input type="hidden" name="contact[tags]" value="newsletter">
          
          {% if form.posted_successfully? %}
            <div class="flex items-center justify-center space-x-3 bg-brand-aqua-mist rounded-full py-4 px-6 w-full animate-fade-in">
              <div class="w-6 h-6 rounded-full bg-brand-aqua flex items-center justify-center">
                <svg class="w-3 h-3 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              </div>
              <span class="text-sm font-medium text-brand-slate">
                Welcome to the ritual ✨
              </span>
            </div>
          {% else %}
            <div class="flex flex-col sm:flex-row gap-4 w-full">
              <input
                type="email"
                name="contact[email]"
                id="NewsletterEmail"
                value="{% if customer %}{{ customer.email }}{% endif %}"
                placeholder="{{ section.settings.email_placeholder | escape }}"
                required
                class="flex-1 px-6 py-4 rounded-full border border-brand-marble/40 bg-white text-sm text-brand-slate placeholder:text-brand-slate/30 focus:outline-none focus:border-brand-aqua/50 focus:ring-2 focus:ring-brand-aqua/10 transition-all"
              >
              <button
                type="submit"
                name="commit"
                class="group flex items-center justify-center space-x-2 bg-brand-slate text-white px-8 py-4 rounded-full text-[11px] uppercase tracking-[0.15em] font-accent font-bold hover:bg-brand-aqua transition-all duration-300 shadow-md active:scale-[0.97] shrink-0"
              >
                <span>{{ section.settings.button_label | escape }}</span>
                <svg class="w-3.5 h-3.5 group-hover:translate-x-1 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
              </button>
            </div>
          {% endif %}
        {% endform %}

        <p class="text-xs text-brand-slate/60 mt-8 font-medium">
          {{ section.settings.footer_text | escape }}
        </p>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Final CTA",
  "settings": [
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "Join the Ritual"
    },
    {
      "type": "html",
      "id": "heading",
      "label": "Heading",
      "default": "Stay <span class=\"italic font-light\">Connected</span> With Us"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Subscribe to our newsletter for early access to new products, clinical skincare tips, and exclusive offers."
    },
    {
      "type": "text",
      "id": "email_placeholder",
      "label": "Email Placeholder",
      "default": "Your email address"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Subscribe"
    },
    {
      "type": "text",
      "id": "footer_text",
      "label": "Footer Text",
      "default": "No spam, ever. Unsubscribe anytime."
    }
  ],
  "presets": [
    {
      "name": "Final CTA"
    }
  ]
}
{% endschema %}
