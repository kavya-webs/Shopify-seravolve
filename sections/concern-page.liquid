<div class="concern-page-wrapper  antialiased text-brand-slate bg-white">

  <!-- ==========================================
       SECTION 1: HERO (Cinematic & Edge-to-Edge)
       ========================================== -->
  <section class="relative w-full h-[85vh] md:h-screen flex flex-col items-center justify-center overflow-hidden bg-[#F6FBFD] px-4 md:px-0">
    <!-- Background Texture -->
    {% assign bg_asset = section.settings.hero_bg_asset | default: 'texture-gel-blue.png' %}
    <img src="{{ bg_asset | asset_url }}" class="absolute inset-0 w-full h-full object-cover scale-105" loading="eager" fetchpriority="high" alt="Background Texture">
    
    <div class="relative z-10 text-center mx-4 px-8 py-12 md:px-14 md:py-14 w-full max-w-[92%] md:w-auto md:max-w-3xl mx-auto flex flex-col items-center justify-center mt-8 md:mt-12 bg-white/40 backdrop-blur-xl border border-white/50 shadow-2xl rounded-[2rem]">
      <span class="text-[10px] uppercase tracking-[0.4em] font-bold text-brand-aqua mb-4">{{ section.settings.hero_label }}</span>
      <h1 class="text-[2.2rem] leading-[1.1] md:text-5xl lg:text-6xl text-brand-slate tracking-tight mb-5">{{ section.settings.hero_heading | newline_to_br }}</h1>
      <p class="text-sm md:text-base text-brand-slate/75 max-w-lg font-light leading-relaxed mb-8">{{ section.settings.hero_body }}</p>
      <a href="#routine" class="px-8 py-4 bg-brand-slate text-white rounded-full text-[11px] font-bold uppercase tracking-[0.2em] hover:bg-brand-slate/90 active:scale-[0.97] transition-all duration-300 shadow-lg shadow-brand-slate/15">{{ section.settings.hero_btn_1 }}</a>
    </div>
  </section>

  <!-- ==========================================
       SECTION 2: THE MECHANICS (Creative Cards)
       ========================================== -->
  <section class="py-32 lg:py-48 px-6 lg:px-20 bg-white">
    <div class="max-w-6xl mx-auto flex flex-col items-center text-center">
      <h2 class=" text-3xl md:text-5xl text-brand-slate mb-24 max-w-3xl leading-tight">{{ section.settings.understand_heading | newline_to_br }}</h2>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-12 w-full text-left">
        {% assign count = 1 %}
        {% for block in section.blocks %}
          {% if block.type == 'why_happens_card' %}
            <div class="group relative bg-[#F6FBFD] rounded-[32px] p-10 md:p-12 hover:shadow-[0_20px_40px_rgba(44,62,80,0.08)] hover:-translate-y-2 transition-all duration-500 overflow-hidden border border-brand-aqua/10">
              
              <!-- Decorative Numeral Watermark -->
              <span class="absolute -bottom-6 -right-6 text-[180px] font-bold text-brand-aqua/[0.04] group-hover:text-brand-aqua/[0.08] transition-colors duration-500 leading-none pointer-events-none select-none">0{{ count }}</span>
              
              <div class="relative z-10">
                <!-- Icon or Image -->
                <div class="w-14 h-14 rounded-2xl bg-white flex items-center justify-center shadow-sm mb-8 overflow-hidden">
                  {% if block.settings.image != blank %}
                    {{ block.settings.image | image_url: width: 120 | image_tag: class: 'w-full h-full object-cover', loading: 'lazy' }}
                  {% else %}
                    <!-- Fallback SVG Icon -->
                    <svg class="w-6 h-6 text-brand-aqua" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" />
                    </svg>
                  {% endif %}
                </div>
                
                <h3 class="text-brand-slate font-bold text-2xl mb-4">{{ block.settings.title }}</h3>
                <p class="text-brand-slate/70 text-lg font-medium leading-relaxed">{{ block.settings.text }}</p>
              </div>
            </div>
            {% assign count = count | plus: 1 %}
          {% endif %}
        {% endfor %}
      </div>
      
      <p class="mt-24 text-xl font-medium text-brand-slate tracking-wide relative inline-block">
        {{ section.settings.why_bottom }}
        <span class="absolute -bottom-4 left-1/2 -translate-x-1/2 w-12 h-1 bg-brand-aqua/30 rounded-full"></span>
      </p>
    </div>
  </section>

  <!-- ==========================================
       SECTION 3: THE PROTOCOL (Sticky Split-Screen)
       ========================================== -->
  <section id="routine" class="relative bg-white border-t border-gray-900/5">
    <div class="flex flex-col lg:flex-row">
      
      <!-- Sticky Left Side: Product -->
      <div class="lg:w-1/2 lg:sticky lg:top-0 h-[60vh] lg:h-screen relative overflow-hidden bg-slate-50">
        
        <!-- Product Image Float -->
        <div class="absolute inset-0 flex items-center justify-center p-12">
          {% assign bundle_block = section.blocks | where: 'type', 'bundle_card' | first %}
          {% assign prod = all_products[bundle_block.settings.product] %}
          {% if prod != blank and prod.featured_image != blank %}
            {{ prod.featured_image | image_url: width: 900 | image_tag: class: 'w-full max-w-md h-auto object-contain drop-shadow-[0_30px_60px_rgba(0,0,0,0.15)] hover:scale-105 transition-transform duration-1000 ease-out', loading: 'lazy' }}
          {% else %}
            <img src="{{ 'heroimg.webp' | asset_url }}" class="w-full max-w-md h-auto object-contain drop-shadow-[0_30px_60px_rgba(0,0,0,0.15)] hover:scale-105 transition-transform duration-1000 ease-out" loading="lazy">
          {% endif %}
        </div>
      </div>
      
      <!-- Scrolling Right Side: Info -->
      <div class="lg:w-1/2 py-24 px-8 lg:px-24 lg:py-40 flex flex-col justify-center min-h-screen bg-white">
        <div class="max-w-lg mx-auto w-full">
          <h3 class=" text-3xl md:text-5xl text-brand-slate mb-8 leading-tight">{{ section.settings.routine_headline | newline_to_br }}</h3>
          <p class="text-xl text-brand-slate/70 font-light mb-20 leading-relaxed">{{ section.settings.routine_subheading | newline_to_br }}</p>
          
          <div class="space-y-20">
            <!-- Details -->
            <div>
              <h4 class="text-[10px] uppercase tracking-[0.4em] font-bold text-brand-aqua mb-8 border-b border-gray-900/10 pb-4">The System</h4>
              <div class="text-brand-slate/70 text-lg font-light leading-relaxed space-y-6 [&>p]:mb-4 [&>ul]:list-disc [&>ul]:ml-5 [&>ul>li]:mb-3 [&>ul>li>strong]:font-bold [&>ul>li>strong]:text-brand-slate">
                {{ bundle_block.settings.description }}
              </div>
              
              <form action="/cart/add" method="post" class="mt-12 sticky bottom-4 z-50 lg:relative lg:bottom-0">
                <input type="hidden" name="id" value="{{ prod.variants.first.id }}">
                <button type="submit" class="w-full py-5 bg-brand-slate text-white rounded-full font-bold text-sm tracking-widest uppercase hover:bg-brand-charcoal hover:scale-[1.02] transition-all duration-300 flex justify-center gap-4 items-center px-8 shadow-2xl lg:shadow-xl">
                  <span>BUY NOW</span>
                  <span class="w-1.5 h-1.5 rounded-full bg-white/40"></span>
                  <span class="text-white">{{ prod.price | money }}</span>
                </button>
              </form>
            </div>
            
            <!-- Why It Works -->
            <div>
              <h4 class="text-[10px] uppercase tracking-[0.4em] font-bold text-brand-aqua mb-8 border-b border-gray-900/10 pb-4">Protocol Specifications</h4>
              <ul class="space-y-6">
                {% for block in section.blocks %}
                  {% if block.type == 'why_choose_card' %}
                    <li class="flex items-center gap-5 text-brand-slate text-lg font-medium">
                      <svg class="w-5 h-5 text-brand-charcoal shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                      {{ block.settings.title }}
                    </li>
                  {% endif %}
                {% endfor %}
              </ul>
            </div>
          </div>

        </div>
      </div>
    </div>
  </section>

  <!-- ==========================================
       SECTION 4: CLINICAL TIMELINE (High Contrast)
       ========================================== -->
  <section class="py-32 lg:py-48 px-6 lg:px-20 bg-brand-slate text-white">
    <div class="max-w-5xl mx-auto">
      <h2 class=" text-3xl md:text-5xl mb-24 text-center text-white">Clinical Timeline</h2>
      
      <div class="space-y-16 md:space-y-0 md:grid md:grid-cols-3 md:gap-16 relative">
        {% for block in section.blocks %}
          {% if block.type == 'timeline_step' %}
            <div class="relative md:pt-10 md:border-t border-white/20">
              <!-- Dot Indicator -->
              <div class="hidden md:block absolute -top-[5px] left-0 w-2.5 h-2.5 bg-white rounded-full"></div>
              
              <span class="block text-xs uppercase tracking-[0.2em] font-bold text-white/70 mb-6">{{ block.settings.time }}</span>
              <p class="text-xl md:text-2xl font-light leading-relaxed">{{ block.settings.text }}</p>
            </div>
          {% endif %}
        {% endfor %}
      </div>
      
      <p class="text-center text-xs text-white/30 mt-32 uppercase tracking-[0.2em] font-bold">{{ section.settings.expect_disclaimer }}</p>
    </div>
  </section>

  <!-- ==========================================
       SECTION 5: FAQ (Minimal Accordion)
       ========================================== -->
  <section class="py-32 lg:py-40 px-6 bg-white">
    <div class="max-w-3xl mx-auto">
      <h2 class=" text-3xl md:text-4xl text-brand-slate mb-20 text-center">Protocol FAQ</h2>
      
      <div class="border-t border-gray-900/10">
        {% for block in section.blocks %}
          {% if block.type == 'faq_item' %}
            <details class="group border-b border-gray-900/10 [&::-webkit-details-marker]:hidden">
              <summary class="flex justify-between items-center cursor-pointer py-8 list-none font-medium text-lg md:text-xl text-brand-slate pr-4">
                {{ block.settings.question }}
                <span class="transition-transform duration-500 group-open:rotate-45 ml-4 shrink-0 text-brand-slate/40">
                  <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 4v16m8-8H4"/></svg>
                </span>
              </summary>
              <div class="pb-10 text-brand-slate/70 text-lg font-light leading-relaxed space-y-4 [&>p]:mb-4">
                {{ block.settings.answer }}
              </div>
            </details>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </section>

</div>

{%- assign has_faq = false -%}
{%- for block in section.blocks -%}
  {%- if block.type == 'faq_item' -%}
    {%- assign has_faq = true -%}
    {%- break -%}
  {%- endif -%}
{%- endfor -%}

{%- if has_faq -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {%- assign first_faq = true -%}
    {%- for block in section.blocks -%}
      {%- if block.type == 'faq_item' -%}
        {%- if first_faq == false -%},{%- endif -%}
        {
          "@type": "Question",
          "name": {{ block.settings.question | json }},
          "acceptedAnswer": {
            "@type": "Answer",
            "text": {{ block.settings.answer | strip_html | json }}
          }
        }
        {%- assign first_faq = false -%}
      {%- endif -%}
    {%- endfor -%}
  ]
}
</script>
{%- endif -%}

{% schema %}
{
  "name": "Concern Landing Page V2",
  "settings": [
    { "type": "header", "content": "Hero Section" },
    { "type": "text", "id": "hero_bg_asset", "label": "Background Asset Filename (e.g. texture.png)" },
    { "type": "image_picker", "id": "hero_image", "label": "Image" },
    { "type": "text", "id": "hero_label", "label": "Label", "default": "FOR ACNE-PRONE SKIN" },
    { "type": "textarea", "id": "hero_heading", "label": "Heading", "default": "A simpler routine for calmer, healthier-looking skin." },
    { "type": "textarea", "id": "hero_body", "label": "Body Text" },
    { "type": "text", "id": "hero_btn_1", "label": "Primary CTA", "default": "Start My Acne Routine" },
    { "type": "text", "id": "hero_btn_2", "label": "Secondary CTA", "default": "See How It Works" },
    
    { "type": "header", "content": "Section 2: We Understand" },
    { "type": "textarea", "id": "understand_heading", "label": "Heading", "default": "Acne isn't just about your skin.\nIt's about confidence too." },
    
    { "type": "header", "content": "Section 3: Why Acne Happens" },
    { "type": "textarea", "id": "why_bottom", "label": "Bottom Copy", "default": "A consistent routine helps support skin that feels cleaner, calmer and healthier over time." },
    
    { "type": "header", "content": "Section 4: The Seravolve Difference" },
    { "type": "text", "id": "comp_headline", "label": "Comparison Headline" },
    { "type": "text", "id": "diff_other_1", "label": "Other Skincare 1", "default": "Research ingredients" },
    { "type": "text", "id": "diff_other_2", "label": "Other Skincare 2", "default": "Compare products" },
    { "type": "text", "id": "diff_other_3", "label": "Other Skincare 3", "default": "Watch videos" },
    { "type": "text", "id": "diff_other_4", "label": "Other Skincare 4", "default": "Hope it works" },
    { "type": "text", "id": "diff_us_1", "label": "Seravolve 1", "default": "Choose your concern" },
    { "type": "text", "id": "diff_us_2", "label": "Seravolve 2", "default": "Follow one routine" },
    { "type": "text", "id": "diff_us_3", "label": "Seravolve 3", "default": "Stay consistent" },
    { "type": "text", "id": "diff_us_4", "label": "Seravolve 4", "default": "Build confidence" },
    
    { "type": "header", "content": "Section 5: Your Routine" },
    { "type": "textarea", "id": "routine_headline", "label": "Headline", "default": "Designed around your concern.\nNot around ingredients." },
    { "type": "textarea", "id": "routine_subheading", "label": "Subheading", "default": "Everything below has one purpose:\nsupporting acne-prone skin with a simple daily routine." },

    { "type": "header", "content": "Section 7: What to Expect" },
    { "type": "text", "id": "expect_disclaimer", "label": "Disclaimer", "default": "*Results vary. Consistency matters." },

    { "type": "header", "content": "Final CTA" },
    { "type": "image_picker", "id": "final_image", "label": "Background Image" },
    { "type": "textarea", "id": "final_heading", "label": "Heading", "default": "Healthy-looking skin starts with one simple decision." },
    { "type": "textarea", "id": "final_body", "label": "Body", "default": "Stop researching products.\nStart following a routine built around your skin." },
    { "type": "text", "id": "final_btn_1", "label": "Primary CTA", "default": "Start My Acne Routine" },
    { "type": "text", "id": "final_btn_2", "label": "Secondary CTA", "default": "Shop Individual Products" }
  ],
  "blocks": [
    {
      "type": "understand_card",
      "name": "Quote Card",
      "limit": 4,
      "settings": [
        { "type": "textarea", "id": "title", "label": "Quote" }
      ]
    },
    {
      "type": "why_happens_card",
      "name": "Cause Card",
      "limit": 3,
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "title", "label": "Title" },
        { "type": "textarea", "id": "text", "label": "Explanation" }
      ]
    },
    {
      "type": "routine_am",
      "name": "Morning Step",
      "settings": [
        { "type": "text", "id": "text", "label": "Step Name" }
      ]
    },
    {
      "type": "routine_pm",
      "name": "Night Step",
      "settings": [
        { "type": "text", "id": "text", "label": "Step Name" }
      ]
    },
    {
      "type": "bundle_card",
      "name": "Bundle Routine Showcase",
      "settings": [
        { "type": "product", "id": "product", "label": "Bundle Product" },
        { "type": "image_picker", "id": "image", "label": "Image (Optional override)" },
        { "type": "text", "id": "title", "label": "Headline", "default": "The Complete Routine" },
        { "type": "richtext", "id": "description", "label": "Description" },
        { "type": "text", "id": "step_1_title", "label": "Step 1 Title", "default": "Cleanse" },
        { "type": "text", "id": "step_1_text", "label": "Step 1 Text" },
        { "type": "text", "id": "step_2_title", "label": "Step 2 Title", "default": "Moisturize" },
        { "type": "text", "id": "step_2_text", "label": "Step 2 Text" },
        { "type": "text", "id": "step_3_title", "label": "Step 3 Title", "default": "Protect" },
        { "type": "text", "id": "step_3_text", "label": "Step 3 Text" }
      ]
    },
    {
      "type": "step_card",
      "name": "Product Step",
      "settings": [
        { "type": "product", "id": "product", "label": "Product" },
        { "type": "image_picker", "id": "image", "label": "Product Image (Optional override)" },
        { "type": "text", "id": "step_number", "label": "Step Identifier", "default": "STEP 1" },
        { "type": "text", "id": "title", "label": "Headline" },
        { "type": "textarea", "id": "text", "label": "Description" },
        { "type": "text", "id": "product_name", "label": "Product Name Fallback" },
        { "type": "url", "id": "product_link", "label": "Product Link Fallback" }
      ]
    },
    {
      "type": "timeline_step",
      "name": "Expectation Timeline",
      "limit": 3,
      "settings": [
        { "type": "text", "id": "time", "label": "Time (e.g., Week 1)" },
        { "type": "text", "id": "text", "label": "Result" }
      ]
    },
    {
      "type": "habit_card",
      "name": "Habit",
      "limit": 5,
      "settings": [
        { "type": "text", "id": "text", "label": "Habit Name" },
        { "type": "textarea", "id": "icon", "label": "SVG Path Data (d=...)" }
      ]
    },
    {
      "type": "faq_item",
      "name": "FAQ",
      "settings": [
        { "type": "text", "id": "question", "label": "Question" },
        { "type": "richtext", "id": "answer", "label": "Answer" }
      ]
    },
    {
      "type": "why_choose_card",
      "name": "Value Prop",
      "limit": 6,
      "settings": [
        { "type": "text", "id": "title", "label": "Title" }
      ]
    }
  ],
  "presets": [
    { "name": "Concern Landing Page V2" }
  ]
}
{% endschema %}