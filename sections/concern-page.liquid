<div x-data="{ showSticky: false }" @scroll.window="showSticky = (window.pageYOffset > 800)" class="w-full bg-white font-sans text-[#5E6A78] overflow-x-hidden relative">

  <!-- STICKY MOBILE CTA -->
  <div 
    class="fixed bottom-4 left-4 right-4 z-50 md:hidden transition-all duration-300 ease-in-out"
    :class="showSticky ? 'translate-y-0 opacity-100' : 'translate-y-20 opacity-0 pointer-events-none'"
    x-cloak
  >
    <a href="#routine" class="block w-full py-4 bg-[#2F3948] text-white rounded-full text-center text-[12px] uppercase tracking-[0.15em] font-black shadow-2xl shadow-brand-charcoal/30">
      {{ section.settings.hero_btn_1 | default: "Start My Routine" }}
    </a>
  </div>

  <!-- ==========================================
       HERO SECTION (50/50 with floating bar)
       ========================================== -->
  <section class="relative bg-[#F6FBFD] pt-20 pb-32 lg:pt-32 lg:pb-40">
    <div class="max-w-7xl mx-auto px-6 lg:px-20 grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-0 items-center">
      
      <!-- Left Content -->
      <div class="z-10 lg:pr-16">
        {% if section.settings.hero_label != blank %}
          <div class="inline-block bg-white text-[10px] font-black tracking-[0.2em] text-[#2F3948] uppercase py-3 px-6 rounded-full mb-8 border border-[#2F3948]/5 shadow-sm">
            {{ section.settings.hero_label }}
          </div>
        {% endif %}
        
        <h1 class="font-serif text-5xl lg:text-6xl text-[#2F3948] leading-[1.1] mb-6">
          {{ section.settings.hero_heading | newline_to_br }}
        </h1>
        
        <p class="text-lg text-[#5E6A78] mb-10 max-w-lg leading-relaxed font-medium">
          {{ section.settings.hero_body | newline_to_br }}
        </p>
        
        <!-- Checklist Horizontal -->
        <div class="flex flex-wrap items-center gap-6 mb-12">
          <div class="flex items-center gap-2"><svg class="w-5 h-5 text-[#2F3948]" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg><span class="text-sm font-bold text-[#2F3948]">Face Wash</span></div>
          <div class="flex items-center gap-2"><svg class="w-5 h-5 text-[#2F3948]" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg><span class="text-sm font-bold text-[#2F3948]">Moisturiser</span></div>
          <div class="flex items-center gap-2"><svg class="w-5 h-5 text-[#2F3948]" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg><span class="text-sm font-bold text-[#2F3948]">Sunscreen</span></div>
        </div>

        <div class="flex flex-col sm:flex-row items-center gap-4">
          <a href="#routine" class="w-full sm:w-auto text-center bg-[#2F3948] text-white px-10 py-5 rounded-full text-[11px] uppercase tracking-[0.2em] font-black hover:bg-black transition-all">
            {{ section.settings.hero_btn_1 }}
          </a>
          <a href="#how" class="w-full sm:w-auto text-center bg-white border border-[#2F3948]/10 text-[#2F3948] px-10 py-5 rounded-full text-[11px] uppercase tracking-[0.2em] font-black hover:bg-[#F6FBFD] shadow-sm transition-all">
            {{ section.settings.hero_btn_2 }}
          </a>
        </div>
      </div>
      
      <!-- Right Image -->
      <div class="lg:absolute lg:top-0 lg:right-0 lg:w-1/2 lg:h-full rounded-l-[40px] overflow-hidden hidden lg:block">
        {% if section.settings.hero_image != blank %}
          {{ section.settings.hero_image | image_url: width: 1200 | image_tag: class: 'w-full h-full object-cover', loading: 'eager' }}
        {% else %}
          <img src="{{ 'acne.webp' | asset_url }}" class="w-full h-full object-cover" loading="eager" alt="Acne hero">
        {% endif %}
      </div>
    </div>
  </section>

  <!-- Floating Trust Bar -->
  <div class="max-w-5xl mx-auto px-6 relative -mt-12 z-20 hidden md:block">
    <div class="bg-white rounded-full py-6 px-10 shadow-[0_10px_40px_rgba(0,0,0,0.05)] flex flex-wrap justify-between items-center gap-6">
      <div class="flex items-center gap-3"><svg class="w-6 h-6 text-[#2F3948]" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg><span class="text-xs font-bold text-[#2F3948]">Concern First</span></div>
      <div class="flex items-center gap-3"><svg class="w-6 h-6 text-[#2F3948]" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg><span class="text-xs font-bold text-[#2F3948]">Cruelty Free</span></div>
      <div class="flex items-center gap-3"><svg class="w-6 h-6 text-[#2F3948]" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg><span class="text-xs font-bold text-[#2F3948]">Made in India</span></div>
      <div class="flex items-center gap-3"><svg class="w-6 h-6 text-[#2F3948]" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg><span class="text-xs font-bold text-[#2F3948]">Free Shipping</span></div>
    </div>
  </div>

  <!-- ==========================================
       SECTION 2: DESIGNED FOR (50/50 Layout)
       ========================================== -->
  <section class="py-24 lg:py-32 px-6 lg:px-20 bg-white">
    <div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-16 items-center">
      <!-- Left Content -->
      <div>
        <h2 class="font-serif text-4xl lg:text-5xl text-[#2F3948] mb-10 max-w-md">{{ section.settings.understand_heading | newline_to_br }}</h2>
        
        <div class="space-y-4 mb-10">
          {% for block in section.blocks %}
            {% if block.type == 'understand_card' %}
              <div class="flex items-center gap-3">
                <svg class="w-6 h-6 text-[#2F3948] shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                <span class="text-lg font-bold text-[#2F3948]">{{ block.settings.title }}</span>
              </div>
            {% endif %}
          {% endfor %}
        </div>
        
        <p class="text-lg text-[#5E6A78] max-w-md font-medium leading-relaxed">This is a complete acne routine designed to simplify your daily skincare decisions.</p>
      </div>

      <!-- Right Image -->
      <div class="rounded-[40px] overflow-hidden bg-[#F6FBFD] aspect-[4/3]">
        <img src="{{ 'heroimg.webp' | asset_url }}" class="w-full h-full object-cover mix-blend-multiply opacity-90" loading="lazy" alt="Acne Products">
      </div>
    </div>
  </section>

  <!-- ==========================================
       SECTION 3: UNDERSTANDING ACNE (Asymmetric Grid)
       ========================================== -->
  <section id="how" class="py-24 px-6 lg:px-20 bg-white">
    <div class="max-w-7xl mx-auto bg-[#F6FBFD] rounded-[40px] p-10 lg:p-20 relative">
      
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_1.5fr] gap-16 items-start">
        
        <!-- Left: Text -->
        <div class="max-w-md">
          <h2 class="font-serif text-4xl text-[#2F3948] mb-8">Understanding acne doesn't have to be complicated.</h2>
          <p class="text-sm font-medium text-[#5E6A78] leading-relaxed mb-6">Acne often develops when excess oil, dead skin cells, and clogged pores create an environment where <strong>breakouts can appear.</strong></p>
          <p class="text-sm font-medium text-[#5E6A78] leading-relaxed mb-6">Many people try multiple products without a clear routine, which can make skincare feel overwhelming.</p>
          <p class="text-sm font-medium text-[#5E6A78] leading-relaxed">That's why Seravolve focuses on <strong>one complete</strong> acne control routine instead of asking you to build a routine step by step.</p>
        </div>

        <!-- Right: 3 Cards -->
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
          {% assign has_why_cards = false %}
          {% assign why_index = 0 %}
          {% for block in section.blocks %}
            {% if block.type == 'why_happens_card' %}
              {% assign has_why_cards = true %}
              {% assign why_index = why_index | plus: 1 %}
              <div class="bg-white rounded-[28px] p-8 shadow-sm flex flex-col items-center text-center">
                <div class="w-16 h-16 rounded-full border border-[#2F3948]/10 flex items-center justify-center mb-6 text-[#2F3948]">
                  <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    {% if why_index == 1 %}<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/>{% endif %}
                    {% if why_index == 2 %}<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M14.121 15.536c-1.171 1.952-3.07 1.952-4.242 0-1.172-1.953-1.172-5.119 0-7.072 1.171-1.952 3.07-1.952 4.242 0M8 10.5h4m-4 3h4m9-1.5a9 9 0 11-18 0 9 9 0 0118 0z"/>{% endif %}
                    {% if why_index == 3 %}<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/>{% endif %}
                  </svg>
                </div>
                <h4 class="font-bold text-[#2F3948] mb-3">{{ block.settings.title }}</h4>
                <p class="text-sm font-medium text-[#5E6A78]">{{ block.settings.text }}</p>
              </div>
            {% endif %}
          {% endfor %}
          {% if has_why_cards == false %}
            <p>Cards go here...</p>
          {% endif %}
        </div>

      </div>

      <!-- Bottom Centered text -->
      <div class="mt-16 flex flex-col items-center justify-center gap-4 text-center max-w-lg mx-auto">
        <div class="w-12 h-12 rounded-full bg-white flex items-center justify-center shrink-0 border border-[#2F3948]/5">
          <svg class="w-5 h-5 text-[#2F3948]" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
        </div>
        <p class="text-sm font-bold text-[#2F3948] leading-tight">{{ section.settings.why_bottom }}</p>
      </div>

    </div>
  </section>

  <!-- ==========================================
       SECTION 4: THE SERAVOLVE DIFFERENCE (Table)
       ========================================== -->
  <section id="difference" class="py-20 px-6 lg:px-20 bg-white">
    <div class="max-w-4xl mx-auto">
      {% if section.settings.comp_headline != blank %}
        <h2 class="font-serif text-3xl lg:text-4xl text-[#2F3948] text-center mb-12">{{ section.settings.comp_headline }}</h2>
      {% endif %}
      
      <div class="rounded-[28px] border border-[#2F3948]/10 overflow-hidden shadow-sm">
        <!-- Header -->
        <div class="grid grid-cols-2 bg-[#F6FBFD] p-6 lg:p-8 border-b border-[#2F3948]/10">
          <div class="font-bold text-[#2F3948]">Traditional Skincare</div>
          <div class="font-bold text-[#2F3948]">Seravolve</div>
        </div>
        <!-- Rows -->
        <div class="grid grid-cols-2 p-6 lg:px-8 border-b border-[#2F3948]/5">
          <div class="text-[#2F3948] font-bold">{{ section.settings.diff_other_1 }}</div>
          <div class="text-[#5E6A78] font-medium">{{ section.settings.diff_us_1 }}</div>
        </div>
        <div class="grid grid-cols-2 p-6 lg:px-8 border-b border-[#2F3948]/5">
          <div class="text-[#2F3948] font-bold">{{ section.settings.diff_other_2 }}</div>
          <div class="text-[#5E6A78] font-medium">{{ section.settings.diff_us_2 }}</div>
        </div>
        <div class="grid grid-cols-2 p-6 lg:px-8 border-b border-[#2F3948]/5">
          <div class="text-[#2F3948] font-bold">{{ section.settings.diff_other_3 }}</div>
          <div class="text-[#5E6A78] font-medium">{{ section.settings.diff_us_3 }}</div>
        </div>
        <div class="grid grid-cols-2 p-6 lg:px-8">
          <div class="text-[#2F3948] font-bold">{{ section.settings.diff_other_4 }}</div>
          <div class="text-[#5E6A78] font-medium">{{ section.settings.diff_us_4 }}</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ==========================================
       SECTION 5: ACNE CONTROL ROUTINE (Conversion Grid)
       ========================================== -->
  <section id="routine" class="py-24 px-6 lg:px-20 bg-white">
    <div class="max-w-6xl mx-auto bg-[#F6FBFD] rounded-[40px] p-8 lg:p-16 relative overflow-hidden shadow-sm border border-[#2F3948]/5">
      
      {% for block in section.blocks %}
        {% if block.type == 'bundle_card' %}
          <!-- Title -->
          <div class="text-center mb-16 relative z-10">
            <div class="inline-block bg-white text-[9px] font-black tracking-[0.2em] text-[#1C51B9] uppercase py-2 px-4 rounded-full mb-6 shadow-sm border border-[#2F3948]/5">
              RECOMMENDED ROUTINE
            </div>
            <h2 class="font-serif text-4xl lg:text-5xl text-[#1C51B9] mb-4">{{ block.settings.title }}</h2>
            <p class="text-[#2F3948] font-bold text-sm max-w-md mx-auto">A simple morning and night routine designed for acne-prone skin.</p>
          </div>

          <!-- The complex grid layout -->
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 relative z-10">
            
            <!-- Left Side: Timeline + Morning/Night Cards -->
            <div class="flex flex-col justify-end">
              <!-- Icons Row -->
              <div class="flex items-center justify-between px-2 mb-8">
                <div class="flex flex-col items-center">
                  <div class="w-16 h-16 rounded-full bg-white shadow-sm border border-[#2F3948]/5 flex items-center justify-center mb-3 text-[#1C51B9]">
                    <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/></svg>
                  </div>
                  <span class="text-[11px] font-bold text-[#2F3948] text-center">Face Wash<br><span class="font-normal text-[#5E6A78]">Cleanse</span></span>
                </div>
                <div class="text-[#2F3948]/20 mb-8">+</div>
                <div class="flex flex-col items-center">
                  <div class="w-16 h-16 rounded-full bg-white shadow-sm border border-[#2F3948]/5 flex items-center justify-center mb-3 text-[#1C51B9]">
                    <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
                  </div>
                  <span class="text-[11px] font-bold text-[#2F3948] text-center">Moisturiser<br><span class="font-normal text-[#5E6A78]">Hydrate</span></span>
                </div>
                <div class="text-[#2F3948]/20 mb-8">+</div>
                <div class="flex flex-col items-center">
                  <div class="w-16 h-16 rounded-full bg-white shadow-sm border border-[#2F3948]/5 flex items-center justify-center mb-3 text-[#1C51B9]">
                    <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
                  </div>
                  <span class="text-[11px] font-bold text-[#2F3948] text-center">Sunscreen<br><span class="font-normal text-[#5E6A78]">Protect</span></span>
                </div>
              </div>

              <!-- Morning / Night Cards -->
              <div class="grid grid-cols-2 gap-4">
                <div class="bg-white rounded-[24px] p-6 text-center shadow-sm border border-[#2F3948]/5">
                  <svg class="w-8 h-8 text-[#E2A123] mx-auto mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
                  <h4 class="font-bold text-[#2F3948] text-sm mb-4">Morning</h4>
                  <div class="text-xs font-medium text-[#5E6A78] space-y-1">
                    <div>Face Wash</div>
                    <div class="text-[#2F3948]/30">↓</div>
                    <div>Moisturiser</div>
                    <div class="text-[#2F3948]/30">↓</div>
                    <div>Sunscreen</div>
                  </div>
                </div>
                <div class="bg-white rounded-[24px] p-6 text-center shadow-sm border border-[#2F3948]/5">
                  <svg class="w-8 h-8 text-[#1C51B9] mx-auto mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/></svg>
                  <h4 class="font-bold text-[#2F3948] text-sm mb-4">Night</h4>
                  <div class="text-xs font-medium text-[#5E6A78] space-y-1">
                    <div>Face Wash</div>
                    <div class="text-[#2F3948]/30">↓</div>
                    <div>Moisturiser</div>
                  </div>
                </div>
              </div>
            </div>

            <!-- Right: Why this works & Image -->
            <div class="flex flex-col relative h-full">
              <!-- Why this works list -->
              <div class="relative z-10 pt-4">
                <h4 class="font-bold text-[#2F3948] text-xl mb-6">Why this routine works<br>for acne-prone skin</h4>
                <div class="space-y-3">
                  <div class="flex items-start gap-3">
                    <svg class="w-5 h-5 text-[#2F3948] shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    <span class="text-xs font-medium text-[#2F3948]">Helps keep skin clean and refreshed</span>
                  </div>
                  <div class="flex items-start gap-3">
                    <svg class="w-5 h-5 text-[#2F3948] shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    <span class="text-xs font-medium text-[#2F3948]">Supports balanced hydration</span>
                  </div>
                  <div class="flex items-start gap-3">
                    <svg class="w-5 h-5 text-[#2F3948] shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    <span class="text-xs font-medium text-[#2F3948]">Protects skin during the day</span>
                  </div>
                  <div class="flex items-start gap-3">
                    <svg class="w-5 h-5 text-[#2F3948] shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    <span class="text-xs font-medium text-[#2F3948]">Removes the guesswork from building an acne routine</span>
                  </div>
                </div>
              </div>
              
              <!-- Floating Image Overlay -->
              {% assign prod = block.settings.product %}
              {% if prod != blank and prod.title == blank %}
                {% assign prod = all_products[block.settings.product] %}
              {% endif %}
              
              <div class="absolute bottom-[-64px] right-[-64px] w-64 md:w-80 h-auto opacity-40 md:opacity-100 z-0 mix-blend-multiply pointer-events-none">
                {% if prod != blank and prod.featured_image != blank %}
                  {{ prod.featured_image | image_url: width: 800 | image_tag: class: 'w-full h-full object-contain', loading: 'lazy' }}
                {% else %}
                  <img src="{{ 'heroimg.webp' | asset_url }}" class="w-full h-full object-contain" loading="lazy" alt="Acne Control Routine">
                {% endif %}
              </div>
            </div>

          </div>
          {% endif %}
        {% endfor %}
  <!-- ==========================================
       SECTION 7: WHAT TO EXPECT
       ========================================== -->
  <section class="py-24 px-6 lg:px-20 bg-white border-t border-[#2F3948]/5">
    <div class="max-w-4xl mx-auto">
      <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-10">
        {% for block in section.blocks %}
          {% if block.type == 'timeline_step' %}
            <div class="flex-1 flex flex-col items-center text-center group" {{ block.shopify_attributes }}>
              <span class="text-[10px] uppercase tracking-widest font-black text-[#5E6A78] mb-4">{{ block.settings.time }}</span>
              <div class="w-4 h-4 rounded-full bg-white border-2 border-[#2F3948] mb-6"></div>
              <p class="font-serif text-xl text-[#2F3948]">{{ block.settings.text }}</p>
            </div>
            {% unless forloop.last %}
              <div class="hidden md:block flex-1 h-px bg-[#2F3948]/10 mt-[-50px]"></div>
            {% endunless %}
          {% endif %}
        {% endfor %}
      </div>
      <p class="text-center text-[10px] text-[#5E6A78] italic mt-16">{{ section.settings.expect_disclaimer }}</p>
    </div>
  </section>


  <!-- ==========================================
       SECTION 8: DAILY HABITS
       ========================================== -->
  <section class="py-24 lg:py-32 px-6 lg:px-20 bg-[#F6FBFD] rounded-[40px] my-10 max-w-[95%] mx-auto">
    <div class="max-w-7xl mx-auto">
      <h2 class="font-serif text-4xl text-[#2F3948] text-center mb-16">Daily Habits That Support Your Routine</h2>
      
      <div class="grid grid-cols-2 md:grid-cols-5 gap-6 text-center">
        {% for block in section.blocks %}
          {% if block.type == 'habit_card' %}
            <div class="flex flex-col items-center" {{ block.shopify_attributes }}>
              <div class="w-20 h-20 bg-white rounded-full flex items-center justify-center text-[#2F3948] mb-6 shadow-sm border border-[#2F3948]/5">
                {% if block.settings.icon != blank %}
                  <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="{{ block.settings.icon }}"/>
                  </svg>
                {% else %}
                  <svg class="w-8 h-8 opacity-20" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                {% endif %}
              </div>
              <p class="text-sm font-medium text-[#5E6A78] max-w-[140px]">{{ block.settings.text }}</p>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </section>


  <!-- ==========================================
       SECTION 9: FAQ
       ========================================== -->
  <section class="py-24 lg:py-32 px-6 lg:px-20 bg-white">
    <div class="max-w-4xl mx-auto">
      <h2 class="font-serif text-4xl text-[#2F3948] mb-12 text-center">Questions We Often Get</h2>
      <div class="space-y-4" x-data="{ active: null }">
        {% for block in section.blocks %}
          {% if block.type == 'faq_item' %}
            <div class="bg-white rounded-[20px] border border-[#2F3948]/10 overflow-hidden" {{ block.shopify_attributes }}>
              <button @click="active === {{ forloop.index }} ? active = null : active = {{ forloop.index }}" class="w-full px-8 py-6 flex justify-between items-center text-left focus:outline-none">
                <span class="font-serif text-xl text-[#2F3948]">{{ block.settings.question }}</span>
                <svg class="w-5 h-5 text-[#5E6A78] transition-transform duration-300" :class="active === {{ forloop.index }} ? 'rotate-180' : ''" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
              </button>
              <div x-show="active === {{ forloop.index }}" x-collapse>
                <div class="px-8 pb-6 text-[#5E6A78] font-medium leading-relaxed">
                  {{ block.settings.answer }}
                </div>
              </div>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </section>


  <!-- ==========================================
       SECTION 10: WHY CHOOSE SERAVOLVE
       ========================================== -->
  <section class="py-24 lg:py-32 px-6 lg:px-20 bg-[#F6FBFD] border-t border-[#2F3948]/5">
    <div class="max-w-6xl mx-auto">
      <h2 class="font-serif text-4xl text-[#2F3948] text-center mb-16">Why Choose Seravolve</h2>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-6">
        {% for block in section.blocks %}
          {% if block.type == 'why_choose_card' %}
            <div class="bg-white p-8 rounded-[28px] text-center shadow-sm border border-[#2F3948]/5" {{ block.shopify_attributes }}>
              <p class="font-serif text-lg text-[#2F3948]">{{ block.settings.title }}</p>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </section>


  <!-- ==========================================
       FINAL CTA
       ========================================== -->
  <section class="relative py-40 px-6 lg:px-20 bg-[#2F3948]">
    {% if section.settings.final_image != blank %}
      {{ section.settings.final_image | image_url: width: 2000 | image_tag: class: 'absolute inset-0 w-full h-full object-cover opacity-40 mix-blend-overlay grayscale', loading: 'lazy' }}
    {% else %}
      <img src="{{ 'heroimg.webp' | asset_url }}" class="absolute inset-0 w-full h-full object-cover opacity-40 mix-blend-overlay grayscale" loading="lazy" alt="Seravolve">
    {% endif %}
    
    <div class="relative z-10 max-w-3xl mx-auto text-center">
      <h2 class="font-serif text-5xl lg:text-7xl text-white mb-8 leading-tight">{{ section.settings.final_heading | newline_to_br }}</h2>
      <p class="text-white/80 font-medium text-lg leading-relaxed mb-12 max-w-xl mx-auto">
        {{ section.settings.final_body | newline_to_br }}
      </p>
      <div class="flex flex-col sm:flex-row justify-center gap-4">
        <a href="#routine" class="px-12 py-5 bg-white text-[#2F3948] rounded-full text-[11px] uppercase tracking-widest font-black hover:bg-[#F6FBFD] transition-colors shadow-xl">
          {{ section.settings.final_btn_1 }}
        </a>
        <a href="/collections/all" class="px-12 py-5 bg-transparent border-2 border-white/20 text-white rounded-full text-[11px] uppercase tracking-widest font-black hover:bg-white/10 transition-colors backdrop-blur-sm">
          {{ section.settings.final_btn_2 }}
        </a>
      </div>
    </div>
  </section>

</div>

{% schema %}
{
  "name": "Concern Landing Page V2",
  "settings": [
    { "type": "header", "content": "Hero Section" },
    { "type": "image_picker", "id": "hero_image", "label": "Image" },
    { "type": "text", "id": "hero_label", "label": "Label", "default": "FOR ACNE-PRONE SKIN" },
    { "type": "textarea", "id": "hero_heading", "label": "Heading", "default": "A simpler routine for calmer, healthier-looking skin." },
    { "type": "textarea", "id": "hero_body", "label": "Body Text" },
    { "type": "text", "id": "hero_btn_1", "label": "Primary CTA", "default": "Start My Acne Routine" },
    { "type": "text", "id": "hero_btn_2", "label": "Secondary CTA", "default": "See How It Works" },
    
    { "type": "header", "content": "Section 2: We Understand" },
