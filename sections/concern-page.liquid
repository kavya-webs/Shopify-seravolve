<div x-data="{ showSticky: false }" @scroll.window="showSticky = (window.pageYOffset > 800)" class="w-full bg-white font-sans text-[#5E6A78] overflow-x-hidden relative">

  <!-- STICKY MOBILE CTA -->
  <div 
    class="fixed bottom-4 left-4 right-4 z-50 md:hidden transition-all duration-300 ease-in-out"
    :class="showSticky ? 'translate-y-0 opacity-100' : 'translate-y-20 opacity-0 pointer-events-none'"
    x-cloak
  >
    <a href="#routine" class="block w-full py-4 bg-[#2F3948] text-white rounded-full text-center text-[12px] uppercase tracking-[0.15em] font-black shadow-2xl shadow-brand-charcoal/30">
      {{ section.settings.hero_btn_1 | default: "Start My Routine" }}
    </a>
  </div>

  <!-- ==========================================
       SECTION 1: PREMIUM HERO
       ========================================== -->
  <section class="relative min-h-[90vh] md:min-h-[85vh] rounded-b-[40px] overflow-hidden bg-[#F6FBFD] flex items-end">
    <!-- Background Image -->
    {% if section.settings.hero_image != blank %}
      {{ section.settings.hero_image | image_url: width: 2000 | image_tag: class: 'absolute inset-0 w-full h-full object-cover', loading: 'eager' }}
    {% else %}
      <img src="{{ 'acne.webp' | asset_url }}" class="absolute inset-0 w-full h-full object-cover" loading="eager" alt="Acne hero">
    {% endif %}
    
    <!-- Gradient Overlay (Bottom only) -->
    <div class="absolute inset-0 bg-gradient-to-t from-[#2F3948]/90 via-[#2F3948]/20 to-transparent"></div>

    <!-- Content -->
    <div class="relative z-10 w-full px-6 lg:px-20 pb-16 pt-32">
      <div class="max-w-2xl">
        <span class="text-[10px] uppercase tracking-[0.3em] font-bold text-white/80 mb-4 block">
          {{ section.settings.hero_label }}
        </span>
        <h1 class="font-serif text-5xl lg:text-7xl text-white leading-[1.05] mb-6">
          {{ section.settings.hero_heading | newline_to_br }}
        </h1>
        <p class="text-lg lg:text-xl text-white/90 font-medium leading-relaxed mb-10 max-w-xl">
          {{ section.settings.hero_body | newline_to_br }}
        </p>
        
        <div class="flex flex-col sm:flex-row gap-4 mb-10">
          <a href="#routine" class="px-10 py-5 bg-white text-[#2F3948] rounded-full text-[11px] uppercase tracking-widest font-black hover:bg-[#F6FBFD] transition-colors text-center shadow-lg">
            {{ section.settings.hero_btn_1 }}
          </a>
          <a href="#difference" class="px-10 py-5 bg-transparent border-2 border-white/30 text-white rounded-full text-[11px] uppercase tracking-widest font-black hover:bg-white/10 transition-colors text-center backdrop-blur-sm">
            {{ section.settings.hero_btn_2 }}
          </a>
        </div>

        <!-- Trust Chips -->
        <div class="flex flex-wrap gap-x-6 gap-y-3 text-[10px] uppercase tracking-widest font-bold text-white/70">
          <span class="flex items-center"><svg class="w-3 h-3 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg> Concern First</span>
          <span class="flex items-center"><svg class="w-3 h-3 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg> Cruelty Free</span>
          <span class="flex items-center"><svg class="w-3 h-3 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg> Made in India</span>
          <span class="flex items-center"><svg class="w-3 h-3 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg> Free Shipping</span>
        </div>
      </div>
    </div>
  </section>


  <!-- ==========================================
       SECTION 2: WE UNDERSTAND
       ========================================== -->
  <section class="py-24 lg:py-32 px-6 lg:px-20 bg-white text-center">
    <div class="max-w-5xl mx-auto">
      <h2 class="font-serif text-4xl lg:text-5xl text-[#2F3948] leading-tight mb-16 max-w-3xl mx-auto">
        {{ section.settings.understand_heading | newline_to_br }}
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-16">
        {% for block in section.blocks %}
          {% if block.type == 'understand_card' %}
            <div class="bg-[#F6FBFD] p-10 rounded-[28px] flex items-center justify-center min-h-[140px]" {{ block.shopify_attributes }}>
              <p class="font-serif text-xl lg:text-2xl text-[#2F3948] italic">"{{ block.settings.title }}"</p>
            </div>
          {% endif %}
        {% endfor %}
      </div>

      <p class="text-sm uppercase tracking-[0.2em] font-black text-[#5E6A78]">
        That's exactly why Seravolve exists.
      </p>
    </div>
  </section>


  <!-- ==========================================
       SECTION 3: WHY ACNE HAPPENS
       ========================================== -->
  <section class="py-24 lg:py-32 px-6 lg:px-20 bg-[#F6FBFD] rounded-[40px]">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-20">
        {% for block in section.blocks %}
          {% if block.type == 'why_happens_card' %}
            <div class="group" {{ block.shopify_attributes }}>
              <div class="aspect-[4/3] rounded-[28px] overflow-hidden mb-6 bg-white shadow-sm border border-[#2F3948]/5">
                {% if block.settings.image != blank %}
                  {{ block.settings.image | image_url: width: 600 | image_tag: class: 'w-full h-full object-cover grayscale opacity-80 group-hover:grayscale-0 transition-all duration-700', loading: 'lazy' }}
                {% else %}
                  <img src="{{ 'pores.webp' | asset_url }}" class="w-full h-full object-cover grayscale opacity-80 group-hover:grayscale-0 transition-all duration-700" loading="lazy" alt="Acne concern">
                {% endif %}
              </div>
              <h3 class="font-serif text-2xl text-[#2F3948] mb-3">{{ block.settings.title }}</h3>
              <p class="text-[#5E6A78] font-medium leading-relaxed">{{ block.settings.text }}</p>
            </div>
          {% endif %}
        {% endfor %}
      </div>

      <div class="max-w-3xl mx-auto text-center">
        <p class="font-serif text-3xl lg:text-4xl text-[#2F3948] leading-tight">
          {{ section.settings.why_bottom | newline_to_br }}
        </p>
      </div>
    </div>
  </section>


  <!-- ==========================================
       SECTION 4: THE SERAVOLVE DIFFERENCE
       ========================================== -->
  <section id="difference" class="py-24 lg:py-32 px-6 lg:px-20 bg-white">
    <div class="max-w-5xl mx-auto">
      <div class="bg-[#F6FBFD] rounded-[40px] p-10 lg:p-20 border border-[#2F3948]/5 shadow-sm">
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-16 md:gap-8 relative">
          
          <!-- VS Badge (Desktop) -->
          <div class="hidden md:flex absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 w-16 h-16 bg-white rounded-full items-center justify-center font-serif text-xl text-[#2F3948] shadow-sm z-10">VS</div>

          <!-- Other Skincare -->
          <div class="flex flex-col items-center md:items-start text-center md:text-left opacity-60">
            <h3 class="text-xs uppercase tracking-[0.2em] font-black text-[#5E6A78] mb-10">Other Skincare</h3>
            <div class="space-y-6 w-full max-w-[250px]">
              <div class="font-serif text-2xl text-[#2F3948]">{{ section.settings.diff_other_1 }}</div>
              <div class="text-[#5E6A78]">↓</div>
              <div class="font-serif text-2xl text-[#2F3948]">{{ section.settings.diff_other_2 }}</div>
              <div class="text-[#5E6A78]">↓</div>
              <div class="font-serif text-2xl text-[#2F3948]">{{ section.settings.diff_other_3 }}</div>
              <div class="text-[#5E6A78]">↓</div>
              <div class="font-serif text-2xl text-[#2F3948]">{{ section.settings.diff_other_4 }}</div>
            </div>
          </div>

          <!-- Seravolve -->
          <div class="flex flex-col items-center md:items-start text-center md:text-left relative">
            <h3 class="text-xs uppercase tracking-[0.2em] font-black text-[#2F3948] mb-10">Seravolve</h3>
            <div class="space-y-6 w-full max-w-[250px]">
              <div class="font-serif text-2xl text-[#2F3948]">{{ section.settings.diff_us_1 }}</div>
              <div class="text-[#2F3948]/30">↓</div>
              <div class="font-serif text-2xl text-[#2F3948]">{{ section.settings.diff_us_2 }}</div>
              <div class="text-[#2F3948]/30">↓</div>
              <div class="font-serif text-2xl text-[#2F3948]">{{ section.settings.diff_us_3 }}</div>
              <div class="text-[#2F3948]/30">↓</div>
              <div class="font-serif text-2xl text-[#2F3948] font-bold">{{ section.settings.diff_us_4 }}</div>
            </div>
          </div>
        </div>

        <div class="mt-20 text-center">
          <a href="#routine" class="inline-block px-12 py-5 bg-[#2F3948] text-white rounded-full text-[11px] uppercase tracking-widest font-black hover:bg-[#5E6A78] transition-colors shadow-lg">
            Show Me My Routine
          </a>
        </div>

      </div>
    </div>
  </section>


  <!-- ==========================================
       SECTION 5: YOUR ROUTINE (HERO SECTION)
       ========================================== -->
  <section id="routine" class="py-12 px-6 lg:px-20 bg-white">
    <div class="max-w-6xl mx-auto bg-[#F6FBFD] rounded-[40px] lg:rounded-[60px] p-10 lg:p-24 shadow-sm border border-[#2F3948]/5 text-center relative overflow-hidden">
      
      <div class="relative z-10 mb-20">
        <h2 class="font-serif text-4xl lg:text-6xl text-[#2F3948] mb-6 leading-tight">
          {{ section.settings.routine_headline | newline_to_br }}
        </h2>
        <p class="text-lg text-[#5E6A78] font-medium max-w-2xl mx-auto">
          {{ section.settings.routine_subheading | newline_to_br }}
        </p>
      </div>

      <div class="relative z-10 grid grid-cols-1 md:grid-cols-2 gap-16 lg:gap-24 mb-20">
        
        <!-- AM -->
        <div class="text-center">
          <div class="w-16 h-16 mx-auto bg-white rounded-full flex items-center justify-center text-[#2F3948] mb-8 shadow-sm">
            <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
          </div>
          <h3 class="text-[10px] uppercase tracking-[0.3em] font-black text-[#5E6A78] mb-8">Morning</h3>
          <div class="space-y-4">
            {% for block in section.blocks %}
              {% if block.type == 'routine_am' %}
                <div class="font-serif text-3xl text-[#2F3948]">{{ block.settings.text }}</div>
                {% unless forloop.last %}<div class="text-[#2F3948]/20">↓</div>{% endunless %}
              {% endif %}
            {% endfor %}
          </div>
        </div>

        <!-- PM -->
        <div class="text-center">
          <div class="w-16 h-16 mx-auto bg-[#2F3948] rounded-full flex items-center justify-center text-white mb-8 shadow-sm">
            <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/></svg>
          </div>
          <h3 class="text-[10px] uppercase tracking-[0.3em] font-black text-[#5E6A78] mb-8">Night</h3>
          <div class="space-y-4">
            {% for block in section.blocks %}
              {% if block.type == 'routine_pm' %}
                <div class="font-serif text-3xl text-[#2F3948]">{{ block.settings.text }}</div>
                {% unless forloop.last %}<div class="text-[#2F3948]/20">↓</div>{% endunless %}
              {% endif %}
            {% endfor %}
          </div>
        </div>

      </div>

      <div class="relative z-10">
        <a href="#products" class="inline-block px-14 py-6 bg-[#2F3948] text-white rounded-full text-[12px] uppercase tracking-widest font-black hover:bg-[#5E6A78] transition-colors shadow-2xl">
          Explore Complete Routine
        </a>
      </div>

    </div>
  </section>

  <!-- ==========================================
       SECTION 6: EVERY STEP HAS A PURPOSE
       ========================================== -->
  <section id="products" class="py-24 lg:py-32 px-6 lg:px-20 bg-white">
    <div class="max-w-5xl mx-auto space-y-8">
      <h2 class="font-serif text-4xl lg:text-5xl text-[#2F3948] text-center mb-16">Every step has one clear purpose.</h2>
      
      {% for block in section.blocks %}
        {% if block.type == 'bundle_card' %}
          <div class="bg-[#F6FBFD] rounded-[40px] p-8 md:p-12 flex flex-col md:flex-row items-center gap-12 border border-[#2F3948]/5" {{ block.shopify_attributes }}>
            {% assign prod = block.settings.product %}
            {% if prod != blank and prod.title == blank %}
              {% assign prod = all_products[block.settings.product] %}
            {% endif %}
            
            <!-- Image Left -->
            <div class="w-full md:w-1/2 aspect-square rounded-[28px] overflow-hidden bg-white">
              {% if prod != blank and prod.featured_image != blank %}
                {{ prod.featured_image | image_url: width: 800 | image_tag: class: 'w-full h-full object-cover', loading: 'lazy' }}
              {% elsif block.settings.image != blank %}
                {{ block.settings.image | image_url: width: 800 | image_tag: class: 'w-full h-full object-cover', loading: 'lazy' }}
              {% else %}
                <div class="w-full h-full bg-gray-100 flex items-center justify-center text-xs text-gray-400">Bundle Image</div>
              {% endif %}
            </div>
            
            <!-- Content Right -->
            <div class="w-full md:w-1/2">
              <h3 class="font-serif text-3xl text-[#2F3948] mb-8">{{ block.settings.title }}</h3>
              
              <div class="space-y-6 mb-10">
                <div class="flex gap-4 items-start">
                  <span class="w-6 h-6 rounded-full bg-white border border-[#2F3948]/20 flex items-center justify-center text-[10px] font-bold text-[#2F3948] shrink-0">1</span>
                  <div>
                    <h4 class="font-bold text-[#2F3948] text-sm">{{ block.settings.step_1_title }}</h4>
                    <p class="text-[#5E6A78] text-sm mt-1">{{ block.settings.step_1_text }}</p>
                  </div>
                </div>
                <div class="flex gap-4 items-start">
                  <span class="w-6 h-6 rounded-full bg-white border border-[#2F3948]/20 flex items-center justify-center text-[10px] font-bold text-[#2F3948] shrink-0">2</span>
                  <div>
                    <h4 class="font-bold text-[#2F3948] text-sm">{{ block.settings.step_2_title }}</h4>
                    <p class="text-[#5E6A78] text-sm mt-1">{{ block.settings.step_2_text }}</p>
                  </div>
                </div>
                <div class="flex gap-4 items-start">
                  <span class="w-6 h-6 rounded-full bg-white border border-[#2F3948]/20 flex items-center justify-center text-[10px] font-bold text-[#2F3948] shrink-0">3</span>
                  <div>
                    <h4 class="font-bold text-[#2F3948] text-sm">{{ block.settings.step_3_title }}</h4>
                    <p class="text-[#5E6A78] text-sm mt-1">{{ block.settings.step_3_text }}</p>
                  </div>
                </div>
              </div>
              
              <div class="pt-8 border-t border-[#2F3948]/10 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
                <span class="font-bold text-[#2F3948]">{% if prod != blank %}{{ prod.title }}{% else %}Acne Control Routine{% endif %}</span>
                <a href="{% if prod != blank %}{{ prod.url }}{% else %}#{% endif %}" class="text-[10px] uppercase tracking-[0.2em] font-black text-[#5E6A78] hover:text-[#2F3948] transition-colors flex items-center">
                  Shop Routine <svg class="w-3 h-3 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                </a>
              </div>
            </div>
          </div>
        {% endif %}
        
        {% if block.type == 'step_card' %}
      {% endfor %}

    </div>
  </section>


  <!-- ==========================================
       SECTION 7: WHAT TO EXPECT
       ========================================== -->
  <section class="py-24 px-6 lg:px-20 bg-white border-t border-[#2F3948]/5">
    <div class="max-w-4xl mx-auto">
      <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-10">
        {% for block in section.blocks %}
          {% if block.type == 'timeline_step' %}
            <div class="flex-1 flex flex-col items-center text-center group" {{ block.shopify_attributes }}>
              <span class="text-[10px] uppercase tracking-widest font-black text-[#5E6A78] mb-4">{{ block.settings.time }}</span>
              <div class="w-4 h-4 rounded-full bg-white border-2 border-[#2F3948] mb-6"></div>
              <p class="font-serif text-xl text-[#2F3948]">{{ block.settings.text }}</p>
            </div>
            {% unless forloop.last %}
              <div class="hidden md:block flex-1 h-px bg-[#2F3948]/10 mt-[-50px]"></div>
            {% endunless %}
          {% endif %}
        {% endfor %}
      </div>
      <p class="text-center text-[10px] text-[#5E6A78] italic mt-16">{{ section.settings.expect_disclaimer }}</p>
    </div>
  </section>


  <!-- ==========================================
       SECTION 8: DAILY HABITS
       ========================================== -->
  <section class="py-24 lg:py-32 px-6 lg:px-20 bg-[#F6FBFD] rounded-[40px] my-10 max-w-[95%] mx-auto">
    <div class="max-w-7xl mx-auto">
      <h2 class="font-serif text-4xl text-[#2F3948] text-center mb-16">Daily Habits That Support Your Routine</h2>
      
      <div class="grid grid-cols-2 md:grid-cols-5 gap-6 text-center">
        {% for block in section.blocks %}
          {% if block.type == 'habit_card' %}
            <div class="flex flex-col items-center" {{ block.shopify_attributes }}>
              <div class="w-20 h-20 bg-white rounded-full flex items-center justify-center text-[#2F3948] mb-6 shadow-sm border border-[#2F3948]/5">
                {% if block.settings.icon != blank %}
                  <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="{{ block.settings.icon }}"/>
                  </svg>
                {% else %}
                  <svg class="w-8 h-8 opacity-20" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                {% endif %}
              </div>
              <p class="text-sm font-medium text-[#5E6A78] max-w-[140px]">{{ block.settings.text }}</p>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </section>


  <!-- ==========================================
       SECTION 9: FAQ
       ========================================== -->
  <section class="py-24 lg:py-32 px-6 lg:px-20 bg-white">
    <div class="max-w-4xl mx-auto">
      <h2 class="font-serif text-4xl text-[#2F3948] mb-12 text-center">Questions We Often Get</h2>
      <div class="space-y-4" x-data="{ active: null }">
        {% for block in section.blocks %}
          {% if block.type == 'faq_item' %}
            <div class="bg-white rounded-[20px] border border-[#2F3948]/10 overflow-hidden" {{ block.shopify_attributes }}>
              <button @click="active === {{ forloop.index }} ? active = null : active = {{ forloop.index }}" class="w-full px-8 py-6 flex justify-between items-center text-left focus:outline-none">
                <span class="font-serif text-xl text-[#2F3948]">{{ block.settings.question }}</span>
                <svg class="w-5 h-5 text-[#5E6A78] transition-transform duration-300" :class="active === {{ forloop.index }} ? 'rotate-180' : ''" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
              </button>
              <div x-show="active === {{ forloop.index }}" x-collapse>
                <div class="px-8 pb-6 text-[#5E6A78] font-medium leading-relaxed">
                  {{ block.settings.answer }}
                </div>
              </div>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </section>


  <!-- ==========================================
       SECTION 10: WHY CHOOSE SERAVOLVE
       ========================================== -->
  <section class="py-24 lg:py-32 px-6 lg:px-20 bg-[#F6FBFD] border-t border-[#2F3948]/5">
    <div class="max-w-6xl mx-auto">
      <h2 class="font-serif text-4xl text-[#2F3948] text-center mb-16">Why Choose Seravolve</h2>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-6">
        {% for block in section.blocks %}
          {% if block.type == 'why_choose_card' %}
            <div class="bg-white p-8 rounded-[28px] text-center shadow-sm border border-[#2F3948]/5" {{ block.shopify_attributes }}>
              <p class="font-serif text-lg text-[#2F3948]">{{ block.settings.title }}</p>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </section>


  <!-- ==========================================
       FINAL CTA
       ========================================== -->
  <section class="relative py-40 px-6 lg:px-20 bg-[#2F3948]">
    {% if section.settings.final_image != blank %}
      {{ section.settings.final_image | image_url: width: 2000 | image_tag: class: 'absolute inset-0 w-full h-full object-cover opacity-40 mix-blend-overlay grayscale', loading: 'lazy' }}
    {% else %}
      <img src="{{ 'heroimg.webp' | asset_url }}" class="absolute inset-0 w-full h-full object-cover opacity-40 mix-blend-overlay grayscale" loading="lazy" alt="Seravolve">
    {% endif %}
    
    <div class="relative z-10 max-w-3xl mx-auto text-center">
      <h2 class="font-serif text-5xl lg:text-7xl text-white mb-8 leading-tight">{{ section.settings.final_heading | newline_to_br }}</h2>
      <p class="text-white/80 font-medium text-lg leading-relaxed mb-12 max-w-xl mx-auto">
        {{ section.settings.final_body | newline_to_br }}
      </p>
      <div class="flex flex-col sm:flex-row justify-center gap-4">
        <a href="#routine" class="px-12 py-5 bg-white text-[#2F3948] rounded-full text-[11px] uppercase tracking-widest font-black hover:bg-[#F6FBFD] transition-colors shadow-xl">
          {{ section.settings.final_btn_1 }}
        </a>
        <a href="/collections/all" class="px-12 py-5 bg-transparent border-2 border-white/20 text-white rounded-full text-[11px] uppercase tracking-widest font-black hover:bg-white/10 transition-colors backdrop-blur-sm">
          {{ section.settings.final_btn_2 }}
        </a>
      </div>
    </div>
