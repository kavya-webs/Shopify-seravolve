{% schema %}
{
  "name": "Find My Routine App",
  "settings": [
    {
      "type": "collection",
      "id": "routine_collection",
      "label": "Routine Products Collection"
    }
  ],
  "presets": [
    {
      "name": "Find My Routine App"
    }
  ]
}
{% endschema %}

<!-- Inject Products into JS Window -->
<script>
  window.routineProducts = [
    {%- assign routine_col = collections[section.settings.routine_collection] -%}
    {%- if routine_col != blank -%}
      {%- for product in routine_col.products -%}
        Object.assign({{ product | json }}, { 
          custom_image: {{ product.featured_image | image_url: width: 400 | json }},
          product_url: {{ product.url | json }}
        }){% unless forloop.last %},{% endunless %}
      {%- endfor -%}
    {%- else -%}
      {%- for product in collections['all'].products limit: 20 -%}
        Object.assign({{ product | json }}, { 
          custom_image: {{ product.featured_image | image_url: width: 400 | json }},
          product_url: {{ product.url | json }}
        }){% unless forloop.last %},{% endunless %}
      {%- endfor -%}
    {%- endif -%}
  ];

  window.scoringConfig = {
    "2-salicylic-acid-deep-cleansing-face-wash-for-acne-control": {
      role: "cleanser", tags: ["Acne & Breakouts", "Oily", "Combination"], baseScore: 10
    },
    "rice-water-3-niacinamide-brightening-toner-for-pore-refining": {
      role: "toner", tags: ["Dullness & Tan", "Acne & Breakouts", "Oily", "Combination"], baseScore: 10
    },
    "luminosity-10-vitamin-c-serum": {
      role: "treatment", tags: ["Dullness & Tan", "Daily Protection", "Morning"], baseScore: 10
    },
    "oil-free-hydrating-face-moisturizer-for-all-skin-types": {
      role: "moisturizer", tags: ["Dry", "Combination", "Weak Skin Barrier"], baseScore: 10
    },
    "ultra-light-spf-50-pa-sunscreen-for-broad-spectrum-protection-description": {
      role: "spf", tags: ["Daily Protection", "Morning", "Both"], baseScore: 10
    }
  };

  document.addEventListener('alpine:init', () => {
    Alpine.data('routineApp', () => ({
      view: 'landing', // 'landing', 'quiz', 'results'
      step: 1,
      totalSteps: 4,
      answers: {
        concern: null,
        skinType: null,
        experience: null,
        usage: null
      },
      amRoutine: [],
      pmRoutine: [],
      routineItems: [],
      totalPrice: 0,
      isAddingToCart: false,
      
      // Question 1
      concerns: [
        { id: "Acne & Breakouts", title: "Acne & Breakouts", desc: "Recurring breakouts and congestion." },
        { id: "Dullness & Tan", title: "Dullness & Tan", desc: "Lack of glow, uneven tone, or sun damage." },
        { id: "Weak Skin Barrier", title: "Weak Skin Barrier", desc: "Redness, sensitivity, or dryness." },
        { id: "Daily Protection", title: "Daily Protection", desc: "Anti-aging and environmental defense." }
      ],
      // Question 2
      skinTypes: [
        { id: "Dry", title: "Dry", desc: "Tightness, flaking, visible fine lines." },
        { id: "Oily", title: "Oily", desc: "Persistent shine, enlarged pores, congestion." },
        { id: "Combination", title: "Combination", desc: "Oily T-zone, dry or normal cheeks." },
        { id: "Normal", title: "Normal", desc: "Balanced moisture, no major concerns." }
      ],
      // Question 3
      experiences: [
        { id: "Beginner", title: "Beginner", desc: "New to active ingredients." },
        { id: "Some Experience", title: "Some Experience", desc: "Used a few serums or acids before." },
        { id: "Regular Routine", title: "Regular Routine", desc: "Comfortable with multi-step routines." }
      ],
      // Question 4
      usages: [
        { id: "Morning", title: "Morning Only", desc: "Quick AM routine." },
        { id: "Night", title: "Night Only", desc: "Focus on PM recovery." },
        { id: "Both", title: "Morning & Night", desc: "Comprehensive 24/7 care." }
      ],

      startQuiz() {
        this.view = 'quiz';
        this.step = 1;
        window.scrollTo({ top: 0, behavior: 'smooth' });
      },

      setAnswer(key, value) {
        this.answers[key] = value;
        setTimeout(() => this.nextStep(), 300);
      },

      nextStep() {
        if (this.step < this.totalSteps) {
          this.step++;
          window.scrollTo({ top: 0, behavior: 'smooth' });
        } else {
          this.generateRoutine();
          this.view = 'results';
          window.scrollTo({ top: 0, behavior: 'smooth' });
        }
      },

      prevStep() {
        if (this.step > 1) {
          this.step--;
          window.scrollTo({ top: 0, behavior: 'smooth' });
        } else {
          this.view = 'landing';
          window.scrollTo({ top: 0, behavior: 'smooth' });
        }
      },

      retake() {
        this.answers = { concern: null, skinType: null, experience: null, usage: null };
        this.view = 'landing';
        window.scrollTo({ top: 0, behavior: 'smooth' });
      },

      generateRoutine() {
        // Scoring Algorithm
        let scoredProducts = window.routineProducts.map(p => {
          let score = 0;
          let config = window.scoringConfig[p.handle] || { role: "treatment", tags: [], baseScore: 5 };
          
          // Weighted scoring based on tags
          if (config.tags.includes(this.answers.concern)) score += 50;
          if (config.tags.includes(this.answers.skinType)) score += 25;
          if (config.tags.includes(this.answers.experience)) score += 15;
          if (config.tags.includes(this.answers.usage)) score += 10;
          
          return { product: p, score: score + config.baseScore, role: config.role };
        });

        // Filter and pick top for each role
        const getTop = (role) => {
          let candidates = scoredProducts.filter(p => p.role === role);
          candidates.sort((a, b) => b.score - a.score);
          return candidates.length > 0 ? candidates[0].product : null;
        };

        const cleanser = getTop("cleanser");
        const toner = getTop("toner");
        const treatment = getTop("treatment");
        const moisturizer = getTop("moisturizer");
        const spf = getTop("spf");

        let am = [];
        let pm = [];

        // Build AM
        if (this.answers.usage !== "Night") {
          if (cleanser && this.answers.skinType !== 'Dry') am.push(cleanser);
          if (toner && ['Oily', 'Combination'].includes(this.answers.skinType)) am.push(toner);
          if (treatment) am.push(treatment);
          if (moisturizer && this.answers.skinType === 'Dry') am.push(moisturizer);
          if (spf) am.push(spf);
        }

        // Build PM
        if (this.answers.usage !== "Morning") {
          if (cleanser) pm.push(cleanser);
          if (toner) pm.push(toner);
          if (moisturizer) pm.push(moisturizer);
        }

        this.amRoutine = am;
        this.pmRoutine = pm;

        // Unique items for cart calculation
        const allItems = [...am, ...pm];
        const uniqueIds = new Set();
        this.routineItems = allItems.filter(item => {
          if (uniqueIds.has(item.id)) return false;
          uniqueIds.add(item.id);
          return true;
        });

        this.totalPrice = this.routineItems.reduce((sum, item) => sum + (item.price / 100), 0);
      },

      getWhyRoutineText() {
        const concernText = this.answers.concern ? this.answers.concern.toLowerCase() : 'your skin';
        return `This routine is designed for ${concernText} and focuses on cleansing, targeted treatment, hydration, and protection based on your specific profile.`;
      },

      getRoleName(handle) {
        let config = window.scoringConfig[handle];
        if(!config) return "Treatment";
        const roles = {
          "cleanser": "Purify",
          "toner": "Refine",
          "treatment": "Target",
          "moisturizer": "Hydrate",
          "spf": "Protect"
        };
        return roles[config.role] || "Treatment";
      },

      async addAllToCart() {
        this.isAddingToCart = true;
        const items = this.routineItems.map(p => ({
          id: p.variants[0].id,
          quantity: 1
        }));

        try {
          const res = await fetch(window.Shopify.routes.root + 'cart/add.js', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ items })
          });
          if (res.ok) window.location.href = '/cart';
        } catch (error) {
          console.error("Error adding to cart:", error);
        } finally {
          this.isAddingToCart = false;
        }
      }
    }));
  });
</script>

<div x-data="routineApp" class="w-full min-h-screen pt-24 lg:pt-32 bg-[#f8faf9] text-brand-charcoal flex flex-col relative overflow-hidden font-sans">
  
  <!-- VIEW: LANDING -->
  <div x-show="view === 'landing'" x-transition.opacity class="w-full flex flex-col items-center">
    
    <!-- Hero -->
    <section class="w-full px-6 py-24 lg:py-32 flex flex-col items-center text-center max-w-4xl mx-auto">
      <h1 class="font-serif text-5xl lg:text-7xl leading-tight text-brand-slate mb-6">Find your skincare routine in under 60 seconds.</h1>
      <p class="text-brand-slate/70 text-lg lg:text-xl max-w-2xl mb-12">Answer a few simple questions and we'll recommend the right routine for your skin—no ingredient knowledge required.</p>
      <button @click="startQuiz" class="bg-brand-aqua text-white px-10 py-5 rounded-full text-xs uppercase tracking-widest font-bold shadow-lg shadow-brand-aqua/20 hover:bg-brand-aqua-deep transition-all duration-300 transform active:scale-95">
        Start Routine Finder
      </button>
    </section>

    <!-- How it Works -->
    <section class="w-full bg-white py-24 px-6 border-t border-brand-charcoal/5">
      <div class="max-w-6xl mx-auto">
        <h2 class="text-center font-serif text-3xl mb-16 text-brand-slate">How It Works</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-12 text-center">
          <div class="flex flex-col items-center">
            <div class="w-16 h-16 rounded-full bg-[#f8faf9] flex items-center justify-center text-brand-aqua mb-6">
              <svg class="w-6 h-6" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><path d="M12 17h.01"/></svg>
            </div>
            <h3 class="font-bold text-lg mb-2 text-brand-slate">Tell us your concern</h3>
            <p class="text-brand-slate/60 text-sm">Select what's bothering your skin right now.</p>
          </div>
          <div class="flex flex-col items-center">
            <div class="w-16 h-16 rounded-full bg-[#f8faf9] flex items-center justify-center text-brand-aqua mb-6">
              <svg class="w-6 h-6" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
            </div>
            <h3 class="font-bold text-lg mb-2 text-brand-slate">Answer a few questions</h3>
            <p class="text-brand-slate/60 text-sm">Help us understand your skin type and lifestyle.</p>
          </div>
          <div class="flex flex-col items-center">
            <div class="w-16 h-16 rounded-full bg-[#f8faf9] flex items-center justify-center text-brand-aqua mb-6">
              <svg class="w-6 h-6" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m2 7 4.41-4.41A2 2 0 0 1 7.83 2h8.34a2 2 0 0 1 1.42.59L22 7"/><path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/><path d="M15 22v-4a2 2 0 0 0-2-2h-2a2 2 0 0 0-2 2v4"/><path d="M2 7h20"/><path d="M22 7v3a2 2 0 0 1-2 2v0a2.7 2.7 0 0 1-1.59-.63.7.7 0 0 0-.82 0A2.7 2.7 0 0 1 16 12a2.7 2.7 0 0 1-1.59-.63.7.7 0 0 0-.82 0A2.7 2.7 0 0 1 12 12a2.7 2.7 0 0 1-1.59-.63.7.7 0 0 0-.82 0A2.7 2.7 0 0 1 8 12a2.7 2.7 0 0 1-1.59-.63.7.7 0 0 0-.82 0A2.7 2.7 0 0 1 4 12v0a2 2 0 0 1-2-2V7"/></svg>
            </div>
            <h3 class="font-bold text-lg mb-2 text-brand-slate">Get your personalized routine</h3>
            <p class="text-brand-slate/60 text-sm">Receive a custom morning and night regimen.</p>
          </div>
        </div>
      </div>
    </section>
  </div>

  <!-- VIEW: QUIZ -->
  <div x-show="view === 'quiz'" style="display: none;" class="w-full flex flex-col min-h-screen">
    <!-- Progress Bar -->
    <div class="w-full px-6 lg:px-20 pt-12">
      <div class="max-w-4xl mx-auto flex items-center justify-between mb-2">
        <span class="text-[10px] uppercase tracking-[0.4em] font-bold text-brand-aqua" x-text="'Step 0' + step"></span>
        <span class="text-[10px] uppercase tracking-[0.4em] font-bold text-brand-charcoal/40" x-text="'0' + totalSteps + ' Total'"></span>
      </div>
      <div class="max-w-4xl mx-auto h-px bg-brand-charcoal/10 relative overflow-hidden">
        <div class="absolute top-0 left-0 h-full bg-brand-aqua transition-all duration-700 ease-out" :style="'width: ' + ((step / totalSteps) * 100) + '%'"></div>
      </div>
    </div>

    <!-- Questions -->
    <main class="flex-grow flex items-center justify-center p-6 pb-24">
      
      <!-- Step 1 -->
      <div x-show="step === 1" x-transition.opacity.duration.300ms class="max-w-4xl w-full text-center">
        <h2 class="font-serif text-3xl lg:text-5xl mb-10 text-brand-slate">What's your biggest concern?</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <template x-for="item in concerns" :key="item.id">
            <button @click="setAnswer('concern', item.id)" :class="answers.concern === item.id ? 'border-brand-aqua bg-brand-aqua/5' : 'border-brand-charcoal/10 bg-white shadow-sm'" class="p-8 rounded-3xl border text-left hover:border-brand-aqua transition-all duration-300">
              <h3 class="text-xl font-serif mb-2 text-brand-slate" x-text="item.title"></h3>
              <p class="text-xs font-light text-brand-slate/60" x-text="item.desc"></p>
            </button>
          </template>
        </div>
      </div>

      <!-- Step 2 -->
      <div x-show="step === 2" x-transition.opacity.duration.300ms style="display: none;" class="max-w-4xl w-full text-center">
        <h2 class="font-serif text-3xl lg:text-5xl mb-10 text-brand-slate">How would you describe your skin?</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <template x-for="item in skinTypes" :key="item.id">
            <button @click="setAnswer('skinType', item.id)" :class="answers.skinType === item.id ? 'border-brand-aqua bg-brand-aqua/5' : 'border-brand-charcoal/10 bg-white shadow-sm'" class="p-8 rounded-3xl border text-left hover:border-brand-aqua transition-all duration-300">
              <h3 class="text-xl font-serif mb-2 text-brand-slate" x-text="item.title"></h3>
              <p class="text-xs font-light text-brand-slate/60" x-text="item.desc"></p>
            </button>
          </template>
        </div>
      </div>

      <!-- Step 3 -->
      <div x-show="step === 3" x-transition.opacity.duration.300ms style="display: none;" class="max-w-4xl w-full text-center">
        <h2 class="font-serif text-3xl lg:text-5xl mb-10 text-brand-slate">How experienced are you with skincare?</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          <template x-for="item in experiences" :key="item.id">
            <button @click="setAnswer('experience', item.id)" :class="answers.experience === item.id ? 'border-brand-aqua bg-brand-aqua/5' : 'border-brand-charcoal/10 bg-white shadow-sm'" class="p-8 rounded-3xl border flex flex-col items-center text-center hover:border-brand-aqua transition-all duration-300">
              <h3 class="text-lg font-serif mb-2 text-brand-slate" x-text="item.title"></h3>
              <p class="text-xs font-light text-brand-slate/60" x-text="item.desc"></p>
            </button>
          </template>
        </div>
      </div>

      <!-- Step 4 -->
      <div x-show="step === 4" x-transition.opacity.duration.300ms style="display: none;" class="max-w-4xl w-full text-center">
        <h2 class="font-serif text-3xl lg:text-5xl mb-10 text-brand-slate">When will you use skincare?</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          <template x-for="item in usages" :key="item.id">
            <button @click="setAnswer('usage', item.id)" :class="answers.usage === item.id ? 'border-brand-aqua bg-brand-aqua/5' : 'border-brand-charcoal/10 bg-white shadow-sm'" class="p-8 rounded-3xl border flex flex-col items-center text-center hover:border-brand-aqua transition-all duration-300">
              <h3 class="text-lg font-serif mb-2 text-brand-slate" x-text="item.title"></h3>
              <p class="text-xs font-light text-brand-slate/60" x-text="item.desc"></p>
            </button>
          </template>
        </div>
      </div>

    </main>

    <!-- Quiz Back Button -->
    <div class="fixed bottom-8 left-1/2 -translate-x-1/2 z-20">
      <button @click="prevStep" class="text-[10px] uppercase tracking-widest font-bold text-brand-slate/40 hover:text-brand-slate transition-colors flex items-center space-x-2">
        <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
        <span>Go Back</span>
      </button>
    </div>
  </div>

  <!-- VIEW: RESULTS -->
  <div x-show="view === 'results'" style="display: none;" class="w-full flex flex-col items-center py-12 lg:py-20 px-6">
    <div class="max-w-4xl w-full">
      
      <p class="text-brand-aqua text-[10px] uppercase font-bold tracking-[0.4em] mb-4 text-center">Custom Regimen</p>
      <h2 class="font-serif text-4xl lg:text-6xl text-center mb-12 text-brand-slate">Your Recommended Routine</h2>
      
      <!-- Routine Breakdown -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-16">
        
        <!-- AM -->
        <div class="bg-white rounded-[32px] p-8 shadow-sm border border-brand-charcoal/5">
          <h3 class="text-brand-aqua text-[10px] uppercase font-bold tracking-[0.2em] mb-6 flex items-center border-b border-brand-charcoal/5 pb-4">
            <svg class="w-4 h-4 mr-2" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="4"/><path d="M12 2v2"/><path d="M12 20v2"/><path d="m4.93 4.93 1.41 1.41"/><path d="m17.66 17.66 1.41 1.41"/><path d="M2 12h2"/><path d="M20 12h2"/><path d="m6.34 17.66-1.41 1.41"/><path d="m19.07 4.93-1.41 1.41"/></svg>
            Morning
          </h3>
          <ul class="space-y-4">
            <template x-if="amRoutine.length > 0">
              <template x-for="(product, idx) in amRoutine" :key="product.id">
                <li class="flex items-center space-x-4">
                  <div class="w-14 h-14 rounded-xl overflow-hidden flex-shrink-0 bg-[#f8faf9]">
                    <img :src="product.custom_image" :alt="product.title" class="w-full h-full object-cover">
                  </div>
                  <div class="flex flex-col flex-grow">
                    <span class="text-[9px] font-bold uppercase tracking-widest text-brand-aqua mb-1" x-text="getRoleName(product.handle)"></span>
                    <span class="font-serif text-[15px] leading-tight text-brand-slate" x-text="product.title"></span>
                  </div>
                  <span class="text-sm font-light whitespace-nowrap" x-text="'₹' + (product.price / 100)"></span>
                </li>
              </template>
            </template>
            <template x-if="amRoutine.length === 0">
              <li class="text-sm font-light text-brand-slate/50 italic py-2">No morning steps required.</li>
            </template>
          </ul>
        </div>

        <!-- PM -->
        <div class="bg-white rounded-[32px] p-8 shadow-sm border border-brand-charcoal/5">
          <h3 class="text-brand-aqua text-[10px] uppercase font-bold tracking-[0.2em] mb-6 flex items-center border-b border-brand-charcoal/5 pb-4">
            <svg class="w-4 h-4 mr-2" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/></svg>
            Night
          </h3>
          <ul class="space-y-4">
            <template x-if="pmRoutine.length > 0">
              <template x-for="(product, idx) in pmRoutine" :key="product.id">
                <li class="flex items-center space-x-4">
                  <div class="w-14 h-14 rounded-xl overflow-hidden flex-shrink-0 bg-[#f8faf9]">
                    <img :src="product.custom_image" :alt="product.title" class="w-full h-full object-cover">
                  </div>
                  <div class="flex flex-col flex-grow">
                    <span class="text-[9px] font-bold uppercase tracking-widest text-brand-aqua mb-1" x-text="getRoleName(product.handle)"></span>
                    <span class="font-serif text-[15px] leading-tight text-brand-slate" x-text="product.title"></span>
                  </div>
                  <span class="text-sm font-light whitespace-nowrap" x-text="'₹' + (product.price / 100)"></span>
                </li>
              </template>
            </template>
            <template x-if="pmRoutine.length === 0">
              <li class="text-sm font-light text-brand-slate/50 italic py-2">No evening steps required.</li>
            </template>
          </ul>
        </div>
      </div>

      <!-- Final CTA -->
      <div class="w-full flex flex-col items-center mb-24 border-b border-brand-charcoal/10 pb-16">
        <div class="bg-brand-aqua/10 text-brand-aqua px-4 py-2 rounded-full text-[10px] font-bold uppercase tracking-widest mb-6">
          Unlock 10% Off Routine Bundle
        </div>
        
        <button 
          @click="addAllToCart"
          :disabled="isAddingToCart || routineItems.length === 0"
          :class="(isAddingToCart || routineItems.length === 0) ? 'opacity-50 cursor-not-allowed' : 'hover:bg-brand-aqua hover:text-white active:scale-95'"
          class="w-full max-w-sm bg-brand-slate text-white px-10 py-5 rounded-full text-xs uppercase tracking-widest font-bold transition-all duration-300 flex items-center justify-center shadow-xl mb-6"
        >
          <span x-text="isAddingToCart ? 'Adding...' : 'Shop This Routine (₹' + (totalPrice * 0.9).toFixed(0) + ')'"></span>
        </button>

        <button 
          @click="retake"
          class="text-[10px] font-bold uppercase tracking-widest text-brand-charcoal/40 hover:text-brand-charcoal transition-colors underline"
        >
          Retake Consultation
        </button>
      </div>

      <!-- Why This Routine -->
      <div class="text-center mb-16 max-w-2xl mx-auto">
