{% schema %}
{
  "name": "Routine Builder",
  "settings": [
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background Image"
    }
  ],
  "presets": [
    {
      "name": "Routine Builder"
    }
  ]
}
{% endschema %}

<!-- Load Alpine.js for state management -->
<script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>

<!-- Inject Products into JS Window -->
<script>
  window.routineProducts = [
    {% if all_products['2-salicylic-acid-deep-cleansing-face-wash-for-acne-control'] != empty %}
      {{ all_products['2-salicylic-acid-deep-cleansing-face-wash-for-acne-control'] | json }},
    {% endif %}
    {% if all_products['rice-water-3-niacinamide-brightening-toner-for-pore-refining'] != empty %}
      {{ all_products['rice-water-3-niacinamide-brightening-toner-for-pore-refining'] | json }},
    {% endif %}
    {% if all_products['luminosity-10-vitamin-c-serum'] != empty %}
      {{ all_products['luminosity-10-vitamin-c-serum'] | json }},
    {% endif %}
    {% if all_products['oil-free-hydrating-face-moisturizer-for-all-skin-types'] != empty %}
      {{ all_products['oil-free-hydrating-face-moisturizer-for-all-skin-types'] | json }},
    {% endif %}
    {% if all_products['ultra-light-spf-50-pa-sunscreen-for-broad-spectrum-protection-description'] != empty %}
      {{ all_products['ultra-light-spf-50-pa-sunscreen-for-broad-spectrum-protection-description'] | json }}
    {% endif %}
  ].filter(p => p != null);

  document.addEventListener('alpine:init', () => {
    Alpine.data('routineBuilder', () => ({
      step: 1,
      answers: {
        skinType: null,
        mainConcern: null,
        sensitivity: 3,
        exposure: null
      },
      amRoutine: [],
      pmRoutine: [],
      routineItems: [],
      totalPrice: 0,
      isAddingToCart: false,

      skinTypes: [
        { id: "Dry", title: "Dry", desc: "Tightness, flaking, visible fine lines." },
        { id: "Oily", title: "Oily", desc: "Persistent shine, enlarged pores, congestion." },
        { id: "Combination", title: "Combination", desc: "Oily T-zone, dry or normal cheeks." },
        { id: "Normal", title: "Normal", desc: "Balanced moisture, no major concerns." }
      ],

      concerns: [
        { id: "Acne", title: "Acne & Blemishes", desc: "Recurring breakouts and congestion." },
        { id: "Aging", title: "Fine Lines & Aging", desc: "Loss of elasticity and expression lines." },
        { id: "Hydration", title: "Dehydration", desc: "Dullness and lack of cellular volume." },
        { id: "Pigmentation", title: "Dark Spots", desc: "Post-acne marking or sun damage." },
        { id: "Sensitivity", title: "Sensitivity", desc: "Redness and reactive skin barrier." }
      ],

      environments: [
        { id: "Indoor", icon: "droplets", title: "Urban Indoor", desc: "Climate controlled, computer blue light exposure." },
        { id: "Outdoor", icon: "sun", title: "High Sun", desc: "Significant UV exposure and environmental heat." },
        { id: "Aggressive", icon: "wind", title: "Aggressive", desc: "Extreme Cold, Wind, or Urban Pollution." }
      ],

      setSkinType(type) { this.answers.skinType = type; this.nextStep(); },
      setConcern(concern) { this.answers.mainConcern = concern; this.nextStep(); },
      setExposure(env) { this.answers.exposure = env; this.nextStep(); },
      
      nextStep() {
        if (this.step < 5) this.step++;
        if (this.step === 5) this.generateRoutine();
      },
      prevStep() {
        if (this.step > 1) this.step--;
      },

      generateRoutine() {
        const cleanser = window.routineProducts.find(p => p.handle.includes("cleansing"));
        const toner = window.routineProducts.find(p => p.handle.includes("toner"));
        const serum = window.routineProducts.find(p => p.handle.includes("serum"));
        const moisturizer = window.routineProducts.find(p => p.handle.includes("moisturizer"));
        const spf = window.routineProducts.find(p => p.handle.includes("sunscreen"));

        let am = [];
        let pm = [];

        // 1. Cleanser
        const excludeSalicylic = this.answers.skinType === "Dry" && this.answers.sensitivity >= 4;
        if (!excludeSalicylic && cleanser) { am.push(cleanser); pm.push(cleanser); }

        // 2. Toner
        const includeToner = ["Oily", "Combination"].includes(this.answers.skinType) || 
                             ["Acne", "Pigmentation"].includes(this.answers.mainConcern);
        if (includeToner && toner) pm.push(toner);

        // 3. Serum
        const excludeVitC = parseInt(this.answers.sensitivity) === 5;
        const includeVitC = !excludeVitC && 
                           (["Pigmentation", "Aging"].includes(this.answers.mainConcern) || 
                            ["Outdoor", "Aggressive"].includes(this.answers.exposure));
        if (includeVitC && serum) am.push(serum);

        // 4. Moisturizer
        if (moisturizer) {
          if (["Dry", "Combination"].includes(this.answers.skinType)) am.push(moisturizer);
          pm.push(moisturizer);
        }

        // 5. SPF
        if (spf) am.push(spf);

        this.amRoutine = am;
        this.pmRoutine = pm;

        // Unique items
        const allItems = [...am, ...pm];
        const uniqueIds = new Set();
        this.routineItems = allItems.filter(item => {
          if (uniqueIds.has(item.id)) return false;
          uniqueIds.add(item.id);
          return true;
        });

        this.totalPrice = this.routineItems.reduce((sum, item) => sum + (item.price / 100), 0);
      },

      getRoleForProduct(handle) {
        if (handle.includes("cleansing")) return "Purify";
        if (handle.includes("toner")) return "Refresh & Refine";
        if (handle.includes("serum")) return "Core Treatment";
        if (handle.includes("moisturizer")) return "Seal & Repair";
        if (handle.includes("sunscreen")) return "Shield";
        return "Treatment";
      },

      async addAllToCart() {
        this.isAddingToCart = true;
        
        const items = this.routineItems.map(p => ({
          id: p.variants[0].id,
          quantity: 1
        }));

        try {
          const res = await fetch(window.Shopify.routes.root + 'cart/add.js', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ items })
          });
          
          if (res.ok) {
            window.location.href = '/cart';
          }
        } catch (error) {
          console.error("Error adding to cart:", error);
        } finally {
          this.isAddingToCart = false;
        }
      }
    }));
  });
</script>

<div x-data="routineBuilder" class="w-full min-h-screen bg-brand-charcoal text-white flex flex-col relative overflow-hidden">
  
  <!-- Background Image -->
  <div class="absolute inset-0 z-0 transition-opacity duration-1000 opacity-40">
    <img
      src="{% if section.settings.background_image != blank %}{{ section.settings.background_image | image_url: width: 2000 }}{% else %}https://cdn.shopify.com/s/files/1/0885/8763/2932/files/contacthero.webp?v=1718873000{% endif %}"
      alt=""
      aria-hidden="true"
      class="w-full h-full object-cover"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-brand-charcoal/80 via-transparent to-brand-charcoal"></div>
  </div>

  <!-- Progress Bar -->
  <div class="relative z-10 w-full px-6 lg:px-20 pt-32 transition-all duration-500">
    <div class="max-w-4xl mx-auto flex items-center justify-between mb-2">
      <span class="text-[10px] uppercase tracking-[0.4em] font-bold text-brand-aqua" x-text="'Step 0' + step"></span>
      <span class="text-[10px] uppercase tracking-[0.4em] font-bold text-white/40">05 Total</span>
    </div>
    <div class="max-w-4xl mx-auto h-px bg-white/10 relative overflow-hidden">
      <div 
        class="absolute top-0 left-0 h-full bg-brand-aqua shadow-[0_0_10px_rgba(212,175,55,0.5)] transition-all duration-700 ease-out"
        :style="'width: ' + ((step / 5) * 100) + '%'"
      ></div>
    </div>
  </div>

  <!-- Steps Content -->
  <main class="relative z-10 flex-grow flex items-center justify-center p-6 pb-32">
    
    <!-- STEP 1: Skin Type -->
    <div x-show="step === 1" x-transition.opacity.duration.500ms class="max-w-4xl w-full text-center">
      <h2 class="font-serif text-4xl lg:text-7xl mb-12 !text-white">How would you describe your <span class="italic font-light">Natural Texture</span>?</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <template x-for="type in skinTypes" :key="type.id">
          <button
            @click="setSkinType(type.id)"
            :class="answers.skinType === type.id ? 'border-brand-aqua bg-brand-gold/10' : 'border-white/10 glass-dark'"
            class="p-8 rounded-[32px] border text-left hover:border-brand-aqua transition-all duration-300 transform hover:scale-[1.02]"
          >
            <h3 class="text-xl font-serif mb-2 !text-white" x-text="type.title"></h3>
            <p class="text-xs leading-relaxed font-light !text-white/50" x-text="type.desc"></p>
          </button>
        </template>
      </div>
    </div>

    <!-- STEP 2: Concern -->
    <div x-show="step === 2" x-transition.opacity.duration.500ms style="display: none;" class="max-w-5xl w-full text-center">
      <h2 class="font-serif text-4xl lg:text-7xl mb-12 !text-white">What is your primary <span class="italic font-light text-brand-aqua">Focus Area</span>?</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <template x-for="concern in concerns" :key="concern.id">
          <button
            @click="setConcern(concern.id)"
            :class="answers.mainConcern === concern.id ? 'border-brand-aqua bg-brand-gold/10' : 'border-white/10 glass-dark'"
            class="p-8 rounded-[32px] border text-left hover:border-brand-aqua transition-all duration-300 transform hover:scale-[1.02]"
          >
            <h3 class="text-xl font-serif mb-2 !text-white" x-text="concern.title"></h3>
            <p class="text-xs leading-relaxed font-light !text-white/50" x-text="concern.desc"></p>
          </button>
        </template>
      </div>
    </div>

    <!-- STEP 3: Sensitivity -->
    <div x-show="step === 3" x-transition.opacity.duration.500ms style="display: none;" class="max-w-3xl w-full text-center">
      <h2 class="font-serif text-4xl lg:text-7xl mb-12 !text-white">Assess your skin's <span class="italic font-light">Sensitivity</span></h2>
      <div class="space-y-16">
        <input 
          type="range" min="1" max="5" 
          x-model="answers.sensitivity"
          class="w-full accent-brand-gold bg-white/10 h-1 rounded-full cursor-pointer"
        />
        <div class="flex justify-between text-[10px] uppercase tracking-widest font-bold opacity-60 !text-white">
          <span>Resilient</span>
          <span>Reactive</span>
        </div>
        <button 
          @click="nextStep()"
          class="mt-12 bg-brand-aqua hover:bg-white text-brand-charcoal px-12 py-5 rounded-full text-xs uppercase tracking-[0.2em] font-bold transition-colors duration-300"
        >
          Continue Routine
        </button>
      </div>
    </div>

    <!-- STEP 4: Environment -->
    <div x-show="step === 4" x-transition.opacity.duration.500ms style="display: none;" class="max-w-4xl w-full text-center">
      <h2 class="font-serif text-4xl lg:text-7xl mb-12 !text-white">Your primary <span class="italic font-light">Daily Environment</span>?</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <template x-for="env in environments" :key="env.id">
          <button
            @click="setExposure(env.id)"
            :class="answers.exposure === env.id ? 'border-brand-aqua bg-brand-gold/10' : 'border-white/10 glass-dark'"
            class="p-10 rounded-[40px] border flex flex-col items-center hover:border-brand-aqua transition-all duration-300 group"
          >
            <!-- Drop Icon -->
            <svg x-show="env.icon === 'droplets'" class="w-10 h-10 text-brand-aqua mb-6 group-hover:scale-110 transition-transform" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 16.3c2.2 0 4-1.83 4-4.05 0-1.16-.57-2.26-1.71-3.19S7.29 6.75 7 5.3c-.29 1.45-1.14 2.84-2.29 3.76S3 11.1 3 12.25c0 2.22 1.8 4.05 4 4.05z"/><path d="M12.56 6.6A10.97 10.97 0 0 0 14 3.02c.5 2.5 2 4.9 4 6.5s3 3.5 3 5.5a6.98 6.98 0 0 1-11.91 4.97"/></svg>
            <!-- Sun Icon -->
            <svg x-show="env.icon === 'sun'" class="w-10 h-10 text-brand-aqua mb-6 group-hover:scale-110 transition-transform" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2"/><path d="M12 20v2"/><path d="m4.93 4.93 1.41 1.41"/><path d="m17.66 17.66 1.41 1.41"/><path d="M2 12h2"/><path d="M20 12h2"/><path d="m6.34 17.66-1.41 1.41"/><path d="m19.07 4.93-1.41 1.41"/></svg>
            <!-- Wind Icon -->
            <svg x-show="env.icon === 'wind'" class="w-10 h-10 text-brand-aqua mb-6 group-hover:scale-110 transition-transform" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.7 7.7a2.5 2.5 0 1 1 1.8 4.3H2"/><path d="M9.6 4.6A2 2 0 1 1 11 8H2"/><path d="M12.6 19.4A2 2 0 1 0 14 16H2"/></svg>
            
            <h3 class="text-xl font-serif mb-2 !text-white" x-text="env.title"></h3>
            <p class="text-xs leading-relaxed font-light !text-white/50" x-text="env.desc"></p>
          </button>
        </template>
      </div>
    </div>

    <!-- STEP 5: Results -->
    <div x-show="step === 5" x-transition.opacity.duration.800ms style="display: none;" class="max-w-6xl w-full bg-white text-brand-charcoal rounded-[60px] p-12 lg:p-24 shadow-2xl flex flex-col items-center">
      <p class="text-brand-aqua text-[10px] uppercase font-bold tracking-[0.4em] mb-8">Your Custom Routine</p>
      <h2 class="font-serif text-4xl lg:text-7xl text-center mb-16">Your <span class="italic font-light">Custom Routine</span></h2>
      
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-20 w-full mb-20">
        
        <!-- AM Routine -->
        <div>
          <h3 class="text-brand-aqua text-[10px] uppercase font-bold tracking-[0.2em] mb-10 border-b border-brand-charcoal/5 pb-4 flex items-center">
            <svg class="w-4 h-4 mr-2" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2"/><path d="M12 20v2"/><path d="m4.93 4.93 1.41 1.41"/><path d="m17.66 17.66 1.41 1.41"/><path d="M2 12h2"/><path d="M20 12h2"/><path d="m6.34 17.66-1.41 1.41"/><path d="m19.07 4.93-1.41 1.41"/></svg>
            AM: The Protection Phase
          </h3>
          <ul class="space-y-8">
            <template x-if="amRoutine.length > 0">
              <template x-for="(product, idx) in amRoutine" :key="product.id">
                <li class="flex items-center space-x-6">
                  <span class="font-serif text-3xl opacity-10" x-text="'0' + (idx + 1)"></span>
                  <div class="flex flex-col">
                    <span class="text-xs font-bold uppercase tracking-widest text-brand-aqua mb-1" x-text="getRoleForProduct(product.handle)"></span>
                    <span class="font-serif text-xl" x-text="product.title"></span>
                  </div>
                </li>
              </template>
            </template>
            <template x-if="amRoutine.length === 0">
              <li class="text-sm font-light text-brand-charcoal/50 italic py-4">No morning steps required.</li>
            </template>
          </ul>
        </div>
        
        <!-- PM Routine -->
        <div>
          <h3 class="text-brand-aqua text-[10px] uppercase font-bold tracking-[0.2em] mb-10 border-b border-brand-charcoal/5 pb-4 flex items-center">
            <svg class="w-4 h-4 mr-2" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 16.3c2.2 0 4-1.83 4-4.05 0-1.16-.57-2.26-1.71-3.19S7.29 6.75 7 5.3c-.29 1.45-1.14 2.84-2.29 3.76S3 11.1 3 12.25c0 2.22 1.8 4.05 4 4.05z"/><path d="M12.56 6.6A10.97 10.97 0 0 0 14 3.02c.5 2.5 2 4.9 4 6.5s3 3.5 3 5.5a6.98 6.98 0 0 1-11.91 4.97"/></svg>
            PM: The Recovery Phase
          </h3>
          <ul class="space-y-8">
            <template x-if="pmRoutine.length > 0">
              <template x-for="(product, idx) in pmRoutine" :key="product.id">
                <li class="flex items-center space-x-6">
                  <span class="font-serif text-3xl opacity-10" x-text="'0' + (idx + 1)"></span>
                  <div class="flex flex-col">
                    <span class="text-xs font-bold uppercase tracking-widest text-brand-aqua mb-1" x-text="getRoleForProduct(product.handle)"></span>
                    <span class="font-serif text-xl" x-text="product.title"></span>
                  </div>
                </li>
              </template>
            </template>
            <template x-if="pmRoutine.length === 0">
              <li class="text-sm font-light text-brand-charcoal/50 italic py-4">No evening steps required.</li>
            </template>
          </ul>
        </div>

      </div>

      <button 
        @click="addAllToCart"
        :disabled="isAddingToCart || routineItems.length === 0"
        :class="(isAddingToCart || routineItems.length === 0) ? 'opacity-50 cursor-not-allowed' : 'hover:bg-brand-aqua active:scale-95'"
        class="bg-brand-slate text-white px-16 py-6 rounded-full text-xs uppercase tracking-widest font-bold transition-all duration-300 flex items-center space-x-4 shadow-xl"
      >
        <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="8" cy="21" r="1"/><circle cx="19" cy="21" r="1"/><path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"/></svg>
        <span x-text="isAddingToCart ? 'Adding...' : 'Add Full Routine to Cart (₹' + totalPrice + ')'"></span>
      </button>

    </div>

  </main>

  <!-- Footer Navigation (Back Button) -->
  <div x-show="step < 5" class="fixed bottom-12 left-1/2 -translate-x-1/2 z-20">
    <button 
      @click="prevStep"
      :disabled="step === 1"
      :class="step === 1 ? 'opacity-0 pointer-events-none' : 'opacity-40 hover:opacity-100'"
      class="flex items-center space-x-3 text-[10px] uppercase tracking-widest font-bold transition-opacity"
    >
      <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
      <span>Go Back</span>
    </button>
  </div>

</div>
