<section class="py-20 lg:py-32 px-6 lg:px-20 bg-white">
  <div class="max-w-7xl mx-auto">
    {%- assign routines = product.metafields.custom.parent_routines.value -%}
    {%- if routines != blank -%}
      <div class="mb-16 text-center lg:text-left flex flex-col lg:flex-row justify-between items-center gap-8">
        <div>
          <p class="text-[9px] uppercase tracking-[0.5em] font-bold mb-4 text-brand-aqua">Related</p>
          <h2 class="font-serif text-3xl lg:text-5xl font-light text-brand-slate">Used in these Routines</h2>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {%- for parent in routines -%}
          <!-- Render the parent routine product card -->
          <a href="{{ parent.url }}" class="group block bg-[#f8faf9] rounded-[32px] p-6 lg:p-8 border border-brand-charcoal/5 hover:border-brand-aqua/20 transition-all shadow-sm hover:shadow-lg">
            <div class="aspect-[4/3] rounded-2xl overflow-hidden bg-brand-charcoal/5 mb-8 relative">
              {%- if parent.featured_image != blank -%}
                <img src="{{ parent.featured_image | image_url: width: 600 }}" alt="{{ parent.title | escape }}" class="w-full h-full object-cover mix-blend-multiply group-hover:scale-105 transition-transform duration-700" loading="lazy" width="{{ parent.featured_image.width }}" height="{{ parent.featured_image.height }}">
              {%- else -%}
                {{ 'product-1' | placeholder_svg_tag: 'w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 opacity-50' }}
              {%- endif -%}
              <div class="absolute top-4 left-4 bg-brand-aqua text-white text-[9px] uppercase tracking-widest font-bold px-3 py-1 rounded-full">Complete Routine</div>
            </div>
            
            <h3 class="font-serif text-2xl text-brand-slate mb-2 group-hover:text-brand-aqua transition-colors">{{ parent.title }}</h3>
            <p class="text-sm text-brand-slate/60 font-light mb-6">{{ parent.metafields.custom.why_we_made_this | default: 'A complete skincare sequence.' | truncatewords: 10 }}</p>
            
            <div class="flex items-center justify-between mt-auto">
              <p class="font-serif text-xl text-brand-slate">{{ parent.price | money_without_trailing_zeros }}</p>
              <span class="w-10 h-10 rounded-full bg-white flex items-center justify-center shadow-sm text-brand-aqua group-hover:bg-brand-aqua group-hover:text-white transition-colors">
                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </span>
            </div>
          </a>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Related Routines",
  "settings": [],
  "presets": [
    {
      "name": "Related Routines"
    }
  ]
}
{% endschema %}
