<main class="min-h-screen bg-brand-glacial text-brand-slate selection:bg-brand-aqua selection:text-white pt-32 pb-48">
  <div class="fixed inset-0 pointer-events-none opacity-40">
    <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-brand-aqua/5 blur-[120px] rounded-full"></div>
    <div class="absolute bottom-0 left-0 w-[500px] h-[500px] bg-brand-slate/5 blur-[100px] rounded-full"></div>
  </div>
  <div class="max-w-4xl mx-auto px-6 lg:px-20 relative z-10">
    <p class="text-[10px] uppercase tracking-[0.4em] font-bold text-brand-aqua mb-4">Legal Policy</p>
    <h1 class="font-serif text-5xl lg:text-7xl font-light mb-8 leading-tight">Refund & Return Policy</h1>
    <div class="flex items-center space-x-4 mb-20">
      <div class="h-px w-8 bg-brand-aqua/40"></div>
      <p class="text-[10px] uppercase tracking-[0.2em] font-medium text-brand-slate-light">Last Updated: June 2026</p>
    </div>
    
    <div class="space-y-12 text-lg text-brand-slate-light font-medium leading-relaxed">
      <section>
        <p class="mb-4 font-bold text-brand-slate text-xl">No general returns or buyer's remorse returns are accepted.</p>
        <p class="mb-4">You can only raise a request if you receive:</p>
        <ul class="list-disc pl-6 mb-4 space-y-2 text-brand-slate-light">
          <li>a wrong product,</li>
          <li>a damaged product, or</li>
          <li>an incomplete order.</li>
        </ul>
        <p class="mb-4">
          The request must be raised within <strong class="text-brand-slate font-bold">48 hours</strong> of delivery, usually with an unboxing video and invoice.
        </p>

        <div class="bg-white p-8 rounded-3xl border border-brand-marble/50 mt-8 space-y-4">
          <h3 class="text-xl font-serif font-bold text-brand-slate mb-4">Google Merchant Center Compliance</h3>
          <ul class="space-y-3">
            <li class="flex justify-between items-baseline border-b border-brand-marble/30 pb-2">
              <span class="font-bold text-brand-slate">Return Window</span>
              <span>48 Hours (for damaged/incorrect items)</span>
            </li>
            <li class="flex justify-between items-baseline border-b border-brand-marble/30 pb-2">
              <span class="font-bold text-brand-slate">Item Condition Required</span>
              <span>Unopened, original packaging, unused</span>
            </li>
            <li class="flex justify-between items-baseline border-b border-brand-marble/30 pb-2">
              <span class="font-bold text-brand-slate">Restocking Fee</span>
              <span>No Restocking Fee</span>
            </li>
            <li class="flex justify-between items-baseline pb-2">
              <span class="font-bold text-brand-slate">Return Shipping Costs</span>
              <span>We arrange and pay for reverse pickup for damaged/incorrect items</span>
            </li>
          </ul>
        </div>
      </section>

      <section>
        <p class="mt-8 font-bold uppercase tracking-widest text-[10px] text-brand-slate">
          Raise request on our WhatsApp:
        </p>
        <p class="mt-2 text-xl text-brand-aqua font-bold">
          <a href="https://wa.me/919978099097" target="_blank" rel="noopener noreferrer" class="hover:text-brand-aqua-deep transition-colors">+91 9978099097</a>
        </p>
      </section>

      <section>
        <h2 class="text-3xl font-serif font-light text-brand-slate mb-6">Contact Us</h2>
        <p class="mb-4">
          For any return or refund inquiries, please contact us via:
        </p>
        <ul class="list-disc pl-6 mb-4 space-y-2">
          <li><strong class="text-brand-slate font-bold">Email:</strong> info@seravolve.com</li>
          <li><strong class="text-brand-slate font-bold">Phone/WhatsApp:</strong> +91 9978099097</li>
          <li><strong class="text-brand-slate font-bold">Address:</strong> 333 Shayona Plaza, Puna-Saroli Junction, BRTS Road, Surat, Gujarat 395010, India</li>
        </ul>
      </section>
    </div>
  </div>
</main>

{% schema %}
{
  "name": "Legal Refund Policy",
  "settings": []
}
{% endschema %}
