<main class="min-h-screen bg-brand-glacial text-brand-slate selection:bg-brand-aqua selection:text-white pt-32 pb-48">
  <div class="fixed inset-0 pointer-events-none opacity-40">
    <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-brand-aqua/5 blur-[120px] rounded-full"></div>
    <div class="absolute bottom-0 left-0 w-[500px] h-[500px] bg-brand-slate/5 blur-[100px] rounded-full"></div>
  </div>
  <div class="max-w-4xl mx-auto px-6 lg:px-20 relative z-10">
    <p class="text-[10px] uppercase tracking-[0.4em] font-bold text-brand-aqua mb-4">Legal Policy</p>
    <h1 class="font-serif text-5xl lg:text-7xl font-light mb-8 leading-tight">Shipping Policy</h1>
    <div class="flex items-center space-x-4 mb-20">
      <div class="h-px w-8 bg-brand-aqua/40"></div>
      <p class="text-[10px] uppercase tracking-[0.2em] font-medium text-brand-slate-light">Last Updated: June 2026</p>
    </div>
    
    <div class="space-y-12 text-lg text-brand-slate-light font-medium leading-relaxed">
      <section>
        <h2 class="text-3xl font-serif font-light text-brand-slate mb-6">Processing & Timeline</h2>
        <p class="mb-4">
          This Shipping Policy is issued by <strong class="text-brand-slate font-bold">ELISENSE ENTERPRISE LLP</strong>, operating under the trademark <strong class="text-brand-slate font-bold">SERAVOLVE™</strong>. Each formulation is handled with clinical care. Orders are processed within 1-2 business days. The cutoff time for order processing is 5:00 PM (IST).
        </p>
        <p class="mt-4 border-l-2 border-brand-aqua pl-6 py-2 italic font-serif text-brand-slate">
          We ship exclusively within the Indian subcontinent.
        </p>
      </section>

      <section>
        <h2 class="text-3xl font-serif font-light text-brand-slate mb-6">Domestic Delivery</h2>
        <p class="mb-4">
          We offer prioritized shipping across India. Our standard clinical transit typically completes within 5-7 business days from the date of dispatch.
        </p>
      </section>

      <section>
        <h2 class="text-3xl font-serif font-light text-brand-slate mb-6">Shipping Rates & Speed</h2>
        <div class="bg-white p-8 rounded-3xl border border-brand-marble/50">
          <ul class="space-y-4">
            <li class="flex justify-between items-baseline border-b border-brand-marble/30 pb-2">
              <span class="font-bold text-brand-slate">Order Handling Time</span>
              <span>1 - 2 Business Days (Mon-Fri)</span>
            </li>
            <li class="flex justify-between items-baseline border-b border-brand-marble/30 pb-2">
              <span class="font-bold text-brand-slate">Order Transit Time</span>
              <span>5 - 7 Business Days (Mon-Fri)</span>
            </li>
            <li class="flex justify-between items-baseline border-b border-brand-marble/30 pb-2">
              <span class="font-bold text-brand-slate">Standard Delivery (Under ₹1999)</span>
              <span>₹199</span>
            </li>
            <li class="flex justify-between items-baseline pb-2">
              <span class="font-bold text-brand-aqua">Standard Delivery (Orders ₹1999+)</span>
              <span class="font-bold text-brand-aqua">FREE</span>
            </li>
          </ul>
        </div>
      </section>

      <section>
        <h2 class="text-3xl font-serif font-light text-brand-slate mb-6">Shipment Confirmation & Tracking</h2>
        <p class="mb-4">
          You will receive a Shipment Confirmation email containing your tracking number(s) once your order has shipped. The tracking number will be active within 24 hours.
        </p>
      </section>

      <section>
        <h2 class="text-3xl font-serif font-light text-brand-slate mb-6">Damages & Integrity</h2>
        <p class="mb-4">
          ELISENSE ENTERPRISE LLP (operating as SERAVOLVE) ensures all products leave our laboratory in pristine, clinically-sealed condition. If you received your order damaged, please notify our clinical support team on WhatsApp at +91 9978099097 within 48 hours of delivery so we can arrange a replacement and file a claim with the carrier.
        </p>
      </section>

      <section>
        <h2 class="text-3xl font-serif font-light text-brand-slate mb-6">Contact Us</h2>
        <p class="mb-4">
          If you have any questions about your shipment, please contact us via:
        </p>
        <ul class="list-disc pl-6 mb-4 space-y-2">
          <li><strong class="text-brand-slate font-bold">Email:</strong> info@seravolve.com</li>
          <li><strong class="text-brand-slate font-bold">Phone/WhatsApp:</strong> +91 9978099097</li>
          <li><strong class="text-brand-slate font-bold">Address:</strong> 333 Shayona Plaza, Puna-Saroli Junction, BRTS Road, Surat, Gujarat 395010, India</li>
        </ul>
      </section>
    </div>
  </div>
</main>

{% schema %}
{
  "name": "Legal Shipping Policy",
  "settings": []
}
{% endschema %}
