{% schema %}
{
  "name": "Custom Collection",
  "settings": [],
  "presets": [
    {
      "name": "Custom Collection"
    }
  ]
}
{% endschema %}

<!-- Load Alpine.js -->
<script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>

<script>
  // Derive categories: use Shopify productType if available, otherwise guess from handle
  const deriveCategory = (handle, type) => {
    if (type && type.trim() !== "") return type;
    handle = handle.toLowerCase();
    if (handle.includes('cleans') || handle.includes('wash')) return "Cleansers";
    if (handle.includes('serum')) return "Serums";
    if (handle.includes('moisturizer')) return "Moisturizers";
    if (handle.includes('toner')) return "Toners";
    if (handle.includes('sunscreen') || handle.includes('spf')) return "Sun Care";
    return "Treatments";
  };

  window.collectionProducts = [
    {% for product in collection.products %}
      {
        id: {{ product.id | json }},
        handle: {{ product.handle | json }},
        title: {{ product.title | json }},
        price: {{ product.price | divided_by: 100.0 | json }},
        productType: {{ product.type | json }},
        featuredImage: {{ product.featured_image | img_url: 'master' | json }},
        url: {{ product.url | json }},
        category: deriveCategory({{ product.handle | json }}, {{ product.type | json }}),
        concern: {{ product.metafields.custom.concern | default: '"Premium Formulation"' }}
      }{% unless forloop.last %},{% endunless %}
    {% endfor %}
  ];

  document.addEventListener('alpine:init', () => {
    Alpine.data('collectionApp', () => ({
      activeCategory: "All",
      searchQuery: "",
      
      get categories() {
        const cats = new Set(window.collectionProducts.map(p => p.category));
        return ["All", ...Array.from(cats)];
      },
      
      get filteredProducts() {
        return window.collectionProducts.filter(p => {
          const matchesCategory = this.activeCategory === "All" || p.category === this.activeCategory;
          const matchesSearch = p.title.toLowerCase().includes(this.searchQuery.toLowerCase());
          return matchesCategory && matchesSearch;
        });
      }
    }));
  });
</script>

<div x-data="collectionApp" class="w-full min-h-screen bg-white pb-32">
  <!-- SHOP HERO -->
  <section class="relative h-[85vh] min-h-[600px] w-full flex items-end pb-20 overflow-hidden">
    <div class="absolute inset-0 z-0">
      <img
        src="{{ 'producthero.webp' | asset_url }}"
        alt="SERAVOLVE Botanical Collection"
        class="w-full h-full object-cover"
        loading="eager"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-brand-charcoal/60 via-transparent to-transparent"></div>
    </div>

    <div class="max-w-7xl mx-auto px-6 lg:px-20 relative z-10 w-full">
      <div class="glass max-w-xl p-10 lg:p-14 rounded-3xl border border-white/30 shadow-2xl transition-all duration-1000">
        <p class="text-[10px] uppercase tracking-[0.4em] font-black text-brand-aqua mb-6 italic">
          Synchronized Science
        </p>
        <h1 class="font-serif text-5xl lg:text-7xl !text-white mb-6 leading-tight">
          The Botanical <span class="italic font-light">Collection</span>
        </h1>
        <p class="text-sm !text-white/80 leading-relaxed font-medium">
          Explore our laboratory-vetted sequences. Each formula is a kinetic marriage of molecular precision and raw plant wisdom.
        </p>
      </div>
    </div>
  </section>

  <!-- FILTER & SEARCH BAR -->
  <section class="relative bg-white/80 backdrop-blur-xl border-b border-brand-marble/5 py-8 px-6 lg:px-20 mb-20 z-20">
    <div class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-center gap-8">
      
      <div class="flex items-center space-x-6 md:space-x-8 overflow-x-auto w-full md:w-auto pb-2 md:pb-0 scrollbar-hide snap-x">
        <template x-for="cat in categories" :key="cat">
          <button
            @click="activeCategory = cat"
            :class="[
              'flex-shrink-0 snap-start text-[10px] uppercase tracking-[0.3em] font-black transition-all duration-300 relative pb-1 whitespace-nowrap',
              activeCategory === cat ? 'text-brand-aqua' : 'text-brand-slate-light/60 hover:text-brand-slate'
            ]"
          >
            <span x-text="cat"></span>
            <div x-show="activeCategory === cat" class="absolute bottom-0 left-0 right-0 h-px bg-brand-aqua transition-all duration-300"></div>
          </button>
        </template>
      </div>

      <div class="relative w-full md:w-80">
        <input
          type="text"
          placeholder="Search Library..."
          x-model="searchQuery"
          class="w-full bg-brand-glacial/10 border border-brand-marble/5 rounded-full py-2.5 px-6 text-[10px] uppercase tracking-widest focus:outline-none focus:border-brand-aqua/40 shadow-inner"
        />
        <svg class="absolute right-5 top-1/2 -translate-y-1/2 w-3.5 h-3.5 text-brand-slate-light/40" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      </div>
    </div>
  </section>

  <!-- PRODUCT GRID -->
  <section class="max-w-7xl mx-auto px-6 lg:px-20">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-12 gap-y-24">
      <template x-for="product in filteredProducts" :key="product.id">
        <div class="block relative group transition-all duration-500">
          <a :href="product.url" class="block w-full">
            <div class="absolute top-[20%] -right-[10%] w-32 h-32 rounded-full bg-brand-gold/10 blur-2xl pointer-events-none transition-transform duration-500 group-hover:scale-150"></div>
            <div class="absolute top-[5%] -right-[5%] h-24 border-l border-brand-marble/20 pointer-events-none"></div>

            <div class="relative w-full p-8 bg-white border border-brand-marble/5 rounded-[2rem] flex flex-col items-center transition-all duration-500 hover:shadow-[0_40px_80px_rgba(0,0,0,0.08)] hover:-translate-y-2">
              
              <!-- Image Area -->
              <div class="relative w-full aspect-square rounded-3xl overflow-hidden mb-10 bg-brand-glacial/10 shadow-inner">
                <img
                  :src="product.featuredImage"
                  :alt="product.title"
                  class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110"
                  loading="lazy"
                />
                <div class="absolute inset-0 bg-black/0 group-hover:bg-black/5 transition-colors duration-300"></div>
                <div class="absolute bottom-6 left-1/2 -translate-x-1/2 glass px-6 py-2.5 rounded-full text-[10px] font-black uppercase tracking-widest text-brand-slate opacity-0 translate-y-4 group-hover:opacity-100 group-hover:translate-y-0 transition-all duration-500 flex items-center space-x-2 whitespace-nowrap">
                  <svg class="w-3 h-3" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><path d="M3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
                  <span>View Details</span>
                </div>
              </div>

              <!-- Content -->
              <div class="w-full text-center space-y-3 mb-8">
                <h3 class="text-brand-slate font-serif text-2xl lg:text-3xl font-light tracking-tight" x-text="product.title"></h3>
                <p class="text-[9px] uppercase tracking-[0.25em] text-brand-aqua font-bold" x-text="product.productType || 'SKINCARE'"></p>
                <div class="h-px w-8 bg-brand-gold/30 mx-auto"></div>
              </div>

              <!-- Footer -->
              <div class="w-full flex items-center justify-between border-t border-brand-marble/5 pt-6">
                <div class="flex flex-col text-left">
                  <strong class="text-brand-slate-light text-[9px] uppercase tracking-[0.3em] font-bold mb-0.5" x-text="product.productType || 'SKINCARE'"></strong>
                  <span class="text-[10px] tracking-widest uppercase font-bold text-brand-aqua/80 mt-1" x-text="product.concern"></span>
                </div>

                <div class="flex items-baseline space-x-1">
                  <span class="text-xs font-medium text-brand-aqua">₹</span>
                  <span class="text-2xl font-mono font-light text-brand-slate tracking-tighter leading-none" x-text="product.price"></span>
                </div>
              </div>

            </div>
          </a>
        </div>
      </template>
    </div>

    <div x-show="filteredProducts.length === 0" style="display: none;" class="flex flex-col items-center justify-center py-32">
      <h3 class="text-6xl md:text-8xl lg:text-[10rem] font-serif text-brand-slate/10 mb-8 italic tracking-tight leading-none relative overflow-hidden text-center block">
        Coming Soon
      </h3>
      <p class="text-brand-aqua uppercase tracking-[0.4em] text-xs md:text-sm font-black text-center">
        No formulas found for this sequence
      </p>
    </div>
  </section>
</div>
