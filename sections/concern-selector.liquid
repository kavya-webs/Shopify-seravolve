{% schema %}
{
  "name": "Shop By Concern",
  "settings": [],
  "presets": [
    {
      "name": "Shop By Concern"
    }
  ]
}
{% endschema %}

<!-- Load Alpine.js -->

<script>
  document.addEventListener('alpine:init', () => {
    Alpine.data('concernSelector', () => ({
      concerns: [
        { id: "acne", title: "Acne & Breakouts", col: "col-span-1 md:col-span-2 row-span-2", img: "{{ 'acne.webp' | asset_url }}", url: "/collections/acne-breakouts" },
        { id: "dryness", title: "Dryness & Dehydration", col: "col-span-1 md:col-span-1 row-span-1", img: "{{ 'dryness.webp' | asset_url }}", url: "/collections/dryness-dehydration" },
        { id: "pigment", title: "Dullness & Pigmentation", col: "col-span-1 md:col-span-1 row-span-1", img: "{{ 'dullness.webp' | asset_url }}", url: "/collections/dullness-pigmentation" },
        { id: "sun", title: "UV & Sun Protection", col: "col-span-1 md:col-span-1 row-span-1", img: "{{ 'uvrays.webp' | asset_url }}", url: "/collections/uv-sun-protection" },
        { id: "pores", title: "Pores & Texture", col: "col-span-1 md:col-span-1 row-span-1", img: "{{ 'pores.webp' | asset_url }}", url: "/collections/pores-texture" }
      ]
    }));
  });
</script>

<div x-data="concernSelector" class="w-full flex flex-col bg-white min-h-screen">
  
  <!-- Header Section -->
  <section class="pt-32 lg:pt-48 pb-16 px-6 lg:px-20 border-b border-brand-marble/5">
    <div class="max-w-7xl mx-auto flex flex-col lg:flex-row justify-between items-end gap-12">
      <div class="max-w-2xl">
        <p class="text-[10px] uppercase tracking-[0.4em] font-bold text-brand-aqua mb-6">Discovery Routine</p>
        <h1 class="font-serif text-5xl lg:text-7xl text-brand-slate leading-tight mb-8">
          Targeted <br />
          <span class="italic font-light text-brand-slate-light">Discovery</span>
        </h1>
        <p class="text-lg text-brand-slate-light/80 font-serif leading-relaxed italic">
          "We decode your skin's unique signals to synchronize a clinical routine that respects your natural biology."
        </p>
      </div>

      <div class="flex items-center space-x-12 pb-2">
        <div class="flex flex-col items-center">
          <span class="text-[10px] font-bold text-brand-aqua mb-2">01</span>
          <span class="text-xs uppercase tracking-widest font-black opacity-40 text-brand-slate">Analyze</span>
        </div>
        <div class="flex flex-col items-center">
          <span class="text-[10px] font-bold text-brand-aqua mb-2">02</span>
          <span class="text-xs uppercase tracking-widest font-black opacity-40 text-brand-slate">Match</span>
        </div>
        <div class="flex flex-col items-center">
          <span class="text-[10px] font-bold text-brand-aqua mb-2">03</span>
          <span class="text-xs uppercase tracking-widest font-black opacity-40 text-brand-slate">Sequence</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Bento Selector -->
  <section class="py-24 px-6 lg:px-20 bg-brand-glacial/10">
    <div class="max-w-7xl mx-auto">
      <div class="mb-12 flex justify-between items-center">
        <h2 class="font-serif text-3xl text-brand-slate italic">Select Your Primary Concern</h2>
        <div class="flex items-center space-x-2 text-brand-slate-light uppercase text-[10px] font-bold tracking-widest">
          <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="7" height="9" x="3" y="3" rx="1"/><rect width="7" height="5" x="14" y="3" rx="1"/><rect width="7" height="9" x="14" y="12" rx="1"/><rect width="7" height="5" x="3" y="16" rx="1"/></svg>
          <span>Concern Profile</span>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-4 gap-6 auto-rows-[250px]">
        <template x-for="(concern, i) in concerns" :key="concern.id">
          <a
            :href="concern.url"
            :class="[
              'relative group rounded-[40px] overflow-hidden border-2 border-transparent transition-all duration-500 block',
              concern.col
            ]"
          >
            <img
              :src="concern.img"
              class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110"
              :alt="concern.title"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-black/30 group-hover:bg-black/20 transition-all duration-500"></div>

            <div class="absolute bottom-8 left-8 right-8 text-left flex justify-between items-end">
              <h3 class="font-serif text-2xl !text-white leading-tight max-w-[150px]" x-text="concern.title"></h3>
              <div class="w-10 h-10 rounded-full border border-white/30 flex items-center justify-center !text-white backdrop-blur-md transition-all group-hover:border-white group-hover:bg-white group-hover:!text-brand-slate">
                <svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
              </div>
            </div>
          </a>
        </template>
      </div>
    </div>
  </section>

</div>
