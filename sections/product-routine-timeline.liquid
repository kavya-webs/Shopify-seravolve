<section class="py-20 lg:py-32 px-6 lg:px-20 bg-brand-charcoal text-white">
  <div class="max-w-4xl mx-auto">
    <div class="mb-16 text-center">
      <p class="text-[9px] uppercase tracking-[0.5em] font-bold mb-4 text-brand-aqua">Efficacy</p>
      <h2 class="font-serif text-3xl lg:text-5xl font-light">Expected Timeline</h2>
    </div>

    {%- assign timeline = product.metafields.custom.routine_timeline.value -%}
    {%- if timeline != blank -%}
      <div class="space-y-12 relative before:absolute before:inset-0 before:ml-5 before:-translate-x-px md:before:mx-auto md:before:translate-x-0 before:h-full before:w-0.5 before:bg-gradient-to-b before:from-brand-aqua before:via-brand-aqua/50 before:to-transparent">
        {%- for item in timeline -%}
          {%- assign split_item = item | split: ':' -%}
          <div class="relative flex items-center justify-between md:justify-normal md:odd:flex-row-reverse group is-active">
            
            <div class="flex items-center justify-center w-10 h-10 rounded-full border-4 border-brand-charcoal bg-brand-aqua shadow shrink-0 md:order-1 md:group-odd:-translate-x-1/2 md:group-even:translate-x-1/2 absolute left-0 md:left-1/2 -translate-x-1/2 md:translate-x-0 z-10">
              <svg class="w-4 h-4 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
            </div>
            
            <div class="w-[calc(100%-4rem)] md:w-[calc(50%-3rem)] ml-14 md:ml-0 p-6 rounded-2xl bg-white/5 border border-white/10 group-hover:border-brand-aqua/50 transition-colors">
              <div class="flex items-center space-x-2 mb-2">
                <span class="text-[10px] uppercase tracking-widest font-bold text-brand-aqua">{{ split_item.first }}</span>
              </div>
              <h3 class="text-base lg:text-lg font-medium text-white/90">{{ split_item.last | strip }}</h3>
            </div>
            
          </div>
        {%- endfor -%}
      </div>
    {%- else -%}
      <div class="py-12 px-6 border border-dashed border-white/20 rounded-2xl text-center italic text-white/50">
        Please fill out the `custom.routine_timeline` metafield (Format as "Week X: Result").
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Routine Timeline",
  "settings": [],
  "presets": [
    {
      "name": "Routine Timeline"
    }
  ]
}
{% endschema %}
