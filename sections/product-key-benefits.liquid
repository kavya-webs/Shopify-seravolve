<section class="py-20 lg:py-32 px-6 lg:px-20 bg-white">
  <div class="max-w-7xl mx-auto">
    <div class="mb-16 text-center">
      <h2 class="font-serif text-3xl lg:text-5xl font-light text-brand-slate mb-6">Key Benefits</h2>
    </div>

    {%- assign benefits = product.metafields.custom.key_benefits.value -%}
    
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 max-w-5xl mx-auto">
      {%- if benefits != blank -%}
        {%- for benefit in benefits -%}
          <div class="bg-[#f8faf9] rounded-3xl p-8 flex flex-col items-center text-center border border-brand-charcoal/5 hover:border-brand-aqua/20 transition-colors shadow-sm">
            <div class="w-12 h-12 rounded-full bg-brand-aqua/10 text-brand-aqua flex items-center justify-center mb-6">
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
            </div>
            <p class="font-serif text-lg text-brand-slate leading-tight">{{ benefit }}</p>
          </div>
        {%- endfor -%}
      {%- else -%}
        <!-- Fallback / Placeholder -->
        {%- for i in (1..4) -%}
          <div class="bg-[#f8faf9] rounded-3xl p-8 flex flex-col items-center text-center border border-dashed border-brand-charcoal/20">
             <p class="font-serif text-brand-slate/50 italic text-sm">Please fill out `custom.key_benefits` metafield</p>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Product Key Benefits",
  "settings": [],
  "presets": [
    {
      "name": "Product Key Benefits"
    }
  ]
}
{% endschema %}
