{% comment %}
  Storytelling "About Us" Page for SERAVOLVE
  Matches the exact brand palette (glacial, aqua-mist, aqua, slate, marble)
{% endcomment %}

{{ 'tailwind.css' | asset_url | stylesheet_tag }}

<!-- JSON-LD Structured Data -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": "{{ shop.url }}#organization",
      "name": "{{ shop.name }}",
      "url": "{{ shop.url }}",
      "logo": "{{ settings.logo | image_url: width: 500 | prepend: 'https:' }}",
      "description": "Clinical Skincare Formulated for Indian Skin."
    },
    {
      "@type": "AboutPage",
      "@id": "{{ shop.url }}{{ request.path }}",
      "url": "{{ shop.url }}{{ request.path }}",
      "name": "{{ page.title | escape }}",
      "description": "{{ page_description | default: shop.description | escape }}",
      "mainEntity": {
        "@id": "{{ shop.url }}#organization"
      }
    },
    {
      "@type": "Event",
      "name": "{{ section.settings.event_heading | escape }}",
      "startDate": "2026-06-25T11:00:00+05:30",
      "endDate": "2026-06-25T15:00:00+05:30",
      "eventAttendanceMode": "https://schema.org/OfflineEventAttendanceMode",
      "eventStatus": "https://schema.org/EventScheduled",
      "location": {
        "@type": "Place",
        "name": "SERAVOLVE Launch Event Location",
        "address": {
          "@type": "PostalAddress",
          "addressCountry": "IN"
        }
      },
      "description": "{{ section.settings.event_description | escape }}",
      "organizer": {
        "@id": "{{ shop.url }}#organization"
      }
    }
  ]
}
</script>

<style>
  /* Scroll-driven reveal animations using Intersection Observer classes */
  .story-reveal {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1), transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .story-reveal.is-visible {
    opacity: 1;
    transform: translateY(0);
  }
  
  /* Staggered children */
  .stagger-1 { transition-delay: 0.1s; }
  .stagger-2 { transition-delay: 0.2s; }
  .stagger-3 { transition-delay: 0.3s; }
  .stagger-4 { transition-delay: 0.4s; }

  /* Smooth scrolling for carousel */
  .snap-x-mandatory {
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
  }
  .snap-x-mandatory::-webkit-scrollbar {
    display: none;
  }
  .snap-center {
    scroll-snap-align: center;
  }
</style>

{%- comment -%}Pre-fetch product images to use as intelligent fallbacks{%- endcomment -%}
{%- assign fallback_products = collections.all.products -%}
{%- assign fb_count = fallback_products.size -%}

<article class="w-full bg-white overflow-hidden" x-data="{ }">
  
  <!-- 1. Opening: Light Cinematic Hero -->
  <section aria-labelledby="chapter-1" class="relative w-full min-h-[90svh] flex flex-col items-center justify-center bg-gradient-to-b from-white to-brand-glacial">
    {%- if section.settings.hero_image != blank -%}
      <div class="absolute inset-0 z-0 opacity-15">
        {{ section.settings.hero_image | image_url: width: 2000 | image_tag: class: 'w-full h-full object-cover', alt: section.settings.hero_image.alt | default: 'Seravolve Brand Background', fetchpriority: 'high' }}
      </div>
    {%- elsif fb_count > 0 -%}
      <div class="absolute inset-0 z-0 opacity-10">
        {{ fallback_products[0].featured_image | image_url: width: 2000 | image_tag: class: 'w-full h-full object-cover', alt: 'SERAVOLVE Products', fetchpriority: 'high' }}
      </div>
    {%- endif -%}
    
    <div class="relative z-10 max-w-3xl mx-auto px-6 text-center">
      <h1 id="chapter-1" class="font-serif text-[2.5rem] leading-[1.1] lg:text-6xl text-brand-slate tracking-tight mb-6 blur-in opacity-0" style="animation-delay: 0.1s; animation-duration: 0.9s;">
        {{ section.settings.hero_heading }}
      </h1>
      <p class="font-serif italic font-light text-brand-slate/85 text-xl lg:text-3xl blur-in opacity-0" style="animation-delay: 0.3s;">
        {{ section.settings.hero_subheading }}
      </p>
    </div>
    
    <div class="absolute bottom-10 left-1/2 -translate-x-1/2 animate-bounce opacity-50 text-brand-aqua">
      <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
    </div>
  </section>

  <!-- 2. The Why: Vision Statement -->
  <section aria-labelledby="chapter-2" class="w-full bg-white py-24 lg:py-32">
    <div class="max-w-7xl mx-auto px-6 lg:px-12 grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-24 items-center">
      <div class="story-reveal">
        <p class="text-[10px] uppercase tracking-[0.3em] font-accent font-bold text-brand-aqua mb-6">Our Vision</p>
        <h2 id="chapter-2" class="font-serif text-3xl lg:text-5xl text-brand-slate mb-8 leading-tight">
          {{ section.settings.vision_heading }}
        </h2>
        <blockquote class="border-l-2 border-brand-aqua/30 pl-6 mb-8">
          <p class="font-serif italic text-xl lg:text-2xl text-brand-slate/90 leading-relaxed">
            "{{ section.settings.vision_quote }}"
          </p>
        </blockquote>
        <p class="text-brand-slate/75 text-base leading-relaxed font-light">
          {{ section.settings.vision_text }}
        </p>
      </div>
      <figure class="relative aspect-[4/5] w-full rounded-2xl overflow-hidden shadow-xl shadow-brand-slate/5 story-reveal stagger-2">
        {% if section.settings.vision_image != blank %}
          {{ section.settings.vision_image | image_url: width: 1000 | image_tag: class: 'w-full h-full object-cover', alt: section.settings.vision_heading }}
        {%- elsif fb_count > 1 -%}
          {{ fallback_products[1].featured_image | image_url: width: 1000 | image_tag: class: 'w-full h-full object-cover', alt: 'SERAVOLVE Vision' }}
        {%- endif -%}
      </figure>
    </div>
  </section>

  <!-- 3. The Science: Brand Identity -->
  <section aria-labelledby="chapter-3" class="w-full bg-brand-glacial py-24 lg:py-32 relative">
    <div class="max-w-7xl mx-auto px-6 lg:px-12 grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16">
      
      <div class="lg:col-span-5 lg:sticky lg:top-32 h-fit story-reveal">
        <p class="text-[10px] uppercase tracking-[0.3em] font-accent font-bold text-brand-aqua mb-6">Our Science</p>
        <h2 id="chapter-3" class="font-serif text-3xl lg:text-4xl text-brand-slate mb-6 leading-tight">
          {{ section.settings.science_heading }}
        </h2>
        <p class="text-brand-slate/75 text-base leading-relaxed font-light mb-8">
          {{ section.settings.science_text }}
        </p>
        
        <ul class="space-y-6">
          {% for i in (1..3) %}
            {% capture pillar_key %}science_pillar_{{ i }}{% endcapture %}
            {% if section.settings[pillar_key] != blank %}
            <li class="flex items-start gap-4 story-reveal stagger-{{ i }}">
              <div class="w-6 h-6 rounded-full bg-brand-aqua/10 flex items-center justify-center shrink-0 mt-0.5">
                <svg class="w-3.5 h-3.5 text-brand-aqua" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              </div>
              <span class="text-sm font-medium text-brand-slate">{{ section.settings[pillar_key] }}</span>
            </li>
            {% endif %}
          {% endfor %}
        </ul>
      </div>

      <div class="lg:col-span-7 grid grid-cols-2 lg:grid-cols-1 gap-4 lg:gap-12">
        {% for i in (1..3) %}
          {% capture img_key %}science_image_{{ i }}{% endcapture %}
          <figure class="relative aspect-square lg:aspect-[4/3] w-full rounded-2xl overflow-hidden shadow-lg shadow-brand-slate/5 story-reveal {% if forloop.last %}col-span-2 lg:col-span-1 max-w-[60%] lg:max-w-full mx-auto{% endif %}">
            {% if section.settings[img_key] != blank %}
              {{ section.settings[img_key] | image_url: width: 1200 | image_tag: class: 'w-full h-full object-cover', alt: 'Science Process' }}
            {%- elsif fb_count > i -%}
              {{ fallback_products[i].featured_image | image_url: width: 1200 | image_tag: class: 'w-full h-full object-cover', alt: fallback_products[i].title }}
            {%- endif -%}
          </figure>
        {% endfor %}
      </div>
      
    </div>
  </section>

  <!-- 4. Formulated for You: Stats -->
  <section aria-labelledby="chapter-4" class="w-full bg-brand-aqua-mist py-24 lg:py-32 relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-brand-glacial to-brand-aqua-mist"></div>
    <div class="relative z-10 max-w-4xl mx-auto px-6 text-center story-reveal">
      <div class="bg-white/60 backdrop-blur-sm border border-white/40 rounded-[2rem] p-10 lg:p-16 shadow-xl shadow-brand-aqua/5">
        <h2 id="chapter-4" class="font-serif text-3xl lg:text-4xl text-brand-slate mb-6 leading-tight">
          {{ section.settings.stats_heading }}
        </h2>
        <p class="text-brand-slate/75 text-base max-w-xl mx-auto font-light mb-12">
          {{ section.settings.stats_description }}
        </p>
        
        <dl class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-4 divide-y md:divide-y-0 md:divide-x divide-brand-marble/30">
          {% for i in (1..3) %}
            {% capture stat_num %}stat_{{ i }}_num{% endcapture %}
            {% capture stat_lbl %}stat_{{ i }}_label{% endcapture %}
            {% if section.settings[stat_num] != blank %}
            <div class="flex flex-col pt-6 md:pt-0 story-reveal stagger-{{ i }}">
              <dt class="order-2 text-xs uppercase tracking-[0.2em] font-accent font-bold text-brand-aqua mt-2">{{ section.settings[stat_lbl] }}</dt>
              <dd class="order-1 font-serif text-5xl lg:text-6xl text-brand-slate">{{ section.settings[stat_num] }}</dd>
            </div>
            {% endif %}
          {% endfor %}
        </dl>
      </div>
    </div>
  </section>

  <!-- 5. The Launch Event: Gallery & Video -->
  <section aria-labelledby="chapter-5" class="w-full bg-white py-24 lg:py-32">
    <div class="max-w-7xl mx-auto px-6 lg:px-12 text-center mb-16 story-reveal">
      <p class="text-[10px] uppercase tracking-[0.3em] font-accent font-bold text-brand-aqua mb-6">The Launch</p>
      <h2 id="chapter-5" class="font-serif text-3xl lg:text-5xl text-brand-slate mb-6 leading-tight">
        {{ section.settings.event_heading }}
      </h2>
      <p class="text-brand-slate/75 text-base max-w-2xl mx-auto font-light">
        {{ section.settings.event_description }}
      </p>
    </div>

    <div class="max-w-7xl mx-auto px-6 lg:px-12">
      <div class="grid grid-cols-2 md:grid-cols-3 gap-4 lg:gap-6">
        
        <!-- Video Embed -->
        {% if section.settings.event_video != blank %}
        <figure class="col-span-2 md:col-span-3 aspect-video rounded-2xl overflow-hidden bg-brand-charcoal relative group cursor-pointer story-reveal" x-data="{ playing: false }" @click="playing = true">
          <template x-if="!playing">
            <div class="absolute inset-0 flex items-center justify-center z-10">
              <div class="w-16 h-16 rounded-full bg-white/20 backdrop-blur-md flex items-center justify-center group-hover:scale-110 transition-transform">
                <svg class="w-6 h-6 text-white ml-1" viewBox="0 0 24 24" fill="currentColor"><path d="M5 3l14 9-14 9V3z"/></svg>
              </div>
            </div>
          </template>
          <template x-if="!playing">
             {% if section.settings.event_video_poster != blank %}
                {{ section.settings.event_video_poster | image_url: width: 1400 | image_tag: class: 'w-full h-full object-cover opacity-80 group-hover:opacity-100 transition-opacity', alt: 'Launch Event Video' }}
             {%- elsif fb_count > 0 -%}
                {{ fallback_products[0].featured_image | image_url: width: 1400 | image_tag: class: 'w-full h-full object-cover opacity-80 group-hover:opacity-100 transition-opacity', alt: 'Launch Event Video' }}
             {%- endif -%}
          </template>
          <template x-if="playing">
            {%- if section.settings.event_video.type == 'youtube' -%}
              <iframe src="https://www.youtube.com/embed/{{ section.settings.event_video.id }}?autoplay=1&mute=0" class="w-full h-full" frameborder="0" allow="autoplay; encrypted-media" allowfullscreen></iframe>
            {%- else -%}
              <iframe src="https://player.vimeo.com/video/{{ section.settings.event_video.id }}?autoplay=1" class="w-full h-full" frameborder="0" allow="autoplay; fullscreen" allowfullscreen></iframe>
            {%- endif -%}
          </template>
        </figure>
        {% endif %}

        <!-- Masonry Photos -->
        {% for block in section.blocks %}
          {% if block.type == 'event_photo' %}
            <figure class="relative rounded-2xl overflow-hidden story-reveal stagger-{{ forloop.index | modulo: 4 }} {% if forloop.index == 1 or forloop.index == 4 %}aspect-[4/5]{% else %}aspect-square{% endif %}" {{ block.shopify_attributes }}>
              {% if block.settings.image != blank %}
                {{ block.settings.image | image_url: width: 800 | image_tag: class: 'w-full h-full object-cover hover:scale-105 transition-transform duration-700', alt: 'Launch Event Moment' }}
              {%- elsif fb_count > forloop.index0 -%}
                {{ fallback_products[forloop.index0].featured_image | image_url: width: 800 | image_tag: class: 'w-full h-full object-cover hover:scale-105 transition-transform duration-700', alt: fallback_products[forloop.index0].title }}
              {%- endif -%}
            </figure>
          {% endif %}
        {% endfor %}

      </div>
    </div>
  </section>

  <!-- 6. The Community: Influencer Reels Carousel -->
  <section aria-labelledby="chapter-6" class="w-full bg-brand-glacial py-24 lg:py-32 overflow-hidden">
    <div class="max-w-7xl mx-auto px-6 lg:px-12 text-center mb-16 story-reveal">
      <p class="text-[10px] uppercase tracking-[0.3em] font-accent font-bold text-brand-aqua mb-6">Our Community</p>
      <h2 id="chapter-6" class="font-serif text-3xl lg:text-5xl text-brand-slate mb-6 leading-tight">
        {{ section.settings.community_heading }}
      </h2>
      <p class="text-brand-slate/75 text-base max-w-2xl mx-auto font-light">
        {{ section.settings.community_description }}
      </p>
    </div>

    <!-- Horizontal scroll container -->
    <div class="w-full px-6 lg:px-12 pb-8 flex gap-6 overflow-x-auto snap-x-mandatory story-reveal" style="padding-left: max(1.5rem, calc((100vw - 80rem) / 2)); padding-right: max(1.5rem, calc((100vw - 80rem) / 2));">
      {% for block in section.blocks %}
        {% if block.type == 'influencer_reel' %}
          <div class="snap-center shrink-0 w-[260px] md:w-[300px] flex flex-col gap-4" {{ block.shopify_attributes }}>
            <a href="{{ block.settings.reel_url }}" target="_blank" rel="noopener noreferrer" class="relative aspect-[9/16] w-full rounded-2xl overflow-hidden bg-brand-charcoal group shadow-lg shadow-brand-slate/10">
              {% if block.settings.thumbnail != blank %}
                {{ block.settings.thumbnail | image_url: width: 600 | image_tag: class: 'w-full h-full object-cover opacity-90 group-hover:scale-105 group-hover:opacity-100 transition-all duration-500', alt: block.settings.name }}
              {%- elsif fb_count > forloop.index0 -%}
                {{ fallback_products[forloop.index0].featured_image | image_url: width: 600 | image_tag: class: 'w-full h-full object-cover opacity-90 group-hover:scale-105 group-hover:opacity-100 transition-all duration-500', alt: fallback_products[forloop.index0].title }}
              {%- endif -%}
              <!-- Play icon -->
              <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
                <div class="w-12 h-12 rounded-full bg-white/20 backdrop-blur-sm flex items-center justify-center group-hover:bg-brand-aqua/90 transition-colors">
                  <svg class="w-5 h-5 text-white ml-1" viewBox="0 0 24 24" fill="currentColor"><path d="M5 3l14 9-14 9V3z"/></svg>
                </div>
              </div>
            </a>
            <div class="px-2">
              <h3 class="font-serif font-bold text-brand-slate text-lg">{{ block.settings.name }}</h3>
              <p class="text-brand-aqua text-sm font-accent tracking-wide">{{ block.settings.handle }}</p>
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </section>

  <!-- 7. Join the Ritual: Final CTA -->
  <section aria-labelledby="chapter-7" class="w-full relative overflow-hidden">
    <div class="h-16 bg-gradient-to-b from-brand-glacial to-[#defffd]"></div>
    <div class="bg-[#defffd] pb-32 pt-12 lg:pt-20 lg:pb-40">
      <div class="max-w-md lg:max-w-2xl mx-auto px-6 text-center story-reveal pb-16 lg:pb-0">
        <p class="text-[9px] uppercase tracking-[0.4em] font-accent font-bold text-brand-aqua mb-6">
          {{ section.settings.cta_tagline | escape }}
        </p>
        <h2 id="chapter-7" class="font-serif text-3xl lg:text-5xl text-brand-slate mb-6 leading-tight">
          {{ section.settings.cta_heading }}
        </h2>
        <p class="text-base text-brand-slate/70 font-light mb-12 max-w-md mx-auto">
          {{ section.settings.cta_description | escape }}
        </p>
        <a href="{{ section.settings.cta_button_link | default: routes.all_products_collection_url }}" class="group inline-flex items-center justify-center space-x-2 bg-brand-aqua-deep text-white px-6 py-4 md:px-10 md:py-5 rounded-full text-[10px] md:text-[12px] uppercase tracking-[0.15em] md:tracking-[0.2em] font-accent font-bold hover:bg-brand-aqua transition-all duration-300 shadow-lg shadow-brand-aqua/20 active:scale-[0.97] w-full max-w-[260px] md:max-w-none md:w-auto mx-auto leading-tight mb-8">
          <span class="text-center">{{ section.settings.cta_button_label | escape }}</span>
          <svg class="w-3 h-3 md:w-4 md:h-4 group-hover:translate-x-1 transition-transform shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

</article>

<script>
document.addEventListener('DOMContentLoaded', () => {
  // Setup Intersection Observer for scroll-driven animations
  const observerOptions = {
    root: null,
    rootMargin: '0px 0px -10% 0px',
    threshold: 0.1
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('is-visible');
      }
    });
  }, observerOptions);

  document.querySelectorAll('.story-reveal').forEach(el => {
    observer.observe(el);
  });
});
</script>

