{%- if request.page_type == 'index' -%}
<script type="application/ld+json">
{
  "@context": "http://schema.org",
  "@type": "WebSite",
  "name": {{ shop.name | json }},
  "url": {{ shop.url | json }},
  "potentialAction": {
    "@type": "SearchAction",
    "target": "{{ shop.url }}/search?q={search_term_string}",
    "query-input": "required name=search_term_string"
  }
}
</script>
<script type="application/ld+json">
{
  "@context": "http://schema.org",
  "@type": "Organization",
  "name": {{ shop.name | json }},
  "url": {{ shop.url | json }},
  "logo": "https:{{ 'logo.png' | asset_url }}"
}
</script>
{%- endif -%}

{%- if request.page_type == 'product' -%}
<script type="application/ld+json">
{
  "@context": "http://schema.org/",
  "@type": "Product",
  "name": {{ product.title | json }},
  "image": [
    {%- for media in product.media -%}
      {{ media | image_url: width: 1024 | prepend: "https:" | json }}{%- unless forloop.last -%},{%- endunless -%}
    {%- endfor -%}
  ],
  "description": {{ product.description | strip_html | json }},
  {%- if product.selected_or_first_available_variant.sku != blank -%}
    "sku": {{ product.selected_or_first_available_variant.sku | json }},
  {%- endif -%}
  "brand": {
    "@type": "Brand",
    "name": {{ product.vendor | default: shop.name | json }}
  },
  "offers": {
    "@type": "Offer",
    "url": {{ request.origin | append: product.url | json }},
    "priceCurrency": {{ cart.currency.iso_code | json }},
    "price": {{ product.selected_or_first_available_variant.price | divided_by: 100.0 | json }},
    "itemCondition": "http://schema.org/NewCondition",
    "availability": "{%- if product.selected_or_first_available_variant.available -%}http://schema.org/InStock{%- else -%}http://schema.org/OutOfStock{%- endif -%}"
  }
}
</script>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What skin types is {{ product.title | escape }} suitable for?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "This formula is designed for all skin types. It is non-comedogenic, meaning it won't clog pores. If you have highly reactive or sensitised skin, we recommend a patch test before first use."
      }
    },
    {
      "@type": "Question",
      "name": "How long before I see visible results?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Studies show initial improvements within 14 days of consistent use, with full results visible at the 8-week mark. Individual results may vary based on skin condition and routine consistency."
      }
    },
    {
      "@type": "Question",
      "name": "Can I use this with other active ingredients?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. This product is compatible with most skincare actives. However, if you are using prescription retinoids or strong chemical exfoliants (AHA/BHA), we suggest alternating usage days to prevent over-sensitisation."
      }
    },
    {
      "@type": "Question",
      "name": "Is this product tested on animals?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Absolutely not. SERAVOLVE is proudly cruelty-free and never tests on animals at any stage of development. All efficacy testing is conducted through in-vitro studies and voluntary human trials."
      }
    },
    {
      "@type": "Question",
      "name": "What is the shelf life after opening?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Once opened, this product retains full potency for 12 months (12M PAO). Store in a cool, dry place away from direct sunlight to preserve the active ingredients."
      }
    }
  ]
}
</script>
{%- endif -%}
